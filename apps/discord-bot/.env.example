# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Optional: role that can see all workspace channels (Monarch staff).
# Also pinged on new support tickets and granted access to ticket channels.
DISCORD_STAFF_ROLE_ID=
# Role applied during /ui member sessions (all other roles stripped temporarily)
DISCORD_UI_ROLE_ID=

# Captcha verification roles
DISCORD_CAPTCHA_UNVERIFIED_ROLE_ID=
DISCORD_CAPTCHA_VERIFIED_ROLE_ID=
DISCORD_CAPTCHA_MEMBER_ROLE_ID=

# Same Postgres as monarch-portal (portal schema via search_path in URL if needed)
DATABASE_URL=

# Portal URLs
PORTAL_PUBLIC_URL=http://localhost:4000
PORTAL_INTERNAL_URL=http://localhost:4000

# Shared secret (must match monarch-portal DISCORD_BOT_INTERNAL_SECRET; use a random string, NOT the bot token)
DISCORD_BOT_INTERNAL_SECRET=change-me-long-random-secret

# HTTP server for portal → bot calls
BOT_HTTP_PORT=4100
# Path to monarch-portal root (so bot can read chat uploads for Discord relay)
PORTAL_UPLOADS_ROOT=../../monarch-portal

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StaffRole {
  ADMIN
  EDITOR
  SHOP_MANAGER
}

enum NewsCategory {
  modding
  servers
  software
  company
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum JobStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ApplicationStatus {
  NEW
  REVIEWED
  SHORTLISTED
  REJECTED
}

enum ContactTopic {
  general
  partnership
  modding
  servers
  software
  other
}

enum ContactEnquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  SKIPPED
  FAILED
}

enum OAuthProvider {
  steam
  discord
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  WAITLIST
}

enum ProductCategory {
  modding
  software
  hosting
  bundle
  other
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
  DISPUTED
}

enum LicenseStatus {
  ACTIVE
  GRACE
  REVOKED
  SUSPENDED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model StaffUser {
  id                  String        @id @default(cuid())
  email               String        @unique
  passwordHash        String
  name                String
  role                StaffRole     @default(EDITOR)
  totpSecretEnc       String?
  totpEnabled         Boolean       @default(false)
  backupCodesHash     String?
  failedLoginAttempts Int           @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  sessions            Session[]
  pendingTwoFactor    PendingTwoFactor?
  supportNotes        SupportNote[]
}

model Session {
  id        String    @id @default(cuid())
  staffId   String
  expiresAt DateTime
  staff     StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model PendingTwoFactor {
  id        String    @id @default(cuid())
  staffId   String    @unique
  expiresAt DateTime
  staff     StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model NewsPost {
  id             String       @id @default(cuid())
  slug           String       @unique
  title          String
  excerpt        String
  body           String       @db.Text
  category       NewsCategory
  status         NewsStatus   @default(DRAFT)
  bannerImageUrl String?
  heroImageUrl   String?
  externalLink   String?
  ctaButtons     Json?
  publishedAt    DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([publishedAt])
  @@index([status])
}

model Job {
  id               String           @id @default(cuid())
  slug             String           @unique
  title            String
  team             String
  workType         String
  excerpt          String
  body             String           @db.Text
  applicationEmail String           @default("careers@monarch-modding.com")
  status           JobStatus        @default(DRAFT)
  applyFormConfig  Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  applications     JobApplication[]

  @@index([status])
}

model JobApplication {
  id           String            @id @default(cuid())
  jobId        String
  status       ApplicationStatus @default(NEW)
  fullName     String
  email        String
  phone        String?
  location     String?
  portfolioUrl String?
  githubUrl    String?
  discord      String?
  coverLetter  String            @db.Text
  staffNotes   String?           @db.Text
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  job          Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  files        ApplicationFile[]

  @@index([jobId])
  @@index([status])
  @@index([createdAt])
}

model ApplicationFile {
  id            String         @id @default(cuid())
  applicationId String
  filename      String
  storagePath   String
  mimeType      String
  sizeBytes     Int
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model ContactEnquiry {
  id                 String               @id @default(cuid())
  fullName           String
  email              String
  phone              String?
  company            String?
  topic              ContactTopic
  message            String               @db.Text
  status             ContactEnquiryStatus @default(NEW)
  customerAckStatus  EmailDeliveryStatus  @default(PENDING)
  staffNotifyStatus  EmailDeliveryStatus  @default(PENDING)
  staffNotes         String?              @db.Text
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([topic])
}

// ─── Customer Accounts ───────────────────────────────────────────────────────

model Customer {
  id                 String             @id @default(cuid())
  email              String?            @unique
  displayName        String
  avatarUrl          String?
  passwordHash       String?
  totpSecretEnc      String?
  totpEnabled        Boolean            @default(false)
  backupCodesHash    String?
  onboardingComplete Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  accounts           ConnectedAccount[]
  sessions           CustomerSession[]
  orders             Order[]
  licenses           ServerLicense[]
  supportNotes       SupportNote[]
  reviews            ProductReview[]
}

model ConnectedAccount {
  id           String        @id @default(cuid())
  customerId   String
  provider     OAuthProvider
  providerId   String
  username     String?
  accessToken  String?
  refreshToken String?
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([customerId])
}

model CustomerSession {
  id         String   @id @default(cuid())
  customerId String
  expiresAt  DateTime
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ─── Products ────────────────────────────────────────────────────────────────

model Product {
  id              String             @id @default(cuid())
  slug            String             @unique
  title           String
  excerpt         String
  body            String             @db.Text
  status          ProductStatus      @default(DRAFT)
  category        ProductCategory
  imageUrl        String?
  previewImages   Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  variants        ProductVariant[]
  files           ProductFile[]
  changelog       ProductChangelog[]
  bundleItems     BundleItem[]       @relation("BundleProduct")
  bundleOf        BundleItem[]       @relation("BundleParent")
  waitlistEntries Waitlist[]
  reviews         ProductReview[]
}

model ProductVariant {
  id            String          @id @default(cuid())
  productId     String
  name          String
  description   String?
  priceUsd      Int
  stripePriceId String?
  maxServers    Int?
  active        Boolean         @default(true)
  sortOrder     Int             @default(0)
  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  licenses      ServerLicense[]
  cartItems     CartItem[]

  @@index([productId])
}

model ProductFile {
  id         String   @id @default(cuid())
  productId  String
  label      String
  storageKey String
  version    String
  sizeBytes  Int
  isLatest   Boolean  @default(true)
  uploadedAt DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isLatest])
}

model ProductChangelog {
  id        String   @id @default(cuid())
  productId String
  version   String
  notes     String   @db.Text
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model BundleItem {
  id        String  @id @default(cuid())
  bundleId  String
  productId String
  bundle    Product @relation("BundleParent", fields: [bundleId], references: [id], onDelete: Cascade)
  product   Product @relation("BundleProduct", fields: [productId], references: [id])

  @@unique([bundleId, productId])
}

model Waitlist {
  id        String   @id @default(cuid())
  productId String
  email     String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, email])
}

// ─── Cart, Orders ─────────────────────────────────────────────────────────────

model CartItem {
  id        String         @id @default(cuid())
  sessionId String
  variantId String
  qty       Int            @default(1)
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@index([sessionId])
}

model AffiliateCode {
  id            String   @id @default(cuid())
  code          String   @unique
  label         String
  discountPct   Int      @default(0)
  commissionPct Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  orders        Order[]
}

model Order {
  id                    String         @id @default(cuid())
  customerId            String
  stripeSessionId       String         @unique
  stripePaymentIntentId String?
  currency              String         @default("gbp")
  totalMinorUnits       Int
  tosAcceptedAt         DateTime?
  status                OrderStatus    @default(PENDING)
  affiliateCodeId       String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  customer              Customer       @relation(fields: [customerId], references: [id])
  items                 OrderItem[]
  supportNotes          SupportNote[]
  affiliateCode         AffiliateCode? @relation(fields: [affiliateCodeId], references: [id])
}

model OrderItem {
  id              String         @id @default(cuid())
  orderId         String
  variantId       String
  priceMinorUnits Int
  currency        String         @default("gbp")
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant         ProductVariant @relation(fields: [variantId], references: [id])
  license         ServerLicense?

  @@index([orderId])
}

// ─── Licenses ─────────────────────────────────────────────────────────────────

model ServerLicense {
  id             String             @id @default(cuid())
  customerId     String
  orderItemId    String             @unique
  variantId      String
  status         LicenseStatus      @default(ACTIVE)
  maxServers     Int?
  gracePeriodEnd DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  customer       Customer           @relation(fields: [customerId], references: [id])
  orderItem      OrderItem          @relation(fields: [orderItemId], references: [id])
  variant        ProductVariant     @relation(fields: [variantId], references: [id])
  servers        RegisteredServer[]
}

model RegisteredServer {
  id             String        @id @default(cuid())
  licenseId      String
  ipAddress      String
  label          String?
  isTestServer   Boolean       @default(false)
  addedAt        DateTime      @default(now())
  lastVerifiedAt DateTime?
  license        ServerLicense @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, ipAddress])
  @@index([ipAddress])
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model ProductReview {
  id         String       @id @default(cuid())
  productId  String
  customerId String
  rating     Int
  title      String?
  body       String       @db.Text
  status     ReviewStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  product    Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([productId, customerId])
  @@index([productId, status])
  @@index([status])
}

// ─── Support ──────────────────────────────────────────────────────────────────

model SupportNote {
  id         String    @id @default(cuid())
  orderId    String?
  customerId String
  body       String    @db.Text
  staffId    String
  createdAt  DateTime  @default(now())
  order      Order?    @relation(fields: [orderId], references: [id])
  customer   Customer  @relation(fields: [customerId], references: [id])
  staff      StaffUser @relation(fields: [staffId], references: [id])
}

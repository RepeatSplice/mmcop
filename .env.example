DATABASE_URL=postgresql://postgres:password@localhost:5432/monarch
SESSION_SECRET=change-me-min-32-characters-long-random
TOTP_ENCRYPTION_KEY=change-me-32-characters-minimum-key!!
SITE_URL=http://localhost:4321
# Admin subdomain hostname (no protocol). When set, /manage is only accessible here.
# Leave blank in local dev to access /manage on the main site as normal.
# Production: ADMIN_HOST=admin.monarch-dayz.com
ADMIN_HOST=
BOOTSTRAP_ADMIN_EMAIL=admin@monarch-dayz.com
BOOTSTRAP_ADMIN_PASSWORD=change-on-first-deploy

# Email (Resend): contact form ack + staff alerts; optional until go-live
RESEND_API_KEY=
EMAIL_FROM=enquiries@monarch-dayz.com
CONTACT_NOTIFY_EMAIL=careers@monarch-modding.com

# Customer OAuth
STEAM_API_KEY=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:4321/api/auth/discord/callback

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Support stack
# Chatwoot: deploy via docs/chatwoot-coolify.md, get token from Settings > Inboxes > Website inbox
CHATWOOT_BASE_URL=https://support.monarch-dayz.com
CHATWOOT_WIDGET_TOKEN=

# ElevenLabs Conversational AI: elevenlabs.io > Conversational AI > Create agent > Agent ID
ELEVENLABS_AGENT_ID=

# Algolia search: algolia.com > Create app > API Keys
# ALGOLIA_SEARCH_KEY is the "Search-Only API Key" (safe to expose)
# ALGOLIA_ADMIN_KEY is the "Admin API Key" (server-side indexing only, never expose client-side)
ALGOLIA_APP_ID=
ALGOLIA_SEARCH_KEY=
ALGOLIA_ADMIN_KEY=

# Cloudflare Turnstile (contact form): dash.cloudflare.com > Turnstile > Add site
# Site key is public; secret key is server-only. Optional in dev — form works without it.
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=


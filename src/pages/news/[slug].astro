---
import MonarchBasicPage from "../../components/MonarchBasicPage.astro";
import { formatLongDate, getCategoryLabel, getNewsBySlug } from "../../lib/news";
import { renderMarkdown } from "../../lib/markdown";

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/news");

const post = await getNewsBySlug(slug);
if (!post) return Astro.redirect("/news");

const longDate = formatLongDate(post.publishedAt);
const categoryLabel = getCategoryLabel(post.category);
const bannerImage = post.bannerImageUrl ?? "/News_Banner.png";
const bodyHtml = renderMarkdown(post.body);
const primaryCta = post.ctaButtons[0];
const extraCtas = post.ctaButtons.slice(1);
const footerCta = post.externalLink
	? { label: "Visit related site", href: post.externalLink, external: true }
	: { label: "All news", href: "/news" };
---

<MonarchBasicPage
	title={`${post.title} | Monarch News`}
	description={post.excerpt}
	eyebrow={`${categoryLabel} · ${longDate}`}
	heading={post.title}
	lead={post.excerpt}
	image={bannerImage}
	cta={primaryCta ? { label: primaryCta.label, href: primaryCta.href, external: primaryCta.external } : footerCta}
	ctas={post.ctaButtons}
	mainClass="mx-auto mt-20 flex max-w-3xl flex-col gap-10 px-6 pb-20"
>
	{
		post.heroImageUrl && (
			<figure class="m-0 overflow-hidden rounded border border-zinc-200 bg-zinc-50">
				<img src={post.heroImageUrl} alt="" class="mx-auto max-h-80 w-full object-contain p-4" loading="lazy" />
			</figure>
		)
	}

	<article class="monarch-article w-full max-w-none" set:html={bodyHtml} />

	{
		extraCtas.length > 0 && (
			<div class="flex flex-wrap gap-3 border-t border-zinc-200 pt-8">
				{extraCtas.map((btn) => (
					<a
						class:list={[
							"font-display inline-flex min-h-[44px] items-center justify-center px-5 py-2.5 text-[13px] uppercase tracking-wide",
							btn.style === "secondary"
								? "border border-brand-black bg-white text-brand-black hover:bg-zinc-50"
								: "border-0 bg-brand-black text-white hover:bg-zinc-800",
						]}
						href={btn.href}
						{...(btn.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
					>
						{btn.label}
					</a>
				))}
			</div>
		)
	}

	<footer class="flex flex-wrap items-center justify-between gap-4 border-t border-zinc-200 pt-8">
		<a class="font-display text-[13px] uppercase tracking-wide text-monarch-500 hover:text-brand-black" href="/news">
			← Back to news
		</a>
		{
			post.externalLink ? (
				<a
					class="font-display text-[13px] uppercase tracking-wide text-monarch-500 hover:text-brand-black"
					href={post.externalLink}
					target="_blank"
					rel="noopener noreferrer"
				>
					External link →
				</a>
			) : null
		}
	</footer>
</MonarchBasicPage>

---
import SiteLayout from "../layouts/SiteLayout.astro";
import MonarchPageHero from "../components/MonarchPageHero.astro";
import { Icon } from "astro-icon/components";
import { listPublishedJobs } from "../lib/jobs";

export const prerender = false;

let openings: Awaited<ReturnType<typeof listPublishedJobs>> = [];
try {
	openings = await listPublishedJobs();
} catch {
	openings = [];
}
---

<SiteLayout
	title="Careers | Monarch"
	description="Careers at Monarch: join our DayZ modding, software, and community server teams. Remote-first, based in New Hampshire."
	mainClass="mx-auto mt-20 flex max-w-7xl flex-col gap-24 px-6 pb-24"
>
	<slot slot="pre-main">
		<MonarchPageHero
			eyebrow="Company"
			title="Careers"
			lead="We hire developers, designers, and operators who live in the DayZ ecosystem and care about shipping reliable work for communities."
			image="/Careers_Banner.png"
			cta={{ label: "Work with us", href: "/work-with-us" }}
		/>
	</slot>

	<!-- ── Why Monarch ── -->
	<section class="mx-auto max-w-3xl text-center" data-scroll-reveal>
		<p class="st-reveal m-0 font-display text-[11px] uppercase tracking-[0.18em] text-monarch-500">Why Monarch</p>
		<h2 class="st-reveal m-0 mt-3 font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em] text-brand-black">
			Small team. Large output.
		</h2>
		<p class="st-reveal m-0 mt-4 text-[15px] leading-relaxed text-zinc-600 sm:text-base">
			You will work on mods, tools, and live servers that real players and server owners depend on. Roles span Monarch
			Modding, Operation Monarch, and Monarch Software. We are remote-first, based in New Hampshire — we ship deliberate
			work, not slide decks.
		</p>
		<div class="st-reveal mt-8 flex flex-wrap justify-center gap-6">
			{[
				{ label: "2019", desc: "Active in DayZ" },
				{ label: "Remote", desc: "Remote-first team" },
				{ label: "NH", desc: "Based in New Hampshire" },
			].map((s) => (
				<div class="text-center">
					<p class="m-0 font-display text-2xl font-medium text-monarch-500">{s.label}</p>
					<p class="m-0 font-display text-[10px] uppercase tracking-[0.15em] text-zinc-500">{s.desc}</p>
				</div>
			))}
		</div>
	</section>

	<!-- ── Open roles ── -->
	<section aria-labelledby="open-roles-heading" data-scroll-reveal>
		<header class="monarch-section-header">
			<p class="monarch-section-kicker st-reveal">Open roles</p>
			<h2
				id="open-roles-heading"
				class="monarch-section-heading st-reveal m-0 font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em] text-brand-black"
			>
				Join the team
			</h2>
			{openings.length > 0 && (
				<p class="monarch-section-lead st-reveal mx-auto mt-3 max-w-2xl text-[15px] leading-relaxed text-zinc-600 sm:text-base">
					{openings.length} open role{openings.length === 1 ? "" : "s"} right now. All positions are remote.
				</p>
			)}
		</header>

		{openings.length > 0 ? (
			<ul class="st-reveal mt-10 list-none space-y-4 p-0" id="open-roles">
				{openings.map((role) => (
					<li class="group border border-zinc-200 bg-white transition-all hover:border-zinc-400 hover:shadow-sm">
						<div class="flex flex-col gap-6 px-6 py-6 sm:flex-row sm:items-center sm:justify-between sm:px-8">
							<div class="min-w-0 flex-1">
								<p class="m-0 font-display text-[11px] uppercase tracking-[0.18em] text-monarch-500">
									{role.team} · {role.workType}
								</p>
								<h3 class="m-0 mt-2 font-display text-lg font-medium uppercase tracking-wide text-brand-black">
									<a href={role.href} class="transition-colors hover:text-monarch-500">
										{role.title}
									</a>
								</h3>
								<p class="m-0 mt-2 max-w-2xl text-[15px] leading-relaxed text-zinc-600">{role.excerpt}</p>
							</div>
							<div class="flex shrink-0 gap-3">
								<a href={role.href} class="monarch-pill-btn monarch-pill-btn--secondary">
									About role
								</a>
								<a href={`${role.href}#apply`} class="monarch-pill-btn">
									Apply
									<Icon name="lucide:arrow-right" class="size-4 shrink-0" is:inline aria-hidden="true" />
								</a>
							</div>
						</div>
					</li>
				))}
			</ul>
		) : (
			<div class="st-reveal mt-10 border border-dashed border-zinc-300 bg-white px-8 py-16 text-center">
				<svg class="mx-auto mb-4 h-10 w-10 text-zinc-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2zM16 3H8a2 2 0 00-2 2v2h12V5a2 2 0 00-2-2z" />
				</svg>
				<p class="m-0 font-display text-sm uppercase tracking-widest text-zinc-400">No open roles right now</p>
				<p class="m-0 mt-2 text-sm text-zinc-500">Check back soon, or reach out to express general interest.</p>
				<a href="/contact" class="monarch-pill-btn mt-6 inline-flex">
					Get in touch
					<Icon name="lucide:arrow-right" class="size-4 shrink-0" is:inline aria-hidden="true" />
				</a>
			</div>
		)}
	</section>

	<!-- ── What we're looking for ── -->
	<section aria-labelledby="looking-for" data-scroll-reveal>
		<header class="monarch-section-header">
			<p class="monarch-section-kicker st-reveal">Disciplines</p>
			<h2
				id="looking-for"
				class="monarch-section-heading st-reveal m-0 font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em] text-brand-black"
			>
				What we look for
			</h2>
		</header>
		<div class="st-reveal mt-10 grid gap-5 sm:grid-cols-3">
			{[
				{
					icon: "lucide:code-2",
					title: "Developers",
					body: "Gameplay systems, automation, build pipelines, and the glue between DayZ updates and what your server runs on Monday.",
				},
				{
					icon: "lucide:pen-tool",
					title: "UI / UX designers",
					body: "Panels, branding, and in game interfaces so Monarch services feel cohesive from Discord to deploy.",
				},
				{
					icon: "lucide:globe",
					title: "Server operators",
					body: "Live Operation Monarch servers, events, and community moderation aligned with Monarch content releases.",
				},
			].map((item) => (
				<div class="group flex gap-4 border border-zinc-200 bg-white px-6 py-6 transition-colors hover:border-zinc-300 sm:flex-col sm:gap-4">
					<div class="flex h-10 w-10 shrink-0 items-center justify-center border border-zinc-200 bg-zinc-50">
						<Icon name={item.icon} class="size-4.5 text-monarch-500" is:inline aria-hidden="true" />
					</div>
					<div>
						<h3 class="m-0 font-display text-sm font-medium uppercase tracking-wide text-brand-black">{item.title}</h3>
						<p class="m-0 mt-2 text-[15px] leading-relaxed text-zinc-600">{item.body}</p>
					</div>
				</div>
			))}
		</div>
	</section>

	<!-- ── CTA ── -->
	<section
		class="st-reveal relative overflow-hidden border border-zinc-200 bg-brand-black px-8 py-16 text-center text-white sm:px-12 sm:py-20"
		data-scroll-reveal
	>
		<p class="m-0 font-display text-[11px] uppercase tracking-[0.2em] text-white/50">Monarch Careers</p>
		<h2 class="m-0 mt-3 font-display text-[clamp(1.5rem,4vw,2.5rem)] font-medium uppercase leading-tight tracking-wide">
			Don't see the right role?
		</h2>
		<p class="mx-auto m-0 mt-4 max-w-xl text-[15px] leading-relaxed text-white/75 sm:text-base">
			Send us a general application or get in touch. We hire when the right person shows up, not just when a role is listed.
		</p>
		<div class="mt-8 flex flex-wrap justify-center gap-3">
			<a
				class="font-display inline-flex min-h-[44px] items-center gap-2 bg-white px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-brand-black transition-colors hover:bg-zinc-100"
				href="/contact"
			>
				Get in touch
			</a>
			<a
				class="font-display inline-flex min-h-[44px] items-center gap-2 border border-white/40 px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-white transition-colors hover:bg-white/10"
				href="/about-monarch"
			>
				About Monarch
			</a>
		</div>
	</section>
</SiteLayout>

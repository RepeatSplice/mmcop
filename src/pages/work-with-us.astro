<script>
	function initCommissionTabs() {
		const tabs = document.querySelectorAll<HTMLButtonElement>("[data-commission-tab]");
		const panels = document.querySelectorAll<HTMLElement>("[data-commission-panel]");
		if (!tabs.length || document.body.dataset.commissionTabsBound === "1") return;
		document.body.dataset.commissionTabsBound = "1";

		tabs.forEach((tab) => {
			tab.addEventListener("click", () => {
				const id = tab.dataset.commissionTab;
				tabs.forEach((t) => {
					const active = t === tab;
					t.classList.toggle("is-active", active);
					t.setAttribute("aria-selected", active ? "true" : "false");
				});
				panels.forEach((p) => {
					const active = p.dataset.commissionPanel === id;
					p.classList.toggle("is-active", active);
					if (active) p.removeAttribute("hidden");
					else p.setAttribute("hidden", "");
				});
			});
		});
	}

	initCommissionTabs();
	document.addEventListener("astro:page-load", initCommissionTabs);
</script>

---
import "../styles/global.css";
import MonarchHeader from "../components/MonarchHeader.astro";
import MonarchFooter from "../components/MonarchFooter.astro";
import HeroCarousel from "../components/HeroCarousel.astro";
import ShopByScenario from "../components/ShopByScenario.astro";
import AboutMonarch from "../components/AboutMonarch.astro";
import HowWeWork from "../components/HowWeWork.astro";
import NewsUpdates from "../components/NewsUpdates.astro";
import ContactSection from "../components/ContactSection.astro";
import PartnersBrandTiles from "../components/PartnersBrandTiles.astro";
import ShopPreview from "../components/ShopPreview.astro";
import StoreReviews from "../components/StoreReviews.astro";
import { featuredPartners } from "../lib/partners.ts";
import { getChatwootBaseUrl, getChatwootWidgetToken } from "../lib/env";
import { getCustomerFromSession } from "../lib/customer-auth/session";

const chatwootBase = getChatwootBaseUrl();
const chatwootToken = getChatwootWidgetToken();
let customer = null;
if (chatwootToken) {
	try { customer = await getCustomerFromSession(Astro.cookies); } catch { customer = null; }
}

const heroSlides = [
	{
		src: "/Hero_Custom_Weapons.png",
		alt: "Monarch custom DayZ weapons and gear in game",
		title: "Custom weapons & packs",
		lead: "Weapon lines, configs, and workshop releases built for your ruleset and wipe calendar.",
		ctas: [
			{ label: "Browse the shop", href: "/shop" },
			{ label: "Work with us", href: "/work-with-us" },
		],
	},
	{
		src: "/Hero_Custom_Mapping.png",
		alt: "Monarch custom DayZ mapping and world building",
		title: "Custom mapping",
		lead: "Bases, arenas, and playable spaces shaped for your server identity and season plans.",
		ctas: [
			{ label: "How we work", href: "/how-we-work" },
			{ label: "Contact", href: "/contact" },
		],
	},
	{
		src: "/Hero_Software_Scripting.png",
		alt: "Monarch Software DayZ scripting and tooling",
		title: "Software & scripting",
		lead: "Bots, API bridges, dedi utilities, and PBO workflows that connect your game stack to the web.",
		ctas: [
			{ label: "Monarch Software", href: "/monarch-software" },
			{ label: "Work with us", href: "/work-with-us" },
		],
	},
	{
		src: "/Hero_GFX.png",
		alt: "Monarch GFX and in game UI design",
		title: "GFX & interfaces",
		lead: "Panels, branding, and in game UI so your community looks cohesive from Discord to deploy.",
		ctas: [
			{ label: "Our services", href: "/#monarch-services" },
			{ label: "About Monarch", href: "/about-monarch" },
		],
	},
	{
		src: "/Hero_Hosting.png",
		alt: "Monarch Hosting and DayZ server infrastructure",
		title: "Server infrastructure",
		lead: "Monarch Hosting launches in 2027. Until then, VYKIX covers performance focused DayZ hardware.",
		ctas: [
			{ label: "Monarch Hosting", href: "/monarch-hosting" },
			{ label: "VYKIX", href: "https://www.vykix.com", external: true },
		],
	},
];

/** Monarch Services strip, left to right */
const scenarios = [
	{
		title: "Monarch Modding",
		tagline: "Custom DayZ packs and workshop content",
		detail: "Weapon lines, configs, and releases built for your ruleset and wipe calendar.",
		href: "/monarch-modding",
		image: "/MM_Service_Banner.png",
		imageVariant: "banner" as const,
		imagePosition: "center",
	},
	{
		title: "Operation Monarch",
		tagline: "Community servers and live events",
		detail: "Curated worlds, seasonal play, and a player home tied to Monarch built ops.",
		href: "/operation-monarch",
		image: "/OPM_Service_Banner.png",
		imageVariant: "banner" as const,
		imagePosition: "center",
	},
	{
		title: "Monarch Software",
		tagline: "Tools for creators and operators",
		detail: "Bots, API bridges, dedi utilities, and PBO workflows linking game to web.",
		href: "/monarch-software",
		image: "/SOFT_Service_Banner.png",
		imageVariant: "banner" as const,
		imagePosition: "center",
	},
	{
		title: "Monarch Hosting",
		tagline: "Server infrastructure",
		detail: "Monarch Hosting arrives in 2027. Until then, VYKIX covers performance DayZ hardware.",
		href: "/monarch-hosting",
		image: "/HOST_Service_Banner.png",
		imageVariant: "banner" as const,
		imagePosition: "center",
	},
];
---

<html lang="en-GB">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Monarch | DayZ modding, servers, software &amp; hosting</title>
		<meta
			name="description"
			content="Monarch is the parent company behind Monarch Modding, Operation Monarch, Monarch Software, and Monarch Hosting. Custom DayZ content, community servers, and creator tools."
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,400;0,600;0,700;1,400&family=Oswald:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<MonarchHeader />
		<div class="mb-0 w-full">
			<HeroCarousel slides={heroSlides} delayMs={15000} />
		</div>
		<main class="mx-auto mt-20 flex max-w-7xl flex-col gap-20 px-6">
			<PartnersBrandTiles partners={featuredPartners} />

			<ShopByScenario scenarios={scenarios} />

			<ShopPreview />

			<AboutMonarch />

			<HowWeWork />

			<StoreReviews />

			<NewsUpdates />

			<ContactSection />
		</main>

		<MonarchFooter />

		<script>
			import { initHome } from "../scripts/home.ts";
			initHome();
			document.addEventListener("astro:page-load", initHome);
		</script>

		{chatwootToken && (
			<script is:inline define:vars={{ chatwootBase, chatwootToken, customer }}>
				window.chatwootSettings = { hideMessageBubble: false, position: "right", locale: "en", type: "standard", darkMode: "auto" };
				(function (d, t) {
					var g = d.createElement(t), s = d.getElementsByTagName(t)[0];
					g.src = chatwootBase + "/packs/js/sdk.js";
					g.defer = true; g.async = true;
					s.parentNode.insertBefore(g, s);
					g.onload = function () {
						window.chatwootSDK.run({ websiteToken: chatwootToken, baseUrl: chatwootBase });
						if (customer) {
							window.addEventListener("chatwoot:ready", function () {
								window.$chatwoot.setUser(customer.id, {
									name: customer.displayName,
									...(customer.email ? { email: customer.email } : {}),
									...(customer.avatarUrl ? { avatar_url: customer.avatarUrl } : {}),
								});
							});
						}
					};
				})(document, "script");
			</script>
		)}
	</body>
</html>

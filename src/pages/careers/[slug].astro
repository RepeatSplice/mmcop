---
import SiteLayout from "../../layouts/SiteLayout.astro";
import MonarchPageHero from "../../components/MonarchPageHero.astro";
import JobApplyForm from "../../components/JobApplyForm.astro";
import { getJobBySlug } from "../../lib/jobs";
import { renderMarkdown } from "../../lib/markdown";
import { getSiteUrl } from "../../lib/env";

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/careers");

const job = await getJobBySlug(slug);
if (!job) return Astro.redirect("/careers");

const bodyHtml = renderMarkdown(job.body);
const siteUrl = getSiteUrl();

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "JobPosting",
	title: job.title,
	description: job.excerpt,
	datePosted: new Date().toISOString().split("T")[0],
	hiringOrganization: {
		"@type": "Organization",
		name: "Monarch",
		sameAs: siteUrl,
	},
	jobLocation: {
		"@type": "Place",
		address: { "@type": "PostalAddress", addressCountry: "US" },
	},
	employmentType: "CONTRACTOR",
	workHours: "Remote",
};
---

<SiteLayout
	title={`${job.title} | Careers | Monarch`}
	description={job.excerpt}
	mainClass="mx-auto mt-20 flex max-w-7xl flex-col gap-16 px-6 pb-24"
>
	<slot slot="pre-main">
		<MonarchPageHero
			eyebrow="Careers"
			title={job.title}
			lead={`${job.team} · ${job.workType}`}
			image="/Careers_Banner.png"
			cta={{ label: "Apply now", href: "#apply" }}
		/>
	</slot>

	<!-- JSON-LD structured data -->
	<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

	<!-- Breadcrumb -->
	<nav class="flex items-center gap-2 text-sm text-zinc-500" aria-label="Breadcrumb">
		<a href="/careers" class="flex items-center gap-1.5 transition-colors hover:text-brand-black">
			<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 16 16" aria-hidden="true">
				<path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
			All open roles
		</a>
		<span class="text-zinc-300">/</span>
		<span class="font-medium text-brand-black">{job.title}</span>
	</nav>

	<!-- Role meta strip -->
	<div class="flex flex-wrap items-center gap-3 border-b border-zinc-100 pb-6">
		<span class="font-display text-[11px] uppercase tracking-[0.18em] text-monarch-500">{job.team}</span>
		<span class="text-zinc-300" aria-hidden="true">·</span>
		<span class="font-display text-[11px] uppercase tracking-[0.18em] text-zinc-500">{job.workType}</span>
		<span class="text-zinc-300" aria-hidden="true">·</span>
		<span class="font-display text-[11px] uppercase tracking-[0.18em] text-zinc-500">Remote</span>
	</div>

	<!-- Job body -->
	<div class="grid gap-12 lg:grid-cols-[1fr_300px] lg:items-start">
		<article class="monarch-article" set:html={bodyHtml} />

		<!-- Sidebar: quick apply -->
		<aside class="lg:sticky lg:top-6">
			<div class="border border-zinc-200 bg-white p-6">
				<p class="m-0 font-display text-[11px] uppercase tracking-[0.18em] text-monarch-500">{job.team}</p>
				<h2 class="m-0 mt-2 font-display text-base font-medium uppercase tracking-wide text-brand-black">{job.title}</h2>
				<p class="m-0 mt-3 text-sm leading-relaxed text-zinc-600">{job.excerpt}</p>
				<div class="mt-5 flex flex-col gap-2">
					<a
						href="#apply"
						class="font-display flex min-h-[44px] items-center justify-center gap-2 bg-brand-black px-4 py-2.5 text-[13px] uppercase tracking-wide text-white transition-colors hover:bg-zinc-800"
					>
						Apply for this role
					</a>
					<a
						href="/careers"
						class="font-display flex min-h-[44px] items-center justify-center gap-2 border border-zinc-200 px-4 py-2.5 text-[13px] uppercase tracking-wide text-zinc-600 transition-colors hover:border-zinc-400 hover:text-brand-black"
					>
						All open roles
					</a>
				</div>
				<div class="mt-5 border-t border-zinc-100 pt-5 space-y-2 text-sm text-zinc-500">
					<p class="m-0 flex items-center gap-2">
						<svg class="h-4 w-4 shrink-0 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
							<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
						</svg>
						Remote · New Hampshire, USA
					</p>
					<p class="m-0 flex items-center gap-2">
						<svg class="h-4 w-4 shrink-0 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z"/>
						</svg>
						{job.team}
					</p>
				</div>
			</div>
		</aside>
	</div>

	<!-- Apply section -->
	<section id="apply" class="scroll-mt-24" aria-labelledby="apply-heading">
		<div class="border border-zinc-200 bg-white px-6 py-8 sm:px-10 sm:py-10">
			<div class="mx-auto max-w-2xl">
				<p class="m-0 font-display text-[11px] uppercase tracking-[0.18em] text-monarch-500">Apply</p>
				<h2
					id="apply-heading"
					class="m-0 mt-2 font-display text-[clamp(1.25rem,3vw,1.65rem)] font-medium uppercase tracking-[0.12em] text-brand-black"
				>
					{job.title}
				</h2>
				<p class="m-0 mt-1 text-sm text-zinc-500">{job.team} · {job.workType} · Remote</p>
				<JobApplyForm jobSlug={job.slug} config={job.applyFormConfig} />
			</div>
		</div>
	</section>
</SiteLayout>

---
import ManageLayout from "../../../layouts/ManageLayout.astro";
import { prisma } from "../../../lib/prisma";
import type { OrderStatus } from "@prisma/client";

export const prerender = false;

const filter = (Astro.url.searchParams.get("status") ?? "all") as OrderStatus | "all";
const where = filter === "all" ? {} : { status: filter };

const orders = await prisma.order.findMany({
	where,
	orderBy: { createdAt: "desc" },
	take: 100,
	include: {
		customer: true,
		items: { include: { variant: { include: { product: true } } } },
	},
});

const counts = await prisma.order.groupBy({ by: ["status"], _count: true });
const countMap = Object.fromEntries(counts.map((c) => [c.status, c._count]));
const totalCount = counts.reduce((sum, c) => sum + c._count, 0);

const tabs = [
	{ id: "all", label: "All", count: totalCount },
	{ id: "PAID", label: "Paid", count: countMap.PAID ?? 0 },
	{ id: "PENDING", label: "Pending", count: countMap.PENDING ?? 0 },
	{ id: "REFUNDED", label: "Refunded", count: countMap.REFUNDED ?? 0 },
	{ id: "DISPUTED", label: "Disputed", count: countMap.DISPUTED ?? 0 },
] as const;

const statusClass: Record<string, string> = {
	PAID: "bg-emerald-100 text-emerald-800",
	PENDING: "bg-amber-100 text-amber-800",
	REFUNDED: "bg-zinc-100 text-zinc-700",
	DISPUTED: "bg-red-100 text-red-700",
};

const formatPrice = (cents: number) => `$${(cents / 100).toFixed(2)}`;
---

<ManageLayout title="Orders" active="orders">
	<div class="flex flex-wrap items-center justify-between gap-4">
		<div>
			<h1 class="m-0 font-display text-2xl font-medium uppercase tracking-[0.12em]">Orders</h1>
			<p class="mt-1 text-sm text-zinc-500">View and manage customer orders.</p>
		</div>
	</div>

	<nav class="mt-6 flex flex-wrap gap-1.5" aria-label="Filter by status">
		{tabs.map((tab) => (
			<a
				href={tab.id === "all" ? "/manage/orders" : `/manage/orders?status=${tab.id}`}
				class:list={[
					"font-display rounded-full border px-3.5 py-1.5 text-xs uppercase tracking-wide transition-colors",
					filter === tab.id
						? "border-brand-black bg-brand-black text-white"
						: "border-zinc-200 bg-white text-zinc-600 hover:bg-zinc-50",
				]}
			>
				{tab.label}
				<span class="ml-1 opacity-60">{tab.count}</span>
			</a>
		))}
	</nav>

	{orders.length === 0 ? (
		<div class="mt-5 rounded-xl border border-dashed border-zinc-300 bg-white px-6 py-12 text-center shadow-sm">
			<svg class="mx-auto mb-3 h-8 w-8 text-zinc-300" viewBox="0 0 16 16" fill="none" aria-hidden="true">
				<rect x="2" y="2" width="12" height="13" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
				<path d="M5 6h6M5 9h4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
			</svg>
			<p class="m-0 text-sm text-zinc-500">No orders in this view.</p>
		</div>
	) : (
		<ul class="mt-4 list-none overflow-hidden rounded-xl border border-zinc-200 bg-white p-0 shadow-sm">
			{orders.map((order) => (
				<li class="border-b border-zinc-100 last:border-0">
					<a
						href={`/manage/orders/${order.id}`}
						class="flex flex-col gap-3 px-5 py-4 transition-colors hover:bg-zinc-50 sm:flex-row sm:items-center sm:justify-between"
					>
						<div class="min-w-0 flex-1">
							<p class="m-0 font-semibold text-brand-black">#{order.id.slice(-8).toUpperCase()}</p>
							<p class="m-0 mt-0.5 text-xs text-zinc-500">
								{order.customer.displayName} &middot; {order.createdAt.toLocaleDateString("en-GB")}
							</p>
							<p class="m-0 mt-1 truncate text-xs text-zinc-400">
								{order.items.map((i) => `${i.variant.product.title} (${i.variant.name})`).join(", ")}
							</p>
						</div>
						<div class="flex shrink-0 items-center gap-3">
							<span class="font-display text-sm font-medium text-brand-black">
								{formatPrice(order.totalMinorUnits)}
							</span>
							<span class:list={["rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase", statusClass[order.status] ?? "bg-zinc-100 text-zinc-700"]}>
								{order.status}
							</span>
							<svg class="h-4 w-4 shrink-0 text-zinc-300" viewBox="0 0 16 16" fill="none" aria-hidden="true">
								<path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</div>
					</a>
				</li>
			))}
		</ul>
	)}
</ManageLayout>

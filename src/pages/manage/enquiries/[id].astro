---
import ManageLayout from "../../../layouts/ManageLayout.astro";
import ManageBtn from "../../../components/manage/ManageBtn.astro";
import { prisma } from "../../../lib/prisma";
import {
	contactTopicLabel,
	emailDeliveryBadgeClass,
	emailDeliveryLabel,
	enquiryStatusBadgeClass,
	enquiryStatusLabel,
	enquiryStatusOptions,
} from "../../../lib/contact-admin";

export const prerender = false;

const { id } = Astro.params;
if (!id) return Astro.redirect("/manage/enquiries");

let error: string | undefined;
const saved = Astro.url.searchParams.get("saved") === "1";

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const action = String(form.get("_action") ?? "save");

	if (action === "delete") {
		await prisma.contactEnquiry.delete({ where: { id } });
		return Astro.redirect("/manage/enquiries");
	}

	const status = String(form.get("status") ?? "");
	const staffNotes = String(form.get("staffNotes") ?? "").trim();
	if (!["NEW", "IN_PROGRESS", "RESOLVED", "SPAM"].includes(status)) {
		error = "Invalid status.";
	} else {
		await prisma.contactEnquiry.update({
			where: { id },
			data: { status: status as "NEW" | "IN_PROGRESS" | "RESOLVED" | "SPAM", staffNotes: staffNotes || null },
		});
		return Astro.redirect(`/manage/enquiries/${id}?saved=1`);
	}
}

const enquiry = await prisma.contactEnquiry.findUnique({ where: { id } });
if (!enquiry) return Astro.redirect("/manage/enquiries");
---

<ManageLayout title="Enquiry" active="enquiries">
	<a href="/manage/enquiries" class="text-sm text-monarch-500 hover:text-brand-black">← Enquiries</a>
	<h1 class="mt-4 font-display text-2xl font-medium uppercase tracking-[0.12em]">{enquiry.fullName}</h1>
	<p class="mt-2 text-sm text-zinc-600">
		<span class:list={["rounded px-2 py-0.5 text-xs font-semibold uppercase", enquiryStatusBadgeClass(enquiry.status)]}>
			{enquiryStatusLabel(enquiry.status)}
		</span>
		{" · "}
		{contactTopicLabel(enquiry.topic)}
		{" · "}
		{enquiry.createdAt.toLocaleString("en-GB")}
	</p>

	{saved && (
		<p class="mt-4 rounded border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-900" role="status">Changes saved.</p>
	)}
	{error && (
		<p class="mt-4 rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800" role="alert">{error}</p>
	)}

	<div class="mt-6 grid gap-6 lg:grid-cols-2">
		<section class="border border-zinc-200 bg-white p-5">
			<h2 class="m-0 font-display text-xs uppercase tracking-wide text-zinc-500">Contact details</h2>
			<ul class="mt-4 list-none space-y-2 p-0 text-sm">
				<li><strong>Email:</strong> <a href={`mailto:${enquiry.email}`} class="text-monarch-500">{enquiry.email}</a></li>
				{enquiry.phone && <li><strong>Phone:</strong> {enquiry.phone}</li>}
				{enquiry.company && <li><strong>Company / Discord:</strong> {enquiry.company}</li>}
			</ul>
			<div class="mt-6">
				<ManageBtn href={`mailto:${enquiry.email}?subject=Re: Your Monarch enquiry`} variant="secondary">Reply by email</ManageBtn>
			</div>
		</section>

		<section class="border border-zinc-200 bg-white p-5">
			<h2 class="m-0 font-display text-xs uppercase tracking-wide text-zinc-500">Email delivery</h2>
			<ul class="mt-4 list-none space-y-3 p-0 text-sm">
				<li class="flex items-center justify-between gap-2">
					<span>Customer acknowledgement</span>
					<span class:list={["rounded px-2 py-0.5 text-[10px] font-semibold uppercase", emailDeliveryBadgeClass(enquiry.customerAckStatus)]}>
						{emailDeliveryLabel(enquiry.customerAckStatus)}
					</span>
				</li>
				<li class="flex items-center justify-between gap-2">
					<span>Staff notification</span>
					<span class:list={["rounded px-2 py-0.5 text-[10px] font-semibold uppercase", emailDeliveryBadgeClass(enquiry.staffNotifyStatus)]}>
						{emailDeliveryLabel(enquiry.staffNotifyStatus)}
					</span>
				</li>
			</ul>
			<p class="mt-4 text-xs text-zinc-500">Emails send via Resend when <code class="text-[11px]">RESEND_API_KEY</code> is set in environment.</p>
		</section>
	</div>

	<section class="mt-6 border border-zinc-200 bg-white p-5">
		<h2 class="m-0 font-display text-xs uppercase tracking-wide text-zinc-500">Message</h2>
		<p class="mt-4 whitespace-pre-wrap text-sm leading-relaxed text-zinc-800">{enquiry.message}</p>
	</section>

	<form method="post" class="mt-6 space-y-4 border border-zinc-200 bg-white p-5">
		<h2 class="m-0 font-display text-xs uppercase tracking-wide text-zinc-500">Update</h2>
		<label class="block text-sm font-semibold">
			Status
			<select name="status" class="mt-1 w-full max-w-xs border border-zinc-200 px-3 py-2">
				{enquiryStatusOptions.map((opt) => (
					<option value={opt.value} selected={enquiry.status === opt.value}>
						{opt.label}
					</option>
				))}
			</select>
		</label>
		<label class="block text-sm font-semibold">
			Internal notes
			<textarea name="staffNotes" rows="4" class="mt-1 w-full border border-zinc-200 px-3 py-2 text-sm">{enquiry.staffNotes ?? ""}</textarea>
		</label>
		<ManageBtn type="submit" name="_action" value="save" variant="primary">Save</ManageBtn>
	</form>

	<form method="post" class="mt-6 flex justify-end border-t border-zinc-100 pt-6">
		<ManageBtn type="submit" name="_action" value="delete" variant="danger" confirm="Permanently delete this enquiry?">
			Delete enquiry
		</ManageBtn>
	</form>
</ManageLayout>

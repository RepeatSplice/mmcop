---
import ManageLayout from "../../../layouts/ManageLayout.astro";
import ManageBtn from "../../../components/manage/ManageBtn.astro";
import { prisma } from "../../../lib/prisma";
import {
	applicationStatusBadgeClass,
	applicationStatusLabel,
	type ApplicationStatus,
} from "../../../lib/applications-admin";

export const prerender = false;

const filter = (Astro.url.searchParams.get("status") ?? "all") as ApplicationStatus | "all";
const jobSlug = Astro.url.searchParams.get("job")?.trim() ?? "";

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const action = String(form.get("_action") ?? "");
	const id = String(form.get("id") ?? "");
	if (id && ["review", "shortlist", "reject", "reopen", "delete"].includes(action)) {
		if (action === "delete") {
			await prisma.jobApplication.delete({ where: { id } });
		} else {
			const statusMap = {
				review: "REVIEWED",
				shortlist: "SHORTLISTED",
				reject: "REJECTED",
				reopen: "NEW",
			} as const;
			await prisma.jobApplication.update({
				where: { id },
				data: { status: statusMap[action as keyof typeof statusMap] },
			});
		}
		const qs = new URLSearchParams();
		if (filter !== "all") qs.set("status", filter);
		if (jobSlug) qs.set("job", jobSlug);
		const suffix = qs.toString() ? `?${qs}` : "";
		return Astro.redirect(`/manage/applications${suffix}`);
	}
}

const jobFilter = jobSlug
	? await prisma.job.findUnique({ where: { slug: jobSlug }, select: { id: true, title: true, slug: true } })
	: null;

const where = {
	...(filter === "all" ? {} : { status: filter }),
	...(jobFilter ? { jobId: jobFilter.id } : {}),
};

const apps = await prisma.jobApplication.findMany({
	where,
	orderBy: { createdAt: "desc" },
	include: { job: { select: { title: true, slug: true } } },
	take: 200,
});

// Count query scoped to the job filter (so tab numbers match the filtered list)
const countWhere = jobFilter ? { jobId: jobFilter.id } : {};
const counts = await prisma.jobApplication.groupBy({
	by: ["status"],
	where: countWhere,
	_count: true,
});
const countMap = Object.fromEntries(counts.map((c) => [c.status, c._count]));
const totalCount = counts.reduce((sum, c) => sum + c._count, 0);

const tabs = [
	{ id: "all", label: "All", count: totalCount },
	{ id: "NEW", label: "New", count: countMap.NEW ?? 0 },
	{ id: "REVIEWED", label: "Reviewed", count: countMap.REVIEWED ?? 0 },
	{ id: "SHORTLISTED", label: "Shortlisted", count: countMap.SHORTLISTED ?? 0 },
	{ id: "REJECTED", label: "Rejected", count: countMap.REJECTED ?? 0 },
] as const;

const capped = apps.length === 200;
---

<ManageLayout title="Applications" active="applications">
	<div class="flex flex-wrap items-center justify-between gap-4">
		<div>
			<h1 class="m-0 font-display text-2xl font-medium uppercase tracking-[0.12em]">Applications</h1>
			<p class="mt-1 text-sm text-zinc-500">Job applications submitted from public career pages.</p>
		</div>
		<ManageBtn href="/manage/jobs" variant="muted">Manage jobs</ManageBtn>
	</div>

	{jobFilter && (
		<p class="mt-4 flex flex-wrap items-center gap-2 rounded border border-zinc-200 bg-zinc-50 px-4 py-2.5 text-sm text-zinc-600">
			Filtered by job: <strong>{jobFilter.title}</strong>
			<a href="/manage/applications" class="ml-auto font-medium text-monarch-500 hover:text-brand-black">Clear filter ×</a>
		</p>
	)}

	<nav class="mt-6 flex flex-wrap gap-1.5" aria-label="Filter by status">
		{tabs.map((tab) => {
			const qs = new URLSearchParams();
			if (tab.id !== "all") qs.set("status", tab.id);
			if (jobSlug) qs.set("job", jobSlug);
			const href = qs.toString() ? `/manage/applications?${qs}` : "/manage/applications";
			return (
				<a
					href={href}
					class:list={[
						"font-display rounded-full border px-3.5 py-1.5 text-xs uppercase tracking-wide transition-colors",
						filter === tab.id
							? "border-brand-black bg-brand-black text-white"
							: "border-zinc-200 bg-white text-zinc-600 hover:bg-zinc-50",
					]}
				>
					{tab.label}
					<span class="ml-1 opacity-60">{tab.count}</span>
				</a>
			);
		})}
	</nav>

	{capped && (
		<p class="mt-3 text-xs text-zinc-500 bg-amber-50 border border-amber-200 rounded px-3 py-2">
			Showing the 200 most recent applications — use the status tabs or job filter to narrow the list.
		</p>
	)}

	{apps.length === 0 ? (
		<div class="mt-5 rounded-xl border border-dashed border-zinc-300 bg-white px-6 py-12 text-center shadow-sm">
			<svg class="mx-auto mb-3 h-8 w-8 text-zinc-300" viewBox="0 0 16 16" fill="none" aria-hidden="true">
				<path d="M4 6h8M4 9h8M4 12h5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
				<rect x="2" y="2" width="12" height="14" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
			</svg>
			<p class="m-0 text-sm text-zinc-500">No applications in this view.</p>
		</div>
	) : (
		<ul class="mt-4 list-none overflow-hidden rounded-xl border border-zinc-200 bg-white p-0 shadow-sm">
			{apps.map((app) => (
				<li class="border-b border-zinc-100 px-5 py-4 last:border-0">
					<div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
						<div class="min-w-0 flex-1">
							<div class="flex flex-wrap items-center gap-2">
								<p class="m-0 font-semibold text-brand-black">{app.fullName}</p>
								<span class:list={["rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase", applicationStatusBadgeClass(app.status)]}>
									{applicationStatusLabel(app.status)}
								</span>
							</div>
							<div class="mt-1 flex flex-wrap items-center gap-2 text-xs text-zinc-500">
								<span>{app.email}</span>
								<span class="text-zinc-300" aria-hidden="true">·</span>
								<a class="font-medium text-monarch-500 hover:text-brand-black" href={`/careers/${app.job.slug}`} target="_blank" rel="noopener">
									{app.job.title}
								</a>
								<span class="text-zinc-300" aria-hidden="true">·</span>
								<span>{app.createdAt.toLocaleString("en-GB")}</span>
							</div>
						</div>
						<div class="flex shrink-0 flex-wrap items-center gap-2">
							<ManageBtn href={`/manage/applications/${app.id}`} variant="primary">View</ManageBtn>
							<form method="post" class="flex flex-wrap gap-1.5">
								<input type="hidden" name="id" value={app.id} />
								{app.status === "NEW" && (
									<ManageBtn type="submit" name="_action" value="review" variant="muted">Mark reviewed</ManageBtn>
								)}
								{app.status !== "SHORTLISTED" && app.status !== "REJECTED" && (
									<ManageBtn type="submit" name="_action" value="shortlist" variant="success">Shortlist</ManageBtn>
								)}
								{app.status !== "REJECTED" && (
									<ManageBtn type="submit" name="_action" value="reject" variant="warning">Reject</ManageBtn>
								)}
								{app.status !== "NEW" && (
									<ManageBtn type="submit" name="_action" value="reopen" variant="muted">Reopen</ManageBtn>
								)}
								<ManageBtn type="submit" name="_action" value="delete" variant="danger" confirm="Delete this application permanently?">Delete</ManageBtn>
							</form>
						</div>
					</div>
				</li>
			))}
		</ul>
	)}
</ManageLayout>

---
import ManageLayout from "../../../layouts/ManageLayout.astro";
import ManageBtn from "../../../components/manage/ManageBtn.astro";
import { prisma } from "../../../lib/prisma";
import { getCategoryLabel } from "../../../lib/news";
import { statusBadgeClass, statusLabel } from "../../../lib/news-admin";
import type { NewsStatus } from "../../../lib/news-admin";

export const prerender = false;

const filter = (Astro.url.searchParams.get("status") ?? "all") as NewsStatus | "all";

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const action = String(form.get("_action") ?? "");
	const targetSlug = String(form.get("slug") ?? "");
	if (targetSlug && ["publish", "archive", "draft", "delete"].includes(action)) {
		if (action === "delete") {
			await prisma.newsPost.delete({ where: { slug: targetSlug } });
		} else {
			const statusMap = { publish: "PUBLISHED", archive: "ARCHIVED", draft: "DRAFT" } as const;
			await prisma.newsPost.update({
				where: { slug: targetSlug },
				data: { status: statusMap[action as keyof typeof statusMap] },
			});
		}
		return Astro.redirect(`/manage/news${filter !== "all" ? `?status=${filter}` : ""}`);
	}
}

const where = filter === "all" ? {} : { status: filter };
const posts = await prisma.newsPost.findMany({ where, orderBy: { publishedAt: "desc" } });
const counts = await prisma.newsPost.groupBy({ by: ["status"], _count: true });
const countMap = Object.fromEntries(counts.map((c) => [c.status, c._count]));
const totalCount = counts.reduce((sum, c) => sum + c._count, 0);
const tabs = [
	{ id: "all", label: "All", count: totalCount },
	{ id: "PUBLISHED", label: "Published", count: countMap.PUBLISHED ?? 0 },
	{ id: "DRAFT", label: "Drafts", count: countMap.DRAFT ?? 0 },
	{ id: "ARCHIVED", label: "Archived", count: countMap.ARCHIVED ?? 0 },
] as const;
---

<ManageLayout title="News" active="news">
	<div class="flex flex-wrap items-center justify-between gap-4">
		<div>
			<h1 class="m-0 font-display text-2xl font-medium uppercase tracking-[0.12em]">News</h1>
			<p class="mt-1 text-sm text-zinc-500">Create, edit, publish, archive, or delete articles.</p>
		</div>
		<ManageBtn href="/manage/news/new" variant="primary">New post</ManageBtn>
	</div>

	<nav class="mt-6 flex flex-wrap gap-1.5" aria-label="Filter by status">
		{tabs.map((tab) => (
			<a
				href={tab.id === "all" ? "/manage/news" : `/manage/news?status=${tab.id}`}
				class:list={[
					"font-display rounded-full border px-3.5 py-1.5 text-xs uppercase tracking-wide transition-colors",
					filter === tab.id
						? "border-brand-black bg-brand-black text-white"
						: "border-zinc-200 bg-white text-zinc-600 hover:bg-zinc-50",
				]}
			>
				{tab.label}
				<span class="ml-1 opacity-60">{tab.count}</span>
			</a>
		))}
	</nav>

	{posts.length === 0 ? (
		<div class="mt-5 rounded-xl border border-dashed border-zinc-300 bg-white px-6 py-12 text-center shadow-sm">
			<svg class="mx-auto mb-3 h-8 w-8 text-zinc-300" viewBox="0 0 16 16" fill="none" aria-hidden="true">
				<rect x="2" y="2" width="12" height="13" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
				<path d="M5 5h6M5 8h6M5 11h3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
			</svg>
			<p class="m-0 text-sm text-zinc-500">
				No posts in this view.{" "}
				<a class="font-semibold text-monarch-500 hover:text-brand-black" href="/manage/news/new">Create one</a>.
			</p>
		</div>
	) : (
		<ul class="mt-4 list-none overflow-hidden rounded-xl border border-zinc-200 bg-white p-0 shadow-sm">
			{posts.map((post) => (
				<li class="border-b border-zinc-100 px-5 py-4 last:border-0">
					<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
						<div class="flex min-w-0 flex-1 gap-4">
							{post.bannerImageUrl && (
								<img
									src={post.bannerImageUrl}
									alt=""
									class="hidden h-14 w-24 shrink-0 rounded-lg border border-zinc-100 object-cover md:block"
								/>
							)}
							<div class="min-w-0 flex-1">
								<p class="m-0 line-clamp-2 font-semibold leading-snug text-brand-black">{post.title}</p>
								<div class="mt-2 flex flex-wrap items-center gap-2">
									<span class:list={["rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase", statusBadgeClass(post.status)]}>
										{statusLabel(post.status)}
									</span>
									<span class="rounded-full bg-zinc-100 px-2.5 py-0.5 text-[10px] font-semibold uppercase text-zinc-700">
										{getCategoryLabel(post.category)}
									</span>
									<span class="text-xs text-zinc-400">{post.publishedAt.toLocaleDateString("en-GB")}</span>
								</div>
								<p class="m-0 mt-1 truncate font-mono text-[11px] text-zinc-400">{post.slug}</p>
							</div>
						</div>

						<div class="flex shrink-0 flex-col gap-2 sm:flex-row sm:items-center">
							<div class="flex flex-wrap gap-1.5">
								{post.status === "PUBLISHED" && (
									<ManageBtn href={`/news/${post.slug}`} variant="muted" external>View</ManageBtn>
								)}
								<ManageBtn href={`/manage/news/${post.slug}`} variant="primary">Edit</ManageBtn>
							</div>

							<form method="post" class="flex flex-wrap gap-1.5 border-t border-zinc-100 pt-2 sm:border-t-0 sm:border-l sm:pl-2 sm:pt-0">
								<input type="hidden" name="slug" value={post.slug} />
								{post.status !== "PUBLISHED" && (
									<ManageBtn type="submit" name="_action" value="publish" variant="success">Publish</ManageBtn>
								)}
								{post.status !== "ARCHIVED" && (
									<ManageBtn type="submit" name="_action" value="archive" variant="muted">Archive</ManageBtn>
								)}
								{post.status !== "DRAFT" && post.status !== "PUBLISHED" && (
									<ManageBtn type="submit" name="_action" value="draft" variant="warning">Draft</ManageBtn>
								)}
								<ManageBtn type="submit" name="_action" value="delete" variant="danger" confirm="Delete this post permanently?">Delete</ManageBtn>
							</form>
						</div>
					</div>
				</li>
			))}
		</ul>
	)}
</ManageLayout>

---
import ManageLayout from "../../layouts/ManageLayout.astro";
import ManageBtn from "../../components/manage/ManageBtn.astro";
import { prisma } from "../../lib/prisma";

export const prerender = false;

const staff = Astro.locals.staff;
const isShopManager = staff?.role === "ADMIN" || staff?.role === "SHOP_MANAGER";

const now = new Date();
const startOfMonth = new Date(now.getFullYear(), now.getMonth(), 1);

const [newApps, newEnquiries, draftNews, publishedJobs] = await Promise.all([
	prisma.jobApplication.count({ where: { status: "NEW" } }),
	prisma.contactEnquiry.count({ where: { status: "NEW" } }),
	prisma.newsPost.count({ where: { status: "DRAFT" } }),
	prisma.job.count({ where: { status: "PUBLISHED" } }),
]);

const shopStats = isShopManager
	? await Promise.all([
			prisma.order.count({ where: { status: "PENDING" } }),
			prisma.serverLicense.count({ where: { status: { in: ["ACTIVE", "GRACE"] } } }),
			prisma.order.aggregate({
				where: { status: "PAID", createdAt: { gte: startOfMonth } },
				_sum: { totalMinorUnits: true },
			}),
			prisma.productReview.count({ where: { status: "PENDING" } }),
			prisma.order.findMany({
				where: { status: { in: ["PAID", "PENDING"] } },
				orderBy: { createdAt: "desc" },
				take: 5,
				include: { customer: true, items: { include: { variant: { include: { product: true } } } } },
			}),
		])
	: null;

const pendingOrders = shopStats?.[0] ?? 0;
const activeLicenses = shopStats?.[1] ?? 0;
const monthlyRevenue = shopStats?.[2]._sum.totalMinorUnits ?? 0;
const pendingReviews = shopStats?.[3] ?? 0;
const recentOrders = (shopStats?.[4] ?? []) as Awaited<ReturnType<typeof prisma.order.findMany>>;

const recentEnquiries = await prisma.contactEnquiry.findMany({
	where: { status: { in: ["NEW", "IN_PROGRESS"] } },
	orderBy: { createdAt: "desc" },
	take: 4,
});

const recentApps = await prisma.jobApplication.findMany({
	where: { status: "NEW" },
	orderBy: { createdAt: "desc" },
	take: 4,
	include: { job: { select: { title: true } } },
});

const formatPrice = (cents: number) => `$${(cents / 100).toFixed(2)}`;

const orderStatusClass: Record<string, string> = {
	PAID: "bg-emerald-100 text-emerald-800",
	PENDING: "bg-amber-100 text-amber-800",
	REFUNDED: "bg-zinc-100 text-zinc-700",
	DISPUTED: "bg-red-100 text-red-700",
};

type Activity =
	| { type: "enquiry"; id: string; name: string; subject: string; date: Date }
	| { type: "application"; id: string; name: string; subject: string; date: Date };

const activity: Activity[] = [
	...recentEnquiries.map((e) => ({
		type: "enquiry" as const,
		id: e.id,
		name: e.fullName,
		subject: "Enquiry",
		date: e.createdAt,
	})),
	...recentApps.map((a) => ({
		type: "application" as const,
		id: a.id,
		name: a.fullName,
		subject: a.job.title,
		date: a.createdAt,
	})),
].sort((a, b) => b.date.getTime() - a.date.getTime()).slice(0, 6);
---

<ManageLayout title="Dashboard" active="dashboard">
	<!-- Page header -->
	<div class="flex flex-wrap items-center justify-between gap-4">
		<div>
			<h1 class="m-0 font-display text-2xl font-medium uppercase tracking-[0.12em]">Dashboard</h1>
			<p class="mt-1 text-sm text-zinc-500">Welcome back, {staff?.name?.split(" ")[0]}.</p>
		</div>
		<div class="flex flex-wrap gap-2">
			<ManageBtn href="/manage/news/new" variant="muted">New post</ManageBtn>
			<ManageBtn href="/manage/jobs/new" variant="muted">New job</ManageBtn>
			{isShopManager && <ManageBtn href="/manage/products/new" variant="primary">New product</ManageBtn>}
		</div>
	</div>

	<!-- Core stat cards -->
	<div class="mt-7 grid grid-cols-2 gap-3 sm:grid-cols-4">
		<a
			href="/manage/applications?status=NEW"
			class="group rounded-xl border border-zinc-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
		>
			<div class="flex items-start justify-between">
				<p class="m-0 font-display text-3xl font-medium text-brand-black">{newApps}</p>
				<div class="flex h-8 w-8 items-center justify-center rounded-lg bg-zinc-50 text-zinc-400 transition-colors group-hover:bg-zinc-100">
					<svg viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
						<path d="M4 6h8M4 9h8M4 12h5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
						<rect x="2" y="2" width="12" height="14" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
					</svg>
				</div>
			</div>
			<p class="m-0 mt-2 text-sm text-zinc-500">New applications</p>
		</a>

		<a
			href="/manage/enquiries?status=NEW"
			class="group rounded-xl border border-zinc-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
		>
			<div class="flex items-start justify-between">
				<p class="m-0 font-display text-3xl font-medium text-brand-black">{newEnquiries}</p>
				<div class="flex h-8 w-8 items-center justify-center rounded-lg bg-zinc-50 text-zinc-400 transition-colors group-hover:bg-zinc-100">
					<svg viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
						<rect x="2" y="3" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
						<path d="M5 7l3 2.5L11 7" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</div>
			</div>
			<p class="m-0 mt-2 text-sm text-zinc-500">New enquiries</p>
		</a>

		<a
			href="/manage/news?status=DRAFT"
			class="group rounded-xl border border-zinc-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
		>
			<div class="flex items-start justify-between">
				<p class="m-0 font-display text-3xl font-medium text-brand-black">{draftNews}</p>
				<div class="flex h-8 w-8 items-center justify-center rounded-lg bg-zinc-50 text-zinc-400 transition-colors group-hover:bg-zinc-100">
					<svg viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
						<rect x="2" y="2" width="12" height="13" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
						<path d="M5 5h6M5 8h6M5 11h3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
					</svg>
				</div>
			</div>
			<p class="m-0 mt-2 text-sm text-zinc-500">Draft posts</p>
		</a>

		<a
			href="/manage/jobs?status=PUBLISHED"
			class="group rounded-xl border border-zinc-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
		>
			<div class="flex items-start justify-between">
				<p class="m-0 font-display text-3xl font-medium text-brand-black">{publishedJobs}</p>
				<div class="flex h-8 w-8 items-center justify-center rounded-lg bg-zinc-50 text-zinc-400 transition-colors group-hover:bg-zinc-100">
					<svg viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
						<rect x="5" y="2" width="6" height="3" rx="1" stroke="currentColor" stroke-width="1.25"/>
						<rect x="2" y="5" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
					</svg>
				</div>
			</div>
			<p class="m-0 mt-2 text-sm text-zinc-500">Active jobs</p>
		</a>
	</div>

	{
		isShopManager && (
			<>
				<!-- Shop divider -->
				<div class="mt-8 flex items-center gap-3">
					<p class="m-0 shrink-0 font-display text-[10px] uppercase tracking-[0.18em] text-zinc-400">
						Shop
					</p>
					<div class="h-px flex-1 bg-zinc-200" />
				</div>

				<!-- Shop stat cards -->
				<div class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-4">
					<a
						href="/manage/analytics"
						class="group rounded-xl border border-zinc-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
					>
						<div class="flex items-start justify-between">
							<p class="m-0 font-display text-2xl font-medium text-monarch-500">
								{formatPrice(monthlyRevenue)}
							</p>
							<div class="flex h-8 w-8 items-center justify-center rounded-lg bg-zinc-50 text-zinc-400 transition-colors group-hover:bg-zinc-100">
								<svg viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
									<path d="M2 12l3-4 3 2 3-5 3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
									<path d="M2 14h12" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
								</svg>
							</div>
						</div>
						<p class="m-0 mt-2 text-sm text-zinc-500">Revenue this month</p>
					</a>

					<a
						href="/manage/orders?status=PENDING"
						class="group rounded-xl border border-zinc-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
					>
						<div class="flex items-start justify-between">
							<p class="m-0 font-display text-3xl font-medium text-brand-black">{pendingOrders}</p>
							<div class="flex h-8 w-8 items-center justify-center rounded-lg bg-zinc-50 text-zinc-400 transition-colors group-hover:bg-zinc-100">
								<svg viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
									<rect x="2" y="2" width="12" height="13" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
									<path d="M5 6h6M5 9h4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
									<path d="M5 12l1.5 1.5L10 10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
								</svg>
							</div>
						</div>
						<p class="m-0 mt-2 text-sm text-zinc-500">Pending orders</p>
					</a>

					<a
						href="/manage/licenses?status=ACTIVE"
						class="group rounded-xl border border-zinc-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
					>
						<div class="flex items-start justify-between">
							<p class="m-0 font-display text-3xl font-medium text-brand-black">{activeLicenses}</p>
							<div class="flex h-8 w-8 items-center justify-center rounded-lg bg-zinc-50 text-zinc-400 transition-colors group-hover:bg-zinc-100">
								<svg viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
									<path d="M8 2l5 2v4c0 2.8-2 5.4-5 6.5C5 13.4 3 10.8 3 8V4l5-2z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
									<path d="M6 8l1.5 1.5L10 6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
								</svg>
							</div>
						</div>
						<p class="m-0 mt-2 text-sm text-zinc-500">Active licenses</p>
					</a>

					<a
						href="/manage/reviews?status=PENDING"
						class:list={[
							"group rounded-xl border bg-white p-5 shadow-sm transition-shadow hover:shadow-md",
							pendingReviews > 0 ? "border-amber-200" : "border-zinc-200",
						]}
					>
						<div class="flex items-start justify-between">
							<p class:list={["m-0 font-display text-3xl font-medium", pendingReviews > 0 ? "text-amber-600" : "text-brand-black"]}>
								{pendingReviews}
							</p>
							<div class:list={["flex h-8 w-8 items-center justify-center rounded-lg transition-colors group-hover:bg-zinc-100", pendingReviews > 0 ? "bg-amber-50 text-amber-500" : "bg-zinc-50 text-zinc-400"]}>
								<svg viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
									<path d="M8 2l1.5 3.5 3.5.5-2.5 2.5.5 3.5L8 10.5l-3 1.5.5-3.5L3 6l3.5-.5z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
								</svg>
							</div>
						</div>
						<p class="m-0 mt-2 text-sm text-zinc-500">Pending reviews</p>
					</a>
				</div>

				<!-- Two-column: recent orders + activity -->
				<div class="mt-8 grid grid-cols-1 gap-5 lg:grid-cols-2">
					<!-- Recent orders -->
					<div class="rounded-xl border border-zinc-200 bg-white shadow-sm">
						<div class="flex items-center justify-between border-b border-zinc-100 px-5 py-4">
							<h2 class="m-0 font-display text-xs uppercase tracking-[0.15em] text-zinc-500">
								Recent Orders
							</h2>
							<a href="/manage/orders" class="font-display text-[11px] uppercase tracking-wide text-monarch-500 hover:text-brand-black">
								View all
							</a>
						</div>
						{recentOrders.length === 0 ? (
							<div class="px-5 py-8 text-center">
								<p class="m-0 text-sm text-zinc-400">No orders yet.</p>
							</div>
						) : (
							<ul class="list-none divide-y divide-zinc-100 p-0">
								{(recentOrders as any[]).map((order) => (
									<li>
										<a
											href={`/manage/orders/${order.id}`}
											class="flex items-center justify-between gap-3 px-5 py-3.5 transition-colors hover:bg-zinc-50"
										>
											<div class="min-w-0">
												<p class="m-0 text-sm font-semibold text-brand-black">
													#{order.id.slice(-8).toUpperCase()}
												</p>
												<p class="m-0 truncate text-xs text-zinc-400">
													{order.customer.displayName} &middot; {order.createdAt.toLocaleDateString("en-GB")}
												</p>
											</div>
											<div class="flex shrink-0 items-center gap-2">
												<span class="font-display text-sm font-medium text-brand-black">
													{formatPrice(order.totalMinorUnits)}
												</span>
												<span class:list={["rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase", orderStatusClass[order.status] ?? "bg-zinc-100 text-zinc-700"]}>
													{order.status}
												</span>
											</div>
										</a>
									</li>
								))}
							</ul>
						)}
					</div>

					<!-- Recent activity -->
					<div class="rounded-xl border border-zinc-200 bg-white shadow-sm">
						<div class="flex items-center justify-between border-b border-zinc-100 px-5 py-4">
							<h2 class="m-0 font-display text-xs uppercase tracking-[0.15em] text-zinc-500">
								Recent Activity
							</h2>
							<a href="/manage/enquiries" class="font-display text-[11px] uppercase tracking-wide text-monarch-500 hover:text-brand-black">
								View enquiries
							</a>
						</div>
						{activity.length === 0 ? (
							<div class="px-5 py-8 text-center">
								<p class="m-0 text-sm text-zinc-400">No new activity.</p>
							</div>
						) : (
							<ul class="list-none divide-y divide-zinc-100 p-0">
								{activity.map((item) => (
									<li>
										<a
											href={item.type === "enquiry" ? `/manage/enquiries/${item.id}` : `/manage/applications/${item.id}`}
											class="flex items-center gap-3 px-5 py-3.5 transition-colors hover:bg-zinc-50"
										>
											<div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-zinc-100 text-zinc-400">
												{item.type === "enquiry" ? (
													<svg viewBox="0 0 16 16" width="13" height="13" fill="none" aria-hidden="true">
														<rect x="2" y="3" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
														<path d="M5 7l3 2.5L11 7" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
													</svg>
												) : (
													<svg viewBox="0 0 16 16" width="13" height="13" fill="none" aria-hidden="true">
														<path d="M4 6h8M4 9h8M4 12h5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
														<rect x="2" y="2" width="12" height="14" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
													</svg>
												)}
											</div>
											<div class="min-w-0 flex-1">
												<p class="m-0 truncate text-sm font-semibold text-brand-black">{item.name}</p>
												<p class="m-0 text-xs text-zinc-400">{item.subject}</p>
											</div>
											<span class="shrink-0 font-display text-[10px] uppercase tracking-wide text-zinc-400">
												{item.type === "enquiry" ? "Enquiry" : "Application"}
											</span>
										</a>
									</li>
								))}
							</ul>
						)}
					</div>
				</div>
			</>
		)
	}

	{
		!isShopManager && activity.length > 0 && (
			<div class="mt-8 rounded-xl border border-zinc-200 bg-white shadow-sm">
				<div class="border-b border-zinc-100 px-5 py-4">
					<h2 class="m-0 font-display text-xs uppercase tracking-[0.15em] text-zinc-500">Recent Activity</h2>
				</div>
				<ul class="list-none divide-y divide-zinc-100 p-0">
					{activity.map((item) => (
						<li>
							<a
								href={item.type === "enquiry" ? `/manage/enquiries/${item.id}` : `/manage/applications/${item.id}`}
								class="flex items-center gap-3 px-5 py-3.5 transition-colors hover:bg-zinc-50"
							>
								<div class="min-w-0 flex-1">
									<p class="m-0 truncate text-sm font-semibold text-brand-black">{item.name}</p>
									<p class="m-0 text-xs text-zinc-400">{item.subject}</p>
								</div>
								<span class="shrink-0 font-display text-[10px] uppercase tracking-wide text-zinc-400">
									{item.type === "enquiry" ? "Enquiry" : "Application"}
								</span>
							</a>
						</li>
					))}
				</ul>
			</div>
		)
	}
</ManageLayout>

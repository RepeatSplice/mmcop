---
import ManageLayout from "../../../layouts/ManageLayout.astro";
import { prisma } from "../../../lib/prisma";
import { hashPassword } from "../../../lib/auth/password";

export const prerender = false;

const staff = Astro.locals.staff;
if (staff?.role !== "ADMIN") {
	return Astro.redirect("/manage");
}

let formError = "";

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const email = String(form.get("email") ?? "").trim().toLowerCase();
	const name = String(form.get("name") ?? "").trim();
	const password = String(form.get("password") ?? "");
	const role = String(form.get("role") ?? "EDITOR") as "ADMIN" | "EDITOR" | "SHOP_MANAGER";
	if (email && name && password.length >= 10) {
		const existing = await prisma.staffUser.findUnique({ where: { email } });
		if (existing) {
			formError = "A user with that email already exists.";
		} else {
			await prisma.staffUser.create({
				data: { email, name, role, passwordHash: await hashPassword(password) },
			});
			return Astro.redirect("/manage/users");
		}
	} else {
		formError = "Please fill in all fields. Password must be at least 10 characters.";
	}
}

const users = await prisma.staffUser.findMany({ orderBy: { createdAt: "asc" } });

const roleLabel: Record<string, string> = { ADMIN: "Admin", EDITOR: "Editor", SHOP_MANAGER: "Shop Manager" };
const roleBadge: Record<string, string> = {
	ADMIN: "bg-monarch-500/10 text-monarch-600",
	EDITOR: "bg-zinc-100 text-zinc-700",
	SHOP_MANAGER: "bg-blue-100 text-blue-700",
};
---

<ManageLayout title="Staff" active="users">
	<div class="flex flex-wrap items-center justify-between gap-4">
		<div>
			<h1 class="m-0 font-display text-2xl font-medium uppercase tracking-[0.12em]">Staff</h1>
			<p class="mt-1 text-sm text-zinc-500">Invite colleagues. They must set up 2FA on first login.</p>
		</div>
	</div>

	<div class="mt-7 grid grid-cols-1 gap-6 lg:grid-cols-5">
		<!-- Add user form -->
		<div class="lg:col-span-2">
			<div class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
				<h2 class="m-0 font-display text-xs uppercase tracking-[0.15em] text-zinc-500">Add User</h2>
				{formError && (
					<div class="mt-3 rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
						{formError}
					</div>
				)}
				<form method="post" class="mt-4 space-y-4">
					<div>
						<label class="mb-1 block font-display text-[10px] uppercase tracking-widest text-zinc-500">
							Name <span class="text-red-500">*</span>
						</label>
						<input
							name="name"
							required
							class="w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm focus:border-brand-black focus:outline-none"
							placeholder="Jane Smith"
						/>
					</div>
					<div>
						<label class="mb-1 block font-display text-[10px] uppercase tracking-widest text-zinc-500">
							Email <span class="text-red-500">*</span>
						</label>
						<input
							name="email"
							type="email"
							required
							class="w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm focus:border-brand-black focus:outline-none"
							placeholder="jane@example.com"
						/>
					</div>
					<div>
						<label class="mb-1 block font-display text-[10px] uppercase tracking-widest text-zinc-500">
							Temp password <span class="text-zinc-400">(min 10 chars)</span>
						</label>
						<input
							name="password"
							type="password"
							required
							minlength="10"
							class="w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm focus:border-brand-black focus:outline-none"
						/>
					</div>
					<div>
						<label class="mb-1 block font-display text-[10px] uppercase tracking-widest text-zinc-500">Role</label>
						<select name="role" class="w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm focus:border-brand-black focus:outline-none">
							<option value="EDITOR">Editor</option>
							<option value="SHOP_MANAGER">Shop Manager</option>
							<option value="ADMIN">Admin</option>
						</select>
					</div>
					<button
						type="submit"
						class="font-display w-full rounded-lg bg-brand-black px-4 py-2.5 text-xs uppercase tracking-wide text-white transition-colors hover:bg-zinc-800"
					>
						Create user
					</button>
				</form>
			</div>
		</div>

		<!-- User list -->
		<div class="lg:col-span-3">
			{users.length === 0 ? (
				<div class="rounded-xl border border-dashed border-zinc-300 bg-white px-6 py-12 text-center shadow-sm">
					<p class="m-0 text-sm text-zinc-500">No staff users yet.</p>
				</div>
			) : (
				<ul class="list-none overflow-hidden rounded-xl border border-zinc-200 bg-white p-0 shadow-sm">
					{users.map((u) => {
						const initials = u.name.split(" ").map((w) => w[0]).slice(0, 2).join("").toUpperCase();
						return (
							<li class="flex items-center gap-4 border-b border-zinc-100 px-5 py-4 last:border-0">
								<div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-monarch-500 font-display text-sm font-medium text-white">
									{initials}
								</div>
								<div class="min-w-0 flex-1">
									<p class="m-0 font-semibold text-brand-black">{u.name}</p>
									<p class="m-0 text-xs text-zinc-500">{u.email}</p>
								</div>
								<div class="flex shrink-0 flex-col items-end gap-1">
									<span class:list={["rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase", roleBadge[u.role] ?? "bg-zinc-100 text-zinc-700"]}>
										{roleLabel[u.role] ?? u.role}
									</span>
									<span class:list={["rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase", u.totpEnabled ? "bg-emerald-100 text-emerald-700" : "bg-amber-100 text-amber-700"]}>
										{u.totpEnabled ? "2FA on" : "2FA pending"}
									</span>
								</div>
							</li>
						);
					})}
				</ul>
			)}
		</div>
	</div>
</ManageLayout>

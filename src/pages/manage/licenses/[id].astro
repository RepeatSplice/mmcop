---
import ManageLayout from "../../../layouts/ManageLayout.astro";
import ManageBtn from "../../../components/manage/ManageBtn.astro";
import { prisma } from "../../../lib/prisma";

export const prerender = false;

const { id } = Astro.params;
if (!id) return Astro.redirect("/manage/licenses");

let successMsg = "";
let error = "";

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const action = String(form.get("_action") ?? "");

	const statusActions: Record<string, string> = {
		revoke: "REVOKED",
		suspend: "SUSPENDED",
		activate: "ACTIVE",
		grace: "GRACE",
	};

	if (action in statusActions) {
		await prisma.serverLicense.update({
			where: { id },
			data: { status: statusActions[action] as "REVOKED" | "SUSPENDED" | "ACTIVE" | "GRACE" },
		});
		successMsg = `License ${action}d.`;
	}

	if (action === "add-ip") {
		const ipAddress = String(form.get("ipAddress") ?? "").trim();
		const label = String(form.get("label") ?? "").trim() || null;
		const isTestServer = form.get("isTestServer") === "on";
		if (ipAddress) {
			await prisma.registeredServer.upsert({
				where: { licenseId_ipAddress: { licenseId: id, ipAddress } },
				create: { licenseId: id, ipAddress, label, isTestServer },
				update: { label, isTestServer },
			});
			successMsg = "IP added.";
		}
	}

	if (action === "remove-ip") {
		const serverId = String(form.get("serverId") ?? "");
		if (serverId) {
			await prisma.registeredServer.delete({ where: { id: serverId } });
			successMsg = "IP removed.";
		}
	}

	return Astro.redirect(`/manage/licenses/${id}`);
}

const license = await prisma.serverLicense.findUnique({
	where: { id },
	include: {
		customer: true,
		variant: { include: { product: true } },
		orderItem: { include: { order: true } },
		servers: { orderBy: { addedAt: "asc" } },
	},
});

if (!license) return Astro.redirect("/manage/licenses");

const statusClass: Record<string, string> = {
	ACTIVE: "bg-green-100 text-green-800",
	GRACE: "bg-yellow-100 text-yellow-800",
	REVOKED: "bg-red-100 text-red-700",
	SUSPENDED: "bg-zinc-100 text-zinc-700",
};
---

<ManageLayout title={`License: ${license.variant.product.title}`} active="licenses">
	<div class="flex flex-wrap items-center justify-between gap-4">
		<div>
			<h1 class="m-0 font-display text-2xl font-medium uppercase tracking-[0.12em]">
				{license.variant.product.title}
			</h1>
			<p class="mt-0.5 text-sm text-zinc-500">
				{license.variant.name} &middot; {license.customer.displayName}
			</p>
		</div>
		<a
			href="/manage/licenses"
			class="font-display border border-zinc-300 bg-white px-3 py-1.5 text-xs uppercase tracking-wide text-zinc-700 transition-colors hover:border-zinc-400"
		>
			Back
		</a>
	</div>

	{successMsg && <div class="mt-4 border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">{successMsg}</div>}
	{error && <div class="mt-4 border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">{error}</div>}

	<div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-3">
		<div class="lg:col-span-2 space-y-6">
			<!-- Server IPs -->
			<div class="border border-zinc-200 bg-white">
				<div class="flex items-center justify-between border-b border-zinc-100 px-5 py-4">
					<h2 class="m-0 font-display text-sm font-medium uppercase tracking-wide text-brand-black">
						Registered Server IPs
					</h2>
					<span class="text-xs text-zinc-500">
						{license.servers.filter((s) => !s.isTestServer).length}
						{license.maxServers ? `/ ${license.maxServers}` : ""} real servers
					</span>
				</div>
				{license.servers.length > 0 && (
					<ul class="list-none divide-y divide-zinc-100 p-0">
						{license.servers.map((server) => (
							<li class="flex items-center justify-between gap-4 px-5 py-3">
								<div>
									<span class="font-mono text-sm text-brand-black">{server.ipAddress}</span>
									{server.label && <span class="ml-2 text-xs text-zinc-500">{server.label}</span>}
									{server.isTestServer && (
										<span class="ml-2 rounded bg-zinc-100 px-1.5 py-0.5 text-[10px] font-semibold uppercase text-zinc-500">
											Test
										</span>
									)}
									{server.lastVerifiedAt && (
										<span class="ml-2 text-xs text-zinc-400">
											Verified {server.lastVerifiedAt.toLocaleDateString("en-GB")}
										</span>
									)}
								</div>
								<form method="post">
									<input type="hidden" name="_action" value="remove-ip" />
									<input type="hidden" name="serverId" value={server.id} />
									<ManageBtn type="submit" variant="danger" confirm="Remove this IP?">
										Remove
									</ManageBtn>
								</form>
							</li>
						))}
					</ul>
				)}
				<form method="post" class="border-t border-zinc-100 px-5 py-4">
					<input type="hidden" name="_action" value="add-ip" />
					<div class="flex flex-wrap items-end gap-3">
						<div>
							<label class="mb-1 block font-display text-[10px] uppercase tracking-widest text-zinc-500">
								IP Address
							</label>
							<input
								type="text"
								name="ipAddress"
								required
								placeholder="1.2.3.4"
								class="border border-zinc-300 bg-white px-3 py-2 text-sm focus:border-brand-black focus:outline-none"
							/>
						</div>
						<div>
							<label class="mb-1 block font-display text-[10px] uppercase tracking-widest text-zinc-500">
								Label
							</label>
							<input
								type="text"
								name="label"
								placeholder="Optional"
								class="border border-zinc-300 bg-white px-3 py-2 text-sm focus:border-brand-black focus:outline-none"
							/>
						</div>
						<div class="flex items-center gap-2 pb-2">
							<input type="checkbox" name="isTestServer" id="isTestServer" class="h-4 w-4" />
							<label for="isTestServer" class="text-xs text-zinc-600">Test</label>
						</div>
						<ManageBtn type="submit" variant="primary">Add IP</ManageBtn>
					</div>
				</form>
			</div>
		</div>

		<!-- Sidebar -->
		<div class="space-y-4">
			<div class="border border-zinc-200 bg-white p-5">
				<h2 class="m-0 font-display text-sm font-medium uppercase tracking-wide text-brand-black">
					Status
				</h2>
				<span class:list={["mt-3 inline-block rounded px-2 py-0.5 text-[10px] font-semibold uppercase", statusClass[license.status]]}>
					{license.status}
				</span>
				{license.gracePeriodEnd && (
					<p class="mt-2 text-xs text-zinc-500">
						Grace until: {license.gracePeriodEnd.toLocaleDateString("en-GB")}
					</p>
				)}
				<div class="mt-4 flex flex-wrap gap-2">
					{license.status !== "ACTIVE" && (
						<form method="post">
							<input type="hidden" name="_action" value="activate" />
							<ManageBtn type="submit" variant="success">Activate</ManageBtn>
						</form>
					)}
					{license.status !== "SUSPENDED" && (
						<form method="post">
							<input type="hidden" name="_action" value="suspend" />
							<ManageBtn type="submit" variant="warning">Suspend</ManageBtn>
						</form>
					)}
					{license.status !== "REVOKED" && (
						<form method="post">
							<input type="hidden" name="_action" value="revoke" />
							<ManageBtn type="submit" variant="danger" confirm="Revoke this license?">
								Revoke
							</ManageBtn>
						</form>
					)}
					{license.status === "ACTIVE" && (
						<form method="post">
							<input type="hidden" name="_action" value="grace" />
							<ManageBtn type="submit" variant="muted">Set Grace</ManageBtn>
						</form>
					)}
				</div>
			</div>

			<div class="border border-zinc-200 bg-white p-5">
				<h2 class="m-0 font-display text-sm font-medium uppercase tracking-wide text-brand-black">
					Customer
				</h2>
				<p class="mt-2 font-semibold text-brand-black">{license.customer.displayName}</p>
				<div class="mt-2">
					<a
						href={`/manage/customers/${license.customer.id}`}
						class="font-display border border-zinc-300 bg-white px-3 py-1 text-xs uppercase tracking-wide text-zinc-700 transition-colors hover:border-zinc-400"
					>
						View Customer
					</a>
				</div>
			</div>

			<div class="border border-zinc-200 bg-white p-5">
				<h2 class="m-0 font-display text-sm font-medium uppercase tracking-wide text-brand-black">
					Order
				</h2>
				<p class="mt-2 font-mono text-xs text-zinc-500">
					#{license.orderItem.order.id.slice(-8).toUpperCase()}
				</p>
				<div class="mt-2">
					<a
						href={`/manage/orders/${license.orderItem.order.id}`}
						class="font-display border border-zinc-300 bg-white px-3 py-1 text-xs uppercase tracking-wide text-zinc-700 transition-colors hover:border-zinc-400"
					>
						View Order
					</a>
				</div>
			</div>
		</div>
	</div>
</ManageLayout>

---
import ManageLayout from "../../../layouts/ManageLayout.astro";
import { prisma } from "../../../lib/prisma";
import type { LicenseStatus } from "@prisma/client";

export const prerender = false;

const filter = (Astro.url.searchParams.get("status") ?? "all") as LicenseStatus | "all";
const where = filter === "all" ? {} : { status: filter };

const licenses = await prisma.serverLicense.findMany({
	where,
	orderBy: { createdAt: "desc" },
	take: 100,
	include: {
		customer: true,
		variant: { include: { product: true } },
		_count: { select: { servers: true } },
	},
});

const counts = await prisma.serverLicense.groupBy({ by: ["status"], _count: true });
const countMap = Object.fromEntries(counts.map((c) => [c.status, c._count]));
const totalCount = counts.reduce((sum, c) => sum + c._count, 0);

const tabs = [
	{ id: "all", label: "All", count: totalCount },
	{ id: "ACTIVE", label: "Active", count: countMap.ACTIVE ?? 0 },
	{ id: "GRACE", label: "Grace", count: countMap.GRACE ?? 0 },
	{ id: "REVOKED", label: "Revoked", count: countMap.REVOKED ?? 0 },
	{ id: "SUSPENDED", label: "Suspended", count: countMap.SUSPENDED ?? 0 },
] as const;

const statusClass: Record<string, string> = {
	ACTIVE: "bg-emerald-100 text-emerald-800",
	GRACE: "bg-amber-100 text-amber-800",
	REVOKED: "bg-red-100 text-red-700",
	SUSPENDED: "bg-zinc-100 text-zinc-700",
};
---

<ManageLayout title="Licenses" active="licenses">
	<div class="flex flex-wrap items-center justify-between gap-4">
		<div>
			<h1 class="m-0 font-display text-2xl font-medium uppercase tracking-[0.12em]">Licenses</h1>
			<p class="mt-1 text-sm text-zinc-500">View and manage server licenses.</p>
		</div>
	</div>

	<nav class="mt-6 flex flex-wrap gap-1.5">
		{tabs.map((tab) => (
			<a
				href={tab.id === "all" ? "/manage/licenses" : `/manage/licenses?status=${tab.id}`}
				class:list={[
					"font-display rounded-full border px-3.5 py-1.5 text-xs uppercase tracking-wide transition-colors",
					filter === tab.id
						? "border-brand-black bg-brand-black text-white"
						: "border-zinc-200 bg-white text-zinc-600 hover:bg-zinc-50",
				]}
			>
				{tab.label}
				<span class="ml-1 opacity-60">{tab.count}</span>
			</a>
		))}
	</nav>

	{licenses.length === 0 ? (
		<div class="mt-5 rounded-xl border border-dashed border-zinc-300 bg-white px-6 py-12 text-center shadow-sm">
			<svg class="mx-auto mb-3 h-8 w-8 text-zinc-300" viewBox="0 0 16 16" fill="none" aria-hidden="true">
				<path d="M8 2l5 2v4c0 2.8-2 5.4-5 6.5C5 13.4 3 10.8 3 8V4l5-2z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
			</svg>
			<p class="m-0 text-sm text-zinc-500">No licenses in this view.</p>
		</div>
	) : (
		<ul class="mt-4 list-none overflow-hidden rounded-xl border border-zinc-200 bg-white p-0 shadow-sm">
			{licenses.map((license) => (
				<li class="border-b border-zinc-100 last:border-0">
					<a
						href={`/manage/licenses/${license.id}`}
						class="flex items-center justify-between gap-4 px-5 py-4 transition-colors hover:bg-zinc-50"
					>
						<div class="min-w-0 flex-1">
							<p class="m-0 font-semibold text-brand-black">
								{license.variant.product.title} &ndash; {license.variant.name}
							</p>
							<p class="m-0 mt-0.5 text-xs text-zinc-500">
								{license.customer.displayName} &middot; {license._count.servers} IP{license._count.servers !== 1 ? "s" : ""}
								{license.maxServers ? ` / ${license.maxServers} max` : ""}
							</p>
						</div>
						<div class="flex shrink-0 items-center gap-3">
							<span class:list={["rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase", statusClass[license.status] ?? "bg-zinc-100 text-zinc-700"]}>
								{license.status}
							</span>
							<svg class="h-4 w-4 text-zinc-300" viewBox="0 0 16 16" fill="none" aria-hidden="true">
								<path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</div>
					</a>
				</li>
			))}
		</ul>
	)}
</ManageLayout>

---
import ManageLayout from "../../../layouts/ManageLayout.astro";
import { prisma } from "../../../lib/prisma";

export const prerender = false;

const search = Astro.url.searchParams.get("q")?.trim() ?? "";

const customers = await prisma.customer.findMany({
	orderBy: { createdAt: "desc" },
	take: 100,
	where: search
		? { OR: [{ displayName: { contains: search, mode: "insensitive" } }, { email: { contains: search, mode: "insensitive" } }] }
		: undefined,
	include: {
		accounts: true,
		_count: { select: { orders: true, licenses: true } },
	},
});

const total = await prisma.customer.count();
---

<ManageLayout title="Customers" active="customers">
	<div class="flex flex-wrap items-center justify-between gap-4">
		<div>
			<h1 class="m-0 font-display text-2xl font-medium uppercase tracking-[0.12em]">Customers</h1>
			<p class="mt-1 text-sm text-zinc-500">{total} registered customer{total !== 1 ? "s" : ""}</p>
		</div>
		<form method="get" class="flex items-center gap-2">
			<input
				type="search"
				name="q"
				value={search}
				placeholder="Search by name or email"
				class="rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm text-brand-black placeholder-zinc-400 focus:border-brand-black focus:outline-none"
			/>
			<button type="submit" class="font-display rounded-lg border border-zinc-300 bg-white px-3 py-2 text-xs uppercase tracking-wide text-zinc-700 transition-colors hover:bg-zinc-50">
				Search
			</button>
		</form>
	</div>

	{customers.length === 0 ? (
		<div class="mt-6 rounded-xl border border-dashed border-zinc-300 bg-white px-6 py-12 text-center shadow-sm">
			<svg class="mx-auto mb-3 h-8 w-8 text-zinc-300" viewBox="0 0 16 16" fill="none" aria-hidden="true">
				<circle cx="8" cy="5" r="2.5" stroke="currentColor" stroke-width="1.25"/>
				<path d="M3 14c0-2.8 2.2-5 5-5s5 2.2 5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
			</svg>
			<p class="m-0 text-sm text-zinc-500">{search ? `No customers matching "${search}".` : "No customers yet."}</p>
		</div>
	) : (
		<ul class="mt-6 list-none overflow-hidden rounded-xl border border-zinc-200 bg-white p-0 shadow-sm">
			{customers.map((customer) => (
				<li class="border-b border-zinc-100 last:border-0">
					<a
						href={`/manage/customers/${customer.id}`}
						class="flex items-center gap-4 px-5 py-4 transition-colors hover:bg-zinc-50"
					>
						<div class="shrink-0">
							{customer.avatarUrl ? (
								<img src={customer.avatarUrl} alt="" class="h-9 w-9 rounded-full border border-zinc-200" />
							) : (
								<div class="flex h-9 w-9 items-center justify-center rounded-full bg-monarch-500 font-display text-sm font-medium text-white">
									{customer.displayName.charAt(0).toUpperCase()}
								</div>
							)}
						</div>
						<div class="min-w-0 flex-1">
							<p class="m-0 font-semibold text-brand-black">{customer.displayName}</p>
							{customer.email && <p class="m-0 text-xs text-zinc-500">{customer.email}</p>}
							<div class="mt-1 flex flex-wrap gap-1">
								{customer.accounts.map((acc) => (
									<span class="rounded-full bg-zinc-100 px-2 py-0.5 text-[10px] font-semibold uppercase text-zinc-600">
										{acc.provider}
									</span>
								))}
							</div>
						</div>
						<div class="shrink-0 text-right">
							<p class="m-0 text-sm text-zinc-600">{customer._count.orders} order{customer._count.orders !== 1 ? "s" : ""}</p>
							<p class="m-0 text-xs text-zinc-400">{customer._count.licenses} license{customer._count.licenses !== 1 ? "s" : ""}</p>
						</div>
						<svg class="h-4 w-4 shrink-0 text-zinc-300" viewBox="0 0 16 16" fill="none" aria-hidden="true">
							<path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</a>
				</li>
			))}
		</ul>
	)}
</ManageLayout>

---
import ManageLayout from "../../../layouts/ManageLayout.astro";
import ManageBtn from "../../../components/manage/ManageBtn.astro";
import { prisma } from "../../../lib/prisma";
import type { ReviewStatus } from "@prisma/client";

export const prerender = false;

const filter = (Astro.url.searchParams.get("status") ?? "PENDING") as ReviewStatus | "ALL";

const where = filter === "ALL" ? {} : { status: filter as ReviewStatus };

const reviews = await prisma.productReview.findMany({
	where,
	include: {
		product: { select: { title: true, slug: true } },
		customer: { select: { displayName: true, email: true } },
	},
	orderBy: { createdAt: "desc" },
	take: 200,
});

const counts = await prisma.productReview.groupBy({ by: ["status"], _count: true });
const countMap = Object.fromEntries(counts.map((c) => [c.status, c._count]));
const total = counts.reduce((s, c) => s + c._count, 0);

const tabs = [
	{ id: "PENDING", label: "Pending", count: countMap.PENDING ?? 0 },
	{ id: "APPROVED", label: "Approved", count: countMap.APPROVED ?? 0 },
	{ id: "REJECTED", label: "Rejected", count: countMap.REJECTED ?? 0 },
	{ id: "ALL", label: "All", count: total },
] as const;

const statusBadge = (status: ReviewStatus) => {
	const map: Record<ReviewStatus, string> = {
		PENDING: "bg-amber-100 text-amber-800",
		APPROVED: "bg-emerald-100 text-emerald-800",
		REJECTED: "bg-red-100 text-red-800",
	};
	return map[status];
};
---

<ManageLayout title="Reviews" active="reviews">
	<div class="flex flex-wrap items-center justify-between gap-4">
		<div>
			<h1 class="m-0 font-display text-2xl font-medium uppercase tracking-[0.12em]">Reviews</h1>
			<p class="mt-1 text-sm text-zinc-500">Moderate customer product reviews before they go public</p>
		</div>
	</div>

	<nav class="mt-6 flex flex-wrap gap-1.5" aria-label="Filter by status">
		{tabs.map((tab) => {
			const href = tab.id === "ALL" ? "/manage/reviews?status=ALL" : `/manage/reviews?status=${tab.id}`;
			return (
				<a
					href={href}
					class:list={[
						"font-display rounded-full border px-3.5 py-1.5 text-xs uppercase tracking-wide transition-colors",
						filter === tab.id
							? "border-brand-black bg-brand-black text-white"
							: "border-zinc-200 bg-white text-zinc-600 hover:bg-zinc-50",
					]}
				>
					{tab.label}
					<span class="ml-1 opacity-60">{tab.count}</span>
				</a>
			);
		})}
	</nav>

	{reviews.length === 0 ? (
		<div class="mt-5 rounded-xl border border-dashed border-zinc-300 bg-white px-6 py-12 text-center shadow-sm">
			<svg class="mx-auto mb-3 h-8 w-8 text-zinc-300" viewBox="0 0 16 16" fill="none" aria-hidden="true">
				<path d="M8 2l1.5 3.5 3.5.5-2.5 2.5.5 3.5L8 10.5l-3 1.5.5-3.5L3 6l3.5-.5z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
			</svg>
			<p class="m-0 text-sm text-zinc-500">No reviews in this view.</p>
		</div>
	) : (
		<ul class="mt-4 list-none overflow-hidden rounded-xl border border-zinc-200 bg-white p-0 shadow-sm">
			{reviews.map((review) => (
				<li class="border-b border-zinc-100 px-5 py-5 last:border-0">
					<div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
						<div class="min-w-0 flex-1">
							<div class="flex flex-wrap items-center gap-2">
								<div class="flex gap-0.5" aria-label={`${review.rating} out of 5`}>
									{[1, 2, 3, 4, 5].map((n) => (
										<svg
											class={`h-3.5 w-3.5 ${n <= review.rating ? "text-amber-400" : "text-zinc-200"}`}
											viewBox="0 0 20 20"
											fill="currentColor"
											aria-hidden="true"
										>
											<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
										</svg>
									))}
								</div>
								<span class:list={["rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase", statusBadge(review.status)]}>
									{review.status}
								</span>
								<a
									href={`/shop/${review.product.slug}`}
									class="text-xs font-medium text-monarch-500 hover:text-brand-black"
									target="_blank"
								>
									{review.product.title}
								</a>
								<span class="text-xs text-zinc-400">{review.createdAt.toLocaleString("en-GB")}</span>
							</div>
							<p class="m-0 mt-1.5 text-sm font-semibold text-brand-black">
								{review.customer.displayName}
								{review.customer.email && (
									<span class="ml-1 font-normal text-zinc-500">&lt;{review.customer.email}&gt;</span>
								)}
							</p>
							{review.title && (
								<p class="m-0 mt-2 text-sm font-semibold text-brand-black">{review.title}</p>
							)}
							<p class="m-0 mt-1 text-sm leading-relaxed text-zinc-600">
								{review.body.length > 300 ? review.body.slice(0, 300).trimEnd() + "..." : review.body}
							</p>
						</div>
						<div class="flex shrink-0 flex-wrap gap-1.5 sm:flex-col sm:items-end">
							{review.status !== "APPROVED" && (
								<form method="post" action={`/api/manage/reviews/${review.id}`}>
									<input type="hidden" name="_action" value="approve" />
									<input type="hidden" name="_returnStatus" value={filter} />
									<ManageBtn type="submit" variant="success">Approve</ManageBtn>
								</form>
							)}
							{review.status !== "REJECTED" && (
								<form method="post" action={`/api/manage/reviews/${review.id}`}>
									<input type="hidden" name="_action" value="reject" />
									<input type="hidden" name="_returnStatus" value={filter} />
									<ManageBtn type="submit" variant="warning">Reject</ManageBtn>
								</form>
							)}
							{review.status !== "PENDING" && (
								<form method="post" action={`/api/manage/reviews/${review.id}`}>
									<input type="hidden" name="_action" value="pending" />
									<input type="hidden" name="_returnStatus" value={filter} />
									<ManageBtn type="submit" variant="muted">Reset</ManageBtn>
								</form>
							)}
							<form method="post" action={`/api/manage/reviews/${review.id}`}>
								<input type="hidden" name="_action" value="delete" />
								<input type="hidden" name="_returnStatus" value={filter} />
								<ManageBtn type="submit" variant="danger" confirm="Delete this review permanently?">Delete</ManageBtn>
							</form>
						</div>
					</div>
				</li>
			))}
		</ul>
	)}
</ManageLayout>

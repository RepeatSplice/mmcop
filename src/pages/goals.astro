---
import SiteLayout from "../layouts/SiteLayout.astro";

const priorities = [
	{
		title: "Climate & resources",
		body: "Reduce operational footprint in UK logistics and packaging, aligned with group science-based targets and local reporting (demo copy).",
	},
	{
		title: "Circular products",
		body: "Design for durability, serviceability, and end-of-life pathways — supporting dealers with repair parts and clear guidance (demo copy).",
	},
	{
		title: "Angler experience",
		body: "Invest in product clarity, education, and digital tools so anglers choose the right tackle and use it safely (demo copy).",
	},
	{
		title: "Inclusive sport",
		body: "Grow participation responsibly through clubs, schools where appropriate, and accessible storytelling (demo copy).",
	},
];
---

<SiteLayout
	title="Goals — Shimano Fishing United Kingdom"
	description="2030 priorities and innovation roadmap for Shimano Fishing in the UK. Demo corporate strategy page."
>
	<div slot="pre-main" class="mb-20 w-full">
		<div class="group/banner relative min-h-[240px] overflow-hidden text-white md:min-h-[300px]">
			<div class="absolute inset-0">
				<img
					src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=2000&q=80"
					alt=""
					width="2000"
					height="800"
					loading="eager"
					class="h-full min-h-[240px] w-full object-cover md:min-h-[300px]"
				/>
			</div>
			<div
				class="pointer-events-none absolute inset-0 bg-[linear-gradient(90deg,rgba(0,0,0,0.58)_0%,rgba(0,0,0,0.28)_55%,rgba(0,0,0,0.15)_100%)]"
				aria-hidden="true"
			>
			</div>
			<div class="relative z-10 mx-auto flex min-h-[240px] max-w-7xl flex-col items-start justify-center gap-3 px-6 py-14 md:min-h-[300px] md:gap-4 md:py-16">
				<p class="m-0 font-display text-[11px] uppercase tracking-[0.2em] text-white/75">Goals</p>
				<h1 class="m-0 max-w-[22ch] font-display text-[clamp(1.85rem,5vw,3rem)] font-medium uppercase leading-tight tracking-wide">
					Towards 2030 — UK fishing
				</h1>
				<p class="m-0 max-w-3xl text-base leading-relaxed text-white/90 md:text-lg">
					Priorities that connect global Shimano direction to how we compete, serve dealers, and support anglers in the
					United Kingdom and Ireland.
				</p>
				<a
					class="font-display mt-2 inline-flex items-center justify-center border-0 bg-white px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-brand-black transition-colors hover:bg-zinc-100"
					href="#goals"
				>
					Read our direction
				</a>
			</div>
		</div>
	</div>

	<section class="text-center" id="goals" aria-labelledby="goals-heading">
		<h2 id="goals-heading" class="m-0 font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em]">
			Our direction
		</h2>
	</section>

	<div class="w-full max-w-none text-left">
		<p class="m-0 text-base leading-relaxed text-zinc-600">
			This page summarises how the UK fishing organisation translates group-level goals into market priorities: sustainable
			growth, trusted products, and a stronger sport. Figures, dates, and programme names here are <strong class="font-semibold text-brand-black">placeholders</strong> for layout only.
		</p>
		<p class="mt-5 text-base leading-relaxed text-zinc-600">
			Publish official targets only after approval from group sustainability, legal, and regional leadership.
		</p>
	</div>

	<section class="text-center" id="priorities" aria-labelledby="priorities-heading">
		<h2 id="priorities-heading" class="m-0 font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em]">
			2030 priorities
		</h2>
	</section>

	<div class="grid w-full gap-4 sm:grid-cols-2">
		{
			priorities.map((p) => (
				<div class="border border-zinc-200 bg-white p-6 text-left shadow-sm">
					<h3 class="m-0 mb-3 font-display text-sm font-medium uppercase tracking-wide text-brand-black">{p.title}</h3>
					<p class="m-0 text-sm leading-relaxed text-zinc-600">{p.body}</p>
				</div>
			))
		}
	</div>

	<ul class="m-0 w-full list-none border border-zinc-200 bg-zinc-50 p-0">
		<li class="border-b border-zinc-200 px-[1.1rem] py-4 text-sm leading-relaxed text-zinc-700 last:border-b-0">
			<span class="font-semibold text-brand-black">Measure:</span> define UK-specific KPIs that map to group scorecards (demo copy).
		</li>
		<li class="border-b border-zinc-200 px-[1.1rem] py-4 text-sm leading-relaxed text-zinc-700 last:border-b-0">
			<span class="font-semibold text-brand-black">Report:</span> annual narrative on progress, risks, and course corrections (demo copy).
		</li>
		<li class="px-[1.1rem] py-4 text-sm leading-relaxed text-zinc-700">
			<span class="font-semibold text-brand-black">Engage:</span> involve dealers and ambassadors in credible, evidence-led storytelling (demo copy).
		</li>
	</ul>

	<section class="-mx-6 w-[calc(100%+3rem)] border-y border-zinc-200 bg-zinc-100 px-6 py-12" id="roadmap" aria-labelledby="roadmap-heading">
		<h2 id="roadmap-heading" class="m-0 text-center font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em]">
			Innovation roadmap
		</h2>
		<p class="mx-auto mt-4 max-w-none text-center text-base leading-relaxed text-zinc-600">
			Phases, themes, and milestones live on the dedicated roadmap page — kept separate so goals stay high-level and the roadmap
			can evolve on its own cadence.
		</p>
		<div class="mt-8 flex justify-center">
			<a
				class="font-display inline-flex items-center justify-center bg-brand-black px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-white transition-colors hover:bg-zinc-800"
				href="/roadmap"
			>
				Open innovation roadmap
			</a>
		</div>
	</section>

	<section class="text-center">
		<h2 class="m-0 font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em]">Where to next</h2>
	</section>

	<div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:justify-center">
		<a
			class="font-display inline-flex items-center justify-center border border-zinc-200 bg-white px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-brand-black transition-colors hover:border-zinc-300 hover:bg-zinc-50"
			href="/"
		>
			Back to home
		</a>
		<a
			class="font-display inline-flex items-center justify-center border border-zinc-200 bg-white px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-brand-black transition-colors hover:border-zinc-300 hover:bg-zinc-50"
			href="/about"
		>
			About us
		</a>
		<a
			class="font-display inline-flex items-center justify-center border border-zinc-200 bg-white px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-brand-black transition-colors hover:border-zinc-300 hover:bg-zinc-50"
			href="/partners"
		>
			Partners
		</a>
		<a
			class="font-display inline-flex items-center justify-center border border-zinc-200 bg-white px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-brand-black transition-colors hover:border-zinc-300 hover:bg-zinc-50"
			href="/roadmap"
		>
			Innovation roadmap
		</a>
		<a
			class="font-display inline-flex items-center justify-center bg-brand-black px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-white transition-colors hover:bg-zinc-800"
			href="/#news"
		>
			Latest news
		</a>
	</div>

	<section class="-mx-6 w-[calc(100%+3rem)] border-t border-zinc-200 bg-zinc-100" id="contact">
		<div class="grid w-full grid-cols-1 md:grid-cols-2">
			<div class="flex flex-col items-center border-b border-zinc-200 px-4 py-10 md:border-b-0 md:border-r md:border-zinc-200">
				<div class="w-full max-w-[36ch] text-left">
					<h2 class="mb-1.5 font-display font-medium uppercase tracking-wide">Members</h2>
					<span class="mb-3 block font-sans text-[13px] font-normal tracking-normal text-zinc-600">Shimano members</span>
					<p class="mb-5 text-sm leading-normal text-zinc-600">Catalogue requests, event news, and email updates in one place.</p>
					<a
						class="font-display inline-flex w-fit bg-brand-black px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-white transition-colors hover:bg-zinc-800"
						href="#"
					>
						Become a member
					</a>
				</div>
			</div>
			<div class="flex flex-col items-center px-4 py-10">
				<div class="w-full max-w-[36ch] text-left">
					<h2 class="mb-1.5 font-display font-medium uppercase tracking-wide">Dealer</h2>
					<span class="mb-3 block font-sans text-[13px] font-normal tracking-normal text-zinc-600">Store information</span>
					<p class="mb-5 text-sm leading-normal text-zinc-600">Find authorised retailers and service centres near you.</p>
					<a
						class="font-display inline-flex w-fit bg-brand-black px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-white transition-colors hover:bg-zinc-800"
						href="#"
					>
						Search for dealers
					</a>
				</div>
			</div>
		</div>
	</section>

	<script>
		import { initHome } from "../scripts/home.ts";
		initHome();
	</script>
</SiteLayout>

---
import MonarchBasicPage from "../components/MonarchBasicPage.astro";
import { partners } from "../lib/partners.ts";
---

<MonarchBasicPage
	title="Partners | Monarch"
	description="Monarch partners and collaborators across DayZ modding, servers, hosting, and content."
	eyebrow="Company"
	heading="Partners"
	lead="Brands and creators we work with across modding, live play, hosting, and community content."
	image="/Partners_Banner.png"
>
	<div
		class="partners-page-grid grid gap-[18px]"
		style="grid-template-columns: repeat(auto-fill, minmax(min(100%, 11rem), 1fr));"
		role="list"
	>
		{
			partners.map((p) => {
				const scale = p.logoScale ?? 1;
				const tileClass =
					"group partners-page-tile flex h-24 items-center justify-center overflow-hidden rounded-2xl border border-black/[0.08] bg-white no-underline transition-[transform,box-shadow] duration-[180ms] ease-out hover:-translate-y-0.5 hover:shadow-[0_12px_30px_rgba(0,0,0,0.08)] sm:h-[6rem]";
				const img = (
					<img
						src={p.logo}
						alt={p.name}
						width="260"
						height="96"
						loading="lazy"
						decoding="async"
						class="block h-[70%] w-[92%] max-h-none max-w-none object-contain opacity-[0.42] grayscale transition-[opacity,filter] duration-300 group-hover:opacity-100 group-hover:grayscale-0 group-focus-visible:opacity-100 group-focus-visible:grayscale-0"
						style={`transform: scale(${scale}); transform-origin: center;`}
					/>
				);

				return p.href ? (
					<a
						class={tileClass}
						href={p.href}
						target="_blank"
						rel="noopener noreferrer"
						role="listitem"
					>
						{img}
					</a>
				) : (
					<div class={tileClass} role="listitem">
						{img}
					</div>
				);
			})
		}
	</div>
</MonarchBasicPage>

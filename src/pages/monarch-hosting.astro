---
import MonarchBasicPage from "../components/MonarchBasicPage.astro";
import MonarchProse from "../components/MonarchProse.astro";
---

<MonarchBasicPage
	title="Monarch Hosting | Game server infrastructure"
	description="Monarch Hosting is planned for early 2027. Until launch, communities can use VYKIX for high performance DayZ hosting."
	eyebrow="Services"
	heading="Monarch Hosting"
	lead="Dedicated Monarch hosting is in development for early 2027. Until then, we partner with VYKIX for serious DayZ server hardware."
	image="/VYKIX%20Logo%20%5BVectorized%5D.png"
	cta={{ label: "Explore VYKIX hosting", href: "https://www.vykix.com", external: true }}
>
	<MonarchProse heading="What we do">
		<p>
			Monarch Hosting will be a standalone product pairing our operational experience with hardware and control panels built
			for DayZ communities. We are targeting early 2027 for launch.
		</p>
		<p>
			Today, hosting needs are met through VYKIX, our hosting partner for overclocked hardware, DDoS protection, and fast
			deploys. Monarch Modding and Operation Monarch workloads already run in that ecosystem.
		</p>
	</MonarchProse>
</MonarchBasicPage>

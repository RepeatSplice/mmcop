---
import MonarchBasicPage from "../components/MonarchBasicPage.astro";
import MonarchProse from "../components/MonarchProse.astro";
---

<MonarchBasicPage
	title="Operation Monarch | DayZ community servers"
	description="Operation Monarch runs community DayZ servers, events, and curated worlds under the Monarch group."
	eyebrow="Services"
	heading="Operation Monarch"
	lead="Community servers, seasonal events, and curated worlds where players experience Monarch content in live play."
	image="/Operation%20Monarch%20Logo.png"
	cta={{ label: "Play Operation Monarch", href: "https://play-opm.com", external: true }}
>
	<MonarchProse heading="What we do">
		<p>
			Operation Monarch is the player facing home for Monarch built worlds. It is where communities connect for wipes,
			events, and long form gameplay on servers operated with the same standards as our modding work.
		</p>
		<p>
			If you want a Monarch aligned place to play, start here. Server news, schedules, and join information live on the
			Operation Monarch site.
		</p>
	</MonarchProse>
</MonarchBasicPage>

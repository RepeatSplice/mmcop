---
import SiteLayout from "../../layouts/SiteLayout.astro";
import MonarchPageHero from "../../components/MonarchPageHero.astro";
import { listPublishedProducts } from "../../lib/products";
import { getProductRating } from "../../lib/reviews";
import type { ProductCategory } from "@prisma/client";

export const prerender = false;

const categories: { id: ProductCategory | "all"; label: string }[] = [
	{ id: "all", label: "All Products" },
	{ id: "modding", label: "Modding" },
	{ id: "software", label: "Software" },
	{ id: "hosting", label: "Hosting" },
	{ id: "bundle", label: "Bundles" },
	{ id: "other", label: "Other" },
];

const filterParam = Astro.url.searchParams.get("category") as ProductCategory | null;
const activeCategory = filterParam && filterParam !== "all" ? filterParam : undefined;
const activeTab = filterParam ?? "all";

const statusParam = Astro.url.searchParams.get("status");

let products = await listPublishedProducts(activeCategory);
if (statusParam === "waitlist") {
	products = products.filter((p) => p.status === "WAITLIST");
} else if (statusParam === "available") {
	products = products.filter((p) => p.status !== "WAITLIST");
}

const formatPrice = (cents: number) => `$${(cents / 100).toFixed(2)}`;

const categoryLabels: Record<string, string> = {
	modding: "Modding",
	software: "Software",
	hosting: "Hosting",
	bundle: "Bundle",
	other: "Other",
};

// Sort
const sortParam = Astro.url.searchParams.get("sort") ?? "featured";
const sortOptions = [
	{ id: "featured", label: "Featured" },
	{ id: "price-asc", label: "Price: low to high" },
	{ id: "price-desc", label: "Price: high to low" },
	{ id: "newest", label: "Newest" },
];

if (sortParam === "price-asc") {
	products.sort((a, b) => {
		const aMin = Math.min(...a.variants.map((v) => v.priceUsd));
		const bMin = Math.min(...b.variants.map((v) => v.priceUsd));
		return aMin - bMin;
	});
} else if (sortParam === "price-desc") {
	products.sort((a, b) => {
		const aMin = Math.min(...a.variants.map((v) => v.priceUsd));
		const bMin = Math.min(...b.variants.map((v) => v.priceUsd));
		return bMin - aMin;
	});
} else if (sortParam === "newest") {
	products.sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());
}

const ratings = await Promise.all(
	products.map((p) => getProductRating(p.id).catch(() => ({ average: 0, count: 0 })))
);
---

<SiteLayout title="Shop | Monarch" description="Premium DayZ mods, software, and hosting solutions.">
	<slot slot="pre-main">
		<MonarchPageHero
			title={activeCategory ? (categoryLabels[activeCategory] ?? activeCategory) : "Shop"}
			lead="Premium DayZ mods, software, and hosting. Licensed and download-ready."
			image="/News_Banner.png"
		/>
	</slot>

	<!-- Main content: sidebar + grid -->
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="flex gap-10 pb-16 pt-2">

			<!-- LEFT SIDEBAR -->
			<aside id="shop-sidebar" class="hidden w-48 shrink-0 lg:block">
				<div class="sticky top-6 space-y-8">

				<!-- Categories -->
				<div>
					<p class="m-0 mb-4 font-display text-[10px] uppercase tracking-[0.18em] text-zinc-400">Category</p>
					<nav class="flex flex-col gap-0.5">
						{categories.map((cat) => (
							<a
								href={cat.id === "all" ? "/shop" : `/shop?category=${cat.id}${sortParam !== "featured" ? `&sort=${sortParam}` : ""}${statusParam ? `&status=${statusParam}` : ""}`}
								class:list={[
									"group flex items-center justify-between rounded-lg px-3 py-2.5 text-[15px] font-medium transition-all",
									activeTab === cat.id
										? "bg-brand-black text-white"
										: "text-zinc-600 hover:bg-zinc-100 hover:text-brand-black",
								]}
							>
								<span>{cat.label}</span>
								{activeTab === cat.id && (
									<svg class="h-3.5 w-3.5 shrink-0 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
										<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
									</svg>
								)}
							</a>
						))}
					</nav>
				</div>

				<!-- Availability -->
				<div>
					<p class="m-0 mb-4 font-display text-[10px] uppercase tracking-[0.18em] text-zinc-400">Availability</p>
					<nav class="flex flex-col gap-0.5">
						{[
							{ id: "", label: "All" },
							{ id: "available", label: "Available now" },
							{ id: "waitlist", label: "Waitlist" },
						].map((opt) => (
							<a
								href={`/shop${activeCategory ? `?category=${activeCategory}&` : "?"}${opt.id ? `status=${opt.id}` : ""}${sortParam !== "featured" ? `${(activeCategory || opt.id) ? "&" : "?"}sort=${sortParam}` : ""}`.replace(/[?&]$/, "")}
								class:list={[
									"group flex items-center justify-between rounded-lg px-3 py-2.5 text-[15px] font-medium transition-all",
									statusParam === (opt.id || null) || (!statusParam && !opt.id)
										? "bg-brand-black text-white"
										: "text-zinc-600 hover:bg-zinc-100 hover:text-brand-black",
								]}
							>
								<span>{opt.label}</span>
								{(statusParam === opt.id || (!statusParam && !opt.id)) && (
									<svg class="h-3.5 w-3.5 shrink-0 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
										<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
									</svg>
								)}
							</a>
						))}
					</nav>
				</div>

				</div>
			</aside>

			<!-- MOBILE: horizontal category strip -->
			<div class="w-full lg:hidden">
				<nav class="flex gap-1.5 overflow-x-auto pb-4">
					{categories.map((cat) => (
						<a
							href={cat.id === "all" ? "/shop" : `/shop?category=${cat.id}`}
							class:list={[
								"shrink-0 rounded-full border px-3.5 py-1.5 font-display text-[10px] uppercase tracking-widest transition-colors",
								activeTab === cat.id
									? "border-brand-black bg-brand-black text-white"
									: "border-zinc-200 text-zinc-500 hover:border-zinc-400",
							]}
						>
							{cat.label}
						</a>
					))}
				</nav>
			</div>

			<!-- RIGHT: Product grid -->
			<div class="min-w-0 flex-1">

				<!-- Topbar: hide filters / count / sort -->
				<div class="mb-6 flex items-center gap-4 border-b border-zinc-100 pb-4">
					<!-- Hide/Show filters toggle (desktop only) -->
					<button
						id="toggle-filters-btn"
						type="button"
						class="hidden items-center gap-2 rounded-lg border border-zinc-200 px-3.5 py-2 text-[13px] font-medium text-zinc-600 transition-colors hover:border-zinc-400 hover:text-brand-black lg:flex"
						aria-label="Toggle filters"
					>
						<svg class="h-4 w-4" viewBox="0 0 22 20" stroke="currentColor" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path stroke-linecap="round" d="M1.5 14H4M4 14C4 15.657 5.343 17 7 17C8.657 17 10 15.657 10 14C10 12.343 8.657 11 7 11C5.343 11 4 12.343 4 14ZM18 6H20.5M18 6C18 7.657 16.657 9 15 9C13.343 9 12 7.657 12 6C12 4.343 13.343 3 15 3C16.657 3 18 4.343 18 6ZM13 14H20.5M1.5 6H9" />
						</svg>
						<span id="toggle-filters-label">Hide filters</span>
					</button>

					<!-- Product count -->
					<p class="m-0 grow text-sm text-zinc-500">
						<span class="font-semibold text-brand-black">{products.length}</span> {products.length === 1 ? "product" : "products"}
					</p>

				<!-- Sort by (custom dropdown) -->
				<div class="relative flex items-center gap-2.5">
					<span class="text-[13px] text-zinc-500">Sort by:</span>
					<div class="relative" id="sort-dropdown-wrap">
						<button
							id="sort-dropdown-btn"
							type="button"
							class="flex cursor-pointer items-center gap-2 rounded-lg border border-zinc-200 bg-white py-2 pl-3.5 pr-3 text-[13px] font-medium text-zinc-700 transition-colors hover:border-zinc-400 hover:text-brand-black"
							aria-haspopup="listbox"
							aria-expanded="false"
						>
							<span id="sort-dropdown-label">
								{sortOptions.find((o) => o.id === sortParam)?.label ?? "Featured"}
							</span>
							<svg id="sort-dropdown-chevron" class="h-3.5 w-3.5 text-zinc-400 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
							</svg>
						</button>

						<!-- Dropdown panel -->
						<ul
							id="sort-dropdown-list"
							role="listbox"
							class="absolute right-0 top-full z-50 mt-1.5 hidden min-w-[160px] overflow-hidden rounded-xl border border-zinc-200 bg-white py-1 shadow-lg"
						>
							{sortOptions.map((opt) => (
								<li role="option" aria-selected={sortParam === opt.id}>
									<a
										href={`/shop${activeCategory ? `?category=${activeCategory}&sort=${opt.id}` : `?sort=${opt.id}`}${statusParam ? `&status=${statusParam}` : ""}`}
										class:list={[
											"flex items-center justify-between gap-3 px-4 py-2.5 text-[13px] transition-colors",
											sortParam === opt.id
												? "bg-zinc-50 font-semibold text-brand-black"
												: "text-zinc-600 hover:bg-zinc-50 hover:text-brand-black",
										]}
									>
										{opt.label}
										{sortParam === opt.id && (
											<svg class="h-3.5 w-3.5 shrink-0 text-brand-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
												<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
											</svg>
										)}
									</a>
								</li>
							))}
						</ul>
					</div>
				</div>
				</div>

				{products.length === 0 ? (
					<div class="flex flex-col items-center justify-center py-20 text-center">
						<svg class="mb-4 h-10 w-10 text-zinc-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2zM16 3H8a2 2 0 00-2 2v2h12V5a2 2 0 00-2-2z"/>
						</svg>
						<p class="m-0 font-display text-sm uppercase tracking-widest text-zinc-400">No products here yet</p>
						<a href="/shop" class="mt-4 text-xs text-zinc-500 underline underline-offset-2 hover:text-brand-black">View all products</a>
					</div>
				) : (
					<div class="grid grid-cols-2 gap-x-5 gap-y-10 sm:grid-cols-2 sm:gap-x-6 xl:grid-cols-3">
						{products.map((product, i) => {
							const lowestVariant = [...product.variants].sort((a, b) => a.priceUsd - b.priceUsd)[0];
							const isWaitlist = product.status === "WAITLIST";
							const rating = ratings[i];

							return (
								<a href={`/shop/${product.slug}`} class="group flex flex-col leading-none">

									{/* ── Image area ── */}
									<div class="relative aspect-square overflow-hidden bg-zinc-100">

										{product.imageUrl ? (
											<img
												src={product.imageUrl}
												alt={product.title}
												loading="lazy"
												decoding="async"
												class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
											/>
										) : (
											<div class="flex h-full w-full items-center justify-center">
												<img src="/Logo.svg" alt="" class="h-12 w-auto opacity-20" />
											</div>
										)}

										{/* Rating — top-right pill */}
										{rating.count > 0 && (
											<span
												class="pointer-events-none absolute right-3 top-3 z-10 flex items-center gap-1.5 rounded-full bg-white/90 px-2.5 py-1.5 text-[12px] font-semibold leading-none text-brand-black backdrop-blur-sm"
												title={`${rating.count} review${rating.count === 1 ? "" : "s"}`}
											>
												<svg class="h-3.5 w-3.5 text-amber-400" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
													<path d="M8 0L9.889 5.813H16L11.056 9.406L12.945 15.218L8 11.625L3.056 15.218L4.944 9.405L0 5.812H6.111L8 0Z"/>
												</svg>
												{rating.average.toFixed(1)}
											</span>
										)}

										{/* Waitlist indicator — bottom left */}
										{isWaitlist && (
											<span class="pointer-events-none absolute bottom-3 left-3 z-10 rounded-full bg-amber-400 px-3 py-1.5 font-display text-[10px] uppercase leading-none tracking-widest text-black">
												Waitlist
											</span>
										)}
									</div>

									{/* ── Card content ── */}
									<div class="mt-4 px-0.5">
										<div class="flex items-baseline justify-between gap-3">
											<h3 class="m-0 grow text-[16px] font-medium leading-snug text-brand-black transition-colors group-hover:text-monarch-500">
												{product.title}
											</h3>
											{lowestVariant && (
												<p class="m-0 shrink-0 text-[16px] font-semibold text-brand-black">
													{isWaitlist ? (
														<span class="text-[13px] font-normal text-zinc-400">Waitlist</span>
													) : (
														formatPrice(lowestVariant.priceUsd)
													)}
												</p>
											)}
										</div>
										{product.excerpt && (
											<p class="m-0 mt-1.5 line-clamp-2 text-[13px] leading-relaxed text-zinc-500">
												{product.excerpt}
											</p>
										)}
									</div>

								</a>
							);
						})}
					</div>
				)}
			</div>

		</div>
	</div>
</SiteLayout>

<script>
// ── Hide / show sidebar ──────────────────────────────────────────────────
const sidebar = document.getElementById("shop-sidebar") as HTMLElement | null;
const toggleBtn = document.getElementById("toggle-filters-btn");
const toggleLabel = document.getElementById("toggle-filters-label");

function applyFilterState(hidden: boolean) {
	if (!sidebar || !toggleLabel) return;
	// inline style beats any Tailwind class (including lg:block)
	sidebar.style.display = hidden ? "none" : "";
	toggleLabel.textContent = hidden ? "Show filters" : "Hide filters";
}

const storedHidden = localStorage.getItem("shop-filters-hidden") === "true";
applyFilterState(storedHidden);

toggleBtn?.addEventListener("click", () => {
	const nowHidden = sidebar?.style.display !== "none";
	localStorage.setItem("shop-filters-hidden", String(nowHidden));
	applyFilterState(nowHidden);
});

// ── Custom sort dropdown ─────────────────────────────────────────────────
const sortBtn = document.getElementById("sort-dropdown-btn");
const sortList = document.getElementById("sort-dropdown-list");
const sortChevron = document.getElementById("sort-dropdown-chevron");

function openSort() {
	sortList?.classList.remove("hidden");
	sortBtn?.setAttribute("aria-expanded", "true");
	sortChevron?.classList.add("rotate-180");
}
function closeSort() {
	sortList?.classList.add("hidden");
	sortBtn?.setAttribute("aria-expanded", "false");
	sortChevron?.classList.remove("rotate-180");
}

sortBtn?.addEventListener("click", (e) => {
	e.stopPropagation();
	sortList?.classList.contains("hidden") ? openSort() : closeSort();
});

document.addEventListener("click", (e) => {
	if (!document.getElementById("sort-dropdown-wrap")?.contains(e.target as Node)) {
		closeSort();
	}
});

document.addEventListener("keydown", (e) => {
	if (e.key === "Escape") closeSort();
});
</script>

---
import AccountLayout from "../../layouts/AccountLayout.astro";
import { prisma } from "../../lib/prisma";

export const prerender = false;

const customer = Astro.locals.customer!;

const orders = await prisma.order.findMany({
	where: { customerId: customer.id },
	orderBy: { createdAt: "desc" },
	include: {
		items: { include: { variant: { include: { product: true } } } },
	},
});

const statusLabel: Record<string, string> = {
	PENDING: "Pending",
	PAID: "Paid",
	REFUNDED: "Refunded",
	DISPUTED: "Disputed",
};
const statusColor: Record<string, string> = {
	PENDING: "acct-badge--yellow",
	PAID: "acct-badge--green",
	REFUNDED: "acct-badge--zinc",
	DISPUTED: "acct-badge--red",
};
---

<AccountLayout title="Orders | Monarch Account" tab="orders" customer={customer}>

	<div class="acct-page-header">
		<div>
			<h1 class="acct-page-header__title">Orders</h1>
			<p class="acct-page-header__sub">Your full order history with Monarch.</p>
		</div>
	</div>

	{orders.length === 0 ? (
		<div class="acct-empty">
			<svg viewBox="0 0 24 24" fill="none" class="acct-empty__icon" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 9h8M8 13h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
			<p>No orders yet.</p>
			<a href="/shop" class="acct-empty__cta">Browse the shop</a>
		</div>
	) : (
		<div class="acct-card-list">
			{orders.map((order) => (
				<div class="acct-order-card">
					<div class="acct-order-card__header">
						<div>
							<strong class="acct-order-card__id">Order #{order.id.slice(-8).toUpperCase()}</strong>
							<span class="acct-order-card__date">{order.createdAt.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })}</span>
						</div>
						<div class="acct-order-card__meta">
							<span class={`acct-badge ${statusColor[order.status]}`}>{statusLabel[order.status]}</span>
							<span class="acct-order-card__total">&pound;{(order.totalMinorUnits / 100).toFixed(2)}</span>
							<a href={`/account/orders/${order.id}`} class="acct-btn acct-btn--sm">View receipt</a>
						</div>
					</div>
					<ul class="acct-order-card__items">
						{order.items.map((item) => (
							<li class="acct-order-card__item">
								<span class="acct-order-card__item-name">{item.variant.product.title}</span>
								<span class="acct-order-card__item-variant">{item.variant.name}</span>
								<span class="acct-order-card__item-price">&pound;{(item.priceMinorUnits / 100).toFixed(2)}</span>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>
	)}

</AccountLayout>

<style>
	.acct-page-header { margin-bottom: 2rem; }
	.acct-page-header__title {
		margin: 0 0 0.375rem;
		font-family: "Oswald", sans-serif;
		font-size: 1.625rem;
		font-weight: 500;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: #0a0a0a;
	}
	.acct-page-header__sub { margin: 0; font-size: 0.9375rem; color: rgb(113 113 122); }

	.acct-card-list { display: flex; flex-direction: column; gap: 0.875rem; }

	.acct-order-card {
		background: #fff;
		border-radius: 1.125rem;
		border: 1px solid rgb(228 228 231);
		overflow: hidden;
	}
	.acct-order-card__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.125rem 1.375rem;
		border-bottom: 1px solid rgb(244 244 245);
	}
	@media (max-width: 640px) {
		.acct-order-card__header { flex-direction: column; align-items: flex-start; }
	}
	.acct-order-card__id {
		display: block;
		font-family: "Oswald", sans-serif;
		font-size: 0.9375rem;
		font-weight: 500;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: #0a0a0a;
	}
	.acct-order-card__date { font-size: 0.8125rem; color: rgb(161 161 170); }
	.acct-order-card__meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-shrink: 0;
	}
	.acct-order-card__total {
		font-family: "Oswald", sans-serif;
		font-size: 1rem;
		font-weight: 500;
		color: #0a0a0a;
	}
	.acct-order-card__items {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.acct-order-card__item {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.875rem 1.375rem;
		border-bottom: 1px solid rgb(244 244 245);
	}
	.acct-order-card__item:last-child { border-bottom: none; }
	.acct-order-card__item-name {
		font-weight: 600;
		font-size: 0.9375rem;
		color: #0a0a0a;
		flex: 1;
	}
	.acct-order-card__item-variant { font-size: 0.8125rem; color: rgb(113 113 122); }
	.acct-order-card__item-price {
		font-family: "Oswald", sans-serif;
		font-size: 0.875rem;
		font-weight: 500;
		color: #0a0a0a;
		margin-left: auto;
	}

	.acct-badge {
		display: inline-flex; align-items: center;
		padding: 0.2rem 0.625rem; border-radius: 999px;
		font-family: "Oswald", sans-serif; font-size: 0.625rem; font-weight: 500;
		letter-spacing: 0.08em; text-transform: uppercase;
	}
	.acct-badge--green { background: rgb(220 252 231); color: rgb(21 128 61); }
	.acct-badge--yellow { background: rgb(254 249 195); color: rgb(133 77 14); }
	.acct-badge--zinc { background: rgb(244 244 245); color: rgb(82 82 91); }
	.acct-badge--red { background: rgb(254 226 226); color: rgb(185 28 28); }

	.acct-btn {
		display: inline-flex; align-items: center; justify-content: center;
		padding: 0.5rem 1rem; border-radius: 0.625rem;
		border: 1px solid rgb(228 228 231); background: #fff;
		font-family: "Oswald", sans-serif; font-size: 0.6875rem; font-weight: 500;
		letter-spacing: 0.1em; text-transform: uppercase; color: #0a0a0a; text-decoration: none;
		transition: background-color 0.15s ease, border-color 0.15s ease;
	}
	.acct-btn:hover { background: rgb(244 244 245); border-color: rgb(161 161 170); }
	.acct-btn--sm { padding: 0.375rem 0.75rem; }

	.acct-empty {
		display: flex; flex-direction: column; align-items: center;
		gap: 0.75rem; padding: 3rem 2rem;
		background: #fff; border-radius: 1.125rem; border: 1px dashed rgb(212 212 216); text-align: center;
	}
	.acct-empty__icon { width: 2.5rem; height: 2.5rem; color: rgb(212 212 216); }
	.acct-empty p { margin: 0; font-size: 0.9375rem; color: rgb(113 113 122); }
	.acct-empty__cta {
		font-family: "Oswald", sans-serif; font-size: 0.75rem; font-weight: 500;
		letter-spacing: 0.1em; text-transform: uppercase; color: #0a0a0a; text-decoration: none;
		padding: 0.5rem 1.25rem; border: 1px solid #0a0a0a; border-radius: 0.625rem;
		transition: background-color 0.15s ease, color 0.15s ease;
	}
	.acct-empty__cta:hover { background: #0a0a0a; color: #fff; }
</style>

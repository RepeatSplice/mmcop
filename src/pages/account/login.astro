			};

			function goToStep2(provider: string): void {
				const p = providers[provider];
				if (!p) return;

				// Update confirm panel
				confirmIcon.innerHTML = `<div style="width:4rem;height:4rem;border-radius:1.25rem;background:${provider === "steam" ? "#1b2838" : "#5865f2"};display:flex;align-items:center;justify-content:center;">${p.icon}</div>`;
				confirmTitle.textContent = p.label;
				confirmBody.textContent = p.body;
				confirmBtn.href = p.href;
				confirmBtn.className = p.btnClass;
				confirmBtn.textContent = "";
				confirmBtn.className = p.btnClass;
				confirmBtn.innerHTML = `${p.label} <svg viewBox="0 0 16 16" fill="none" style="width:1rem;height:1rem;flex-shrink:0;" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

				// Switch panels
				step1.classList.add("is-hidden");
				step2.classList.remove("is-hidden");

			}

			function goToStep1(): void {
				step2.classList.add("is-hidden");
				step1.classList.remove("is-hidden");
			}

			document.querySelectorAll<HTMLButtonElement>("[data-provider]").forEach((btn) => {
				btn.addEventListener("click", () => goToStep2(btn.dataset.provider ?? ""));
			});

			back.addEventListener("click", goToStep1);
		</script>
	</body>
</html>

---
import "../../styles/global.css";
import { prisma } from "../../lib/prisma";
import { getCustomerFromSession } from "../../lib/customer-auth/session";

export const prerender = false;

const customer = await getCustomerFromSession(Astro.cookies);
if (!customer) return Astro.redirect("/account/login");
if (customer.onboardingComplete) return Astro.redirect("/account");

const step = Astro.url.searchParams.get("step") ?? "connect";

const accounts = await prisma.connectedAccount.findMany({ where: { customerId: customer.id } });
const hasSteam = accounts.some((a) => a.provider === "steam");
const hasDiscord = accounts.some((a) => a.provider === "discord");
const hasBoth = hasSteam && hasDiscord;

// If they have both, force to password step
const resolvedStep = hasBoth ? "password" : "connect";
const activeStep = step === "password" && hasBoth ? "password" : resolvedStep;

const missingProvider = hasSteam ? "discord" : "steam";
const connectedProvider = hasSteam ? "Steam" : "Discord";
---

<!doctype html>
<html lang="en-GB">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex" />
		<title>Set up your account | Monarch</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;600;700&family=Oswald:wght@400;500;600&display=swap" rel="stylesheet" />
	</head>
	<body class="onboard-body font-sans text-brand-black">

		<div class="onboard-layout">

			<!-- Left branding panel -->
			<div class="onboard-panel onboard-panel--left" aria-hidden="true">
				<div class="onboard-panel__inner">
					<a href="/" tabindex="-1" class="onboard-logo">
						<img src="/LogoText.svg" alt="Monarch" width="200" height="59" class="h-9 w-auto" style="filter:brightness(0) invert(1);opacity:0.9" />
					</a>
					<div class="onboard-steps-vis">
						<div class={`onboard-step-vis ${activeStep === "connect" ? "is-active" : hasBoth ? "is-done" : ""}`}>
							<span class="onboard-step-vis__num">{hasBoth ? "✓" : "1"}</span>
							<div>
								<strong>Connect both accounts</strong>
								<span>Steam + Discord required</span>
							</div>
						</div>
						<div class="onboard-step-vis__line"></div>
						<div class={`onboard-step-vis ${activeStep === "password" ? "is-active" : ""}`}>
							<span class="onboard-step-vis__num">2</span>
							<div>
								<strong>Set a site password</strong>
								<span>Used for account security</span>
							</div>
						</div>
					</div>
					<p class="onboard-panel__legal">Signed in as <strong>{customer.displayName}</strong></p>
				</div>
			</div>

			<!-- Right form panel -->
			<div class="onboard-panel onboard-panel--right">
				<div class="onboard-form-wrap">

					{activeStep === "connect" && (
						<div>
							<div class="onboard-badge">
								<svg viewBox="0 0 16 16" fill="none" class="h-4 w-4" aria-hidden="true"><path d="M8 2a6 6 0 1 0 0 12A6 6 0 0 0 8 2z" stroke="currentColor" stroke-width="1.25"/><path d="M8 6v4M8 5h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
								Step 1 of 2
							</div>
							<h1 class="onboard-title">Connect your {missingProvider === "discord" ? "Discord" : "Steam"} account</h1>
							<p class="onboard-body">
								You signed in with <strong>{connectedProvider}</strong>. To complete your Monarch account you also need to connect {missingProvider === "discord" ? "Discord" : "Steam"}.
								This lets us verify your identity across both platforms.
							</p>
							<div class="onboard-connect-row">
								<div class="onboard-connected">
									<span class={`onboard-connected__icon onboard-connected__icon--${hasSteam ? "steam" : "discord"}`}>
										{hasSteam ? (
											<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
										) : (
											<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
										)}
									</span>
									<div>
										<strong>{connectedProvider}</strong>
										<span>Connected</span>
									</div>
									<svg viewBox="0 0 16 16" fill="none" class="h-4 w-4 text-green-500 ml-auto" aria-hidden="true"><path d="M3 8l3.5 3.5L13 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
								</div>

								<a
									href={`/api/auth/${missingProvider}/redirect`}
									class={`onboard-provider-btn onboard-provider-btn--${missingProvider}`}
								>
									<span class={`onboard-provider-btn__icon onboard-provider-btn__icon--${missingProvider}`}>
										{missingProvider === "discord" ? (
											<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
										) : (
											<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
										)}
									</span>
									<span class="onboard-provider-btn__content">
										<strong>Connect {missingProvider === "discord" ? "Discord" : "Steam"}</strong>
										<span>Authorise via {missingProvider === "discord" ? "Discord OAuth" : "Steam OpenID"}</span>
									</span>
									<svg viewBox="0 0 16 16" fill="none" class="h-4 w-4 shrink-0 ml-auto opacity-50"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
								</a>
							</div>
						</div>
					)}

					{activeStep === "password" && (
						<div>
							<div class="onboard-badge onboard-badge--success">
								<svg viewBox="0 0 16 16" fill="none" class="h-4 w-4" aria-hidden="true"><path d="M3 8l3.5 3.5L13 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
								Both accounts connected
							</div>
							<h1 class="onboard-title">Set a site password</h1>
							<p class="onboard-body">
								Set a password for your Monarch account. This is separate from your Steam and Discord passwords.
							</p>

							<div class="onboard-warning">
								<svg viewBox="0 0 16 16" fill="none" class="h-4 w-4 shrink-0 mt-0.5" aria-hidden="true"><path d="M8 2L2 13h12L8 2z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/><path d="M8 7v3M8 12h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
								<span>Do not reuse your Steam or Discord password. Use something unique to this account.</span>
							</div>

							<form id="passwordForm" class="onboard-password-form">
								<label class="onboard-field">
									<span>New password</span>
									<input type="password" name="password" id="pwField" required minlength="10" autocomplete="new-password" placeholder="At least 10 characters" />
								</label>
								<label class="onboard-field">
									<span>Confirm password</span>
									<input type="password" name="confirm" id="pwConfirm" required minlength="10" autocomplete="new-password" placeholder="Repeat your password" />
								</label>
								<p id="pwError" class="onboard-pw-error hidden" role="alert"></p>
								<button type="submit" class="onboard-submit" id="pwBtn">
									Complete setup
									<svg viewBox="0 0 16 16" fill="none" class="h-4 w-4 shrink-0" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
								</button>
							</form>
						</div>
					)}

				</div>
			</div>
		</div>

		<style>
			*, *::before, *::after { box-sizing: border-box; }
			.onboard-body { min-height: 100dvh; background: rgb(250 250 250); margin: 0; }

			.onboard-layout {
				display: grid;
				grid-template-columns: 1fr;
				min-height: 100dvh;
			}
			@media (min-width: 900px) {
				.onboard-layout { grid-template-columns: 1fr 1fr; }
			}

			/* Left panel */
			.onboard-panel--left {
				display: none;
				background: #0a0a0a;
				position: relative;
				overflow: hidden;
			}
			.onboard-panel--left::before {
				content: "";
				position: absolute;
				inset: 0;
				background: radial-gradient(ellipse at 80% 20%, rgb(53 90 122 / 0.55) 0%, transparent 65%);
			}
			@media (min-width: 900px) {
				.onboard-panel--left { display: flex; align-items: stretch; }
			}
			.onboard-panel__inner {
				position: relative;
				z-index: 1;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				width: 100%;
				padding: 3rem 3.5rem;
			}
			.onboard-logo { margin-top: 2.5rem; display: block; }

			/* Step vis */
			.onboard-steps-vis {
				flex: 1;
				display: flex;
				flex-direction: column;
				justify-content: center;
				gap: 0;
				padding: 3rem 0;
			}
			.onboard-step-vis {
				display: flex;
				align-items: flex-start;
				gap: 1rem;
				padding: 1.25rem 0;
			}
			.onboard-step-vis__num {
				width: 2rem;
				height: 2rem;
				border-radius: 999px;
				border: 1.5px solid rgb(255 255 255 / 0.2);
				display: flex;
				align-items: center;
				justify-content: center;
				font-family: "Oswald", sans-serif;
				font-size: 0.8125rem;
				font-weight: 500;
				color: rgb(255 255 255 / 0.4);
				flex-shrink: 0;
				transition: all 0.3s ease;
			}
			.onboard-step-vis.is-active .onboard-step-vis__num {
				border-color: #fff;
				color: #fff;
				background: rgb(255 255 255 / 0.1);
			}
			.onboard-step-vis.is-done .onboard-step-vis__num {
				border-color: rgb(134 239 172);
				color: rgb(134 239 172);
			}
			.onboard-step-vis > div {
				display: flex;
				flex-direction: column;
				gap: 0.2rem;
				padding-top: 0.1rem;
			}
			.onboard-step-vis > div strong {
				font-family: "Oswald", sans-serif;
				font-size: 0.875rem;
				font-weight: 500;
				letter-spacing: 0.04em;
				text-transform: uppercase;
				color: rgb(255 255 255 / 0.4);
			}
			.onboard-step-vis.is-active > div strong { color: #fff; }
			.onboard-step-vis.is-done > div strong { color: rgb(134 239 172 / 0.8); }
			.onboard-step-vis > div span {
				font-size: 0.8125rem;
				color: rgb(255 255 255 / 0.3);
			}
			.onboard-step-vis__line {
				width: 1.5px;
				height: 1.5rem;
				background: rgb(255 255 255 / 0.1);
				margin-left: 0.9375rem;
			}
			.onboard-panel__legal {
				margin: 0;
				font-size: 0.8125rem;
				color: rgb(255 255 255 / 0.35);
			}
			.onboard-panel__legal strong { color: rgb(255 255 255 / 0.6); }

			/* Right panel */
			.onboard-panel--right {
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 2rem 1.5rem;
			}
			.onboard-form-wrap { width: 100%; max-width: 26rem; }

			/* Badge */
			.onboard-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.35rem 0.875rem;
				border-radius: 999px;
				background: rgb(241 245 249);
				font-family: "Oswald", sans-serif;
				font-size: 0.6875rem;
				font-weight: 500;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: rgb(100 116 139);
				margin-bottom: 0.875rem;
			}
			.onboard-badge--success {
				background: rgb(240 253 244);
				color: rgb(21 128 61);
			}

			/* Title */
			.onboard-title {
				margin: 0 0 0.5rem;
				font-family: "Oswald", sans-serif;
				font-size: 1.625rem;
				font-weight: 500;
				letter-spacing: 0.04em;
				text-transform: uppercase;
				color: #0a0a0a;
			}
			.onboard-body {
				margin: 0 0 1.25rem;
				font-size: 0.9375rem;
				color: rgb(82 82 91);
				line-height: 1.6;
			}

			/* Connect row */
			.onboard-connect-row {
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}
			.onboard-connected {
				display: flex;
				align-items: center;
				gap: 1rem;
				padding: 1rem 1.125rem;
				border: 1px solid rgb(187 247 208);
				border-radius: 1rem;
				background: rgb(240 253 244);
			}
			.onboard-connected__icon {
				width: 2.5rem;
				height: 2.5rem;
				border-radius: 0.625rem;
				display: flex;
				align-items: center;
				justify-content: center;
				flex-shrink: 0;
			}
			.onboard-connected__icon--steam { background: #1b2838; color: #fff; }
			.onboard-connected__icon--discord { background: #5865f2; color: #fff; }
			.onboard-connected > div {
				display: flex;
				flex-direction: column;
				gap: 0.2rem;
				flex: 1;
			}
			.onboard-connected > div strong {
				font-family: "Oswald", sans-serif;
				font-size: 0.9375rem;
				font-weight: 500;
				letter-spacing: 0.03em;
				text-transform: uppercase;
				color: rgb(21 128 61);
			}
			.onboard-connected > div span {
				font-size: 0.8125rem;
				color: rgb(74 222 128);
			}

			.onboard-provider-btn {
				display: flex;
				align-items: center;
				gap: 1rem;
				padding: 1rem 1.125rem;
				border: 1px solid rgb(228 228 231);
				border-radius: 1rem;
				background: #fff;
				text-decoration: none;
				transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
			}
			.onboard-provider-btn:hover {
				border-color: rgb(161 161 170);
				box-shadow: 0 6px 20px rgb(0 0 0 / 0.07);
				transform: translateY(-1px);
			}
			.onboard-provider-btn__icon {
				width: 2.5rem;
				height: 2.5rem;
				border-radius: 0.625rem;
				display: flex;
				align-items: center;
				justify-content: center;
				flex-shrink: 0;
			}
			.onboard-provider-btn__icon--steam { background: #1b2838; color: #fff; }
			.onboard-provider-btn__icon--discord { background: #5865f2; color: #fff; }
			.onboard-provider-btn__content {
				display: flex;
				flex-direction: column;
				gap: 0.2rem;
				flex: 1;
			}
			.onboard-provider-btn__content strong {
				font-family: "Oswald", sans-serif;
				font-size: 0.9375rem;
				font-weight: 500;
				letter-spacing: 0.03em;
				text-transform: uppercase;
				color: #0a0a0a;
			}
			.onboard-provider-btn__content span { font-size: 0.8125rem; color: rgb(113 113 122); }

			/* Warning */
			.onboard-warning {
				display: flex;
				align-items: flex-start;
				gap: 0.625rem;
				padding: 0.875rem 1rem;
				border: 1px solid rgb(254 215 170);
				border-radius: 0.75rem;
				background: rgb(255 247 237);
				font-size: 0.875rem;
				color: rgb(154 52 18);
				line-height: 1.5;
				margin-bottom: 1.75rem;
			}

			/* Password form */
			.onboard-password-form { display: flex; flex-direction: column; gap: 1rem; }
			.onboard-field {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
				font-size: 0.875rem;
				font-weight: 600;
				color: #0a0a0a;
			}
			.onboard-field input {
				padding: 0.75rem 1rem;
				border: 1px solid rgb(228 228 231);
				border-radius: 0.75rem;
				background: #fff;
				font-family: inherit;
				font-size: 0.9375rem;
				color: #0a0a0a;
				outline: none;
				transition: border-color 0.2s ease, box-shadow 0.2s ease;
			}
			.onboard-field input:focus {
				border-color: #0a0a0a;
				box-shadow: 0 0 0 3px rgb(10 10 10 / 0.08);
			}
			.onboard-pw-error {
				padding: 0.75rem 1rem;
				border: 1px solid rgb(254 202 202);
				border-radius: 0.75rem;
				background: rgb(254 242 242);
				font-size: 0.875rem;
				color: rgb(185 28 28);
			}
			.onboard-pw-error.hidden { display: none; }
			.onboard-submit {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.5rem;
				padding: 0.875rem 1.5rem;
				border: none;
				border-radius: 0.75rem;
				background: #0a0a0a;
				font-family: "Oswald", sans-serif;
				font-size: 0.875rem;
				font-weight: 500;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: #fff;
				cursor: pointer;
				transition: opacity 0.2s ease, transform 0.15s ease;
				margin-top: 0.5rem;
			}
			.onboard-submit:hover { opacity: 0.85; transform: translateY(-1px); }
			.onboard-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
		</style>

		<script>
			const form = document.getElementById("passwordForm") as HTMLFormElement | null;
			const errEl = document.getElementById("pwError");
			const btn = document.getElementById("pwBtn") as HTMLButtonElement | null;

			form?.addEventListener("submit", async (e) => {
				e.preventDefault();
				if (!errEl || !btn) return;
				errEl.classList.add("hidden");
				btn.disabled = true;
				btn.textContent = "Setting up...";

				const fd = new FormData(form);
				const res = await fetch("/api/account/set-password", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ password: fd.get("password"), confirm: fd.get("confirm") }),
				});
				const data = await res.json();

				if (!res.ok) {
					errEl.textContent = data.error ?? "Something went wrong.";
					errEl.classList.remove("hidden");
					btn.disabled = false;
					btn.innerHTML = 'Complete setup <svg viewBox="0 0 16 16" fill="none" style="width:1rem;height:1rem;" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
					return;
				}

				window.location.href = "/account";
			});
		</script>
	</body>
</html>

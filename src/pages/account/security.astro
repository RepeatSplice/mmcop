---
import AccountLayout from "../../layouts/AccountLayout.astro";
import { prisma } from "../../lib/prisma";

export const prerender = false;

const customer = Astro.locals.customer!;

const connectedAccounts = await prisma.connectedAccount.findMany({
	where: { customerId: customer.id },
	orderBy: { provider: "asc" },
});
---

<AccountLayout title="Security | Monarch Account" tab="security" customer={customer}>

	<div class="acct-page-header">
		<div>
			<h1 class="acct-page-header__title">Security</h1>
			<p class="acct-page-header__sub">Manage your password, two-factor authentication, and connected platforms.</p>
		</div>
	</div>

	<!-- Password -->
	<div class="acct-section">
		<div class="acct-section__header">
			<h2 class="acct-section__title">
				<svg viewBox="0 0 16 16" fill="none" class="h-4 w-4" aria-hidden="true"><rect x="4" y="7" width="8" height="7" rx="1.5" stroke="currentColor" stroke-width="1.25"/><path d="M5.5 7V5a2.5 2.5 0 0 1 5 0v2" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
				Site password
			</h2>
		</div>
		<div class="acct-security-card">
			{customer.passwordHash ? (
				<p class="acct-security-card__desc">Your account has a site password set. You can change it below.</p>
			) : (
				<p class="acct-security-card__desc">No site password set. Add one for extra account security.</p>
			)}

			<div class="acct-warning">
				<svg viewBox="0 0 16 16" fill="none" class="h-4 w-4 shrink-0" aria-hidden="true"><path d="M8 2L2 13h12L8 2z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/><path d="M8 7v3M8 12h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
				<span>Do not reuse your Steam or Discord password. Use something unique to this account.</span>
			</div>

			<form id="pwForm" class="acct-form">
				{customer.passwordHash && (
					<label class="acct-field">
						<span>Current password</span>
						<input type="password" name="current" required autocomplete="current-password" />
					</label>
				)}
				<label class="acct-field">
					<span>New password</span>
					<input type="password" name="password" required minlength="10" autocomplete="new-password" placeholder="At least 10 characters" />
				</label>
				<label class="acct-field">
					<span>Confirm new password</span>
					<input type="password" name="confirm" required minlength="10" autocomplete="new-password" />
				</label>
				<p id="pwError" class="acct-form__error hidden" role="alert"></p>
				<p id="pwSuccess" class="acct-form__success hidden" role="status">Password updated.</p>
				<button type="submit" class="acct-submit" id="pwBtn">
					{customer.passwordHash ? "Update password" : "Set password"}
				</button>
			</form>
		</div>
	</div>

	<!-- 2FA -->
	<div class="acct-section">
		<div class="acct-section__header">
			<h2 class="acct-section__title">
				<svg viewBox="0 0 16 16" fill="none" class="h-4 w-4" aria-hidden="true"><path d="M8 2l5 2v4c0 2.8-2 5.4-5 6.5C5 13.4 3 10.8 3 8V4l5-2z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/></svg>
				Two-factor authentication
			</h2>
			<span class={`acct-badge ${customer.totpEnabled ? "acct-badge--green" : "acct-badge--zinc"}`}>
				{customer.totpEnabled ? "Enabled" : "Disabled"}
			</span>
		</div>
		<div class="acct-security-card">
			{customer.totpEnabled ? (
				<div>
					<p class="acct-security-card__desc">2FA is active. Your account requires a code from your authenticator app on each login.</p>
					<form method="post" action="/api/account/disable-2fa" id="disable2faForm">
						<p id="twoFaError" class="acct-form__error hidden" role="alert"></p>
						<label class="acct-field">
							<span>Enter your current 2FA code to disable</span>
							<input type="text" name="code" required inputmode="numeric" pattern="[0-9 ]{6,7}" autocomplete="one-time-code" placeholder="000 000" style="letter-spacing:0.2em;max-width:12rem;" />
						</label>
						<button type="submit" class="acct-submit acct-submit--danger" id="disable2faBtn">
							Disable 2FA
						</button>
					</form>
				</div>
			) : (
				<div>
					<p class="acct-security-card__desc">Add an extra layer of security using an authenticator app (Google Authenticator, Authy, etc.).</p>
					<a href="/account/setup-2fa" class="acct-submit">Set up 2FA</a>
				</div>
			)}
		</div>
	</div>

	<!-- Connected accounts -->
	<div class="acct-section">
		<div class="acct-section__header">
			<h2 class="acct-section__title">
				<svg viewBox="0 0 16 16" fill="none" class="h-4 w-4" aria-hidden="true"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.25"/><path d="M8 5v3l2 1" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
				Connected accounts
			</h2>
		</div>
		<div class="acct-connected-list">
			{["steam", "discord"].map((provider) => {
				const acc = connectedAccounts.find((a) => a.provider === provider);
				return (
					<div class="acct-connected-row">
						<span class={`acct-connected-icon acct-connected-icon--${provider}`}>
							{provider === "steam" ? (
								<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
							) : (
								<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
							)}
						</span>
						<div class="acct-connected-row__info">
							<strong>{provider === "steam" ? "Steam" : "Discord"}</strong>
							{acc ? <span>{acc.username}</span> : <span class="acct-connected-row__none">Not connected</span>}
						</div>
						{acc ? (
							<span class="acct-badge acct-badge--green">Connected</span>
						) : (
							<a href={`/api/auth/${provider}/redirect`} class="acct-btn acct-btn--sm">Connect</a>
						)}
					</div>
				);
			})}
		</div>
	</div>

</AccountLayout>

<style>
	.acct-page-header { margin-bottom: 2rem; }
	.acct-page-header__title {
		margin: 0 0 0.375rem;
		font-family: "Oswald", sans-serif; font-size: 1.625rem; font-weight: 500;
		letter-spacing: 0.03em; text-transform: uppercase; color: #0a0a0a;
	}
	.acct-page-header__sub { margin: 0; font-size: 0.9375rem; color: rgb(113 113 122); }

	.acct-section { margin-bottom: 2rem; }
	.acct-section__header {
		display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
		margin-bottom: 0.875rem;
	}
	.acct-section__title {
		margin: 0; display: flex; align-items: center; gap: 0.625rem;
		font-family: "Oswald", sans-serif; font-size: 0.9375rem; font-weight: 500;
		letter-spacing: 0.08em; text-transform: uppercase; color: #0a0a0a;
	}

	.acct-security-card {
		background: #fff; border-radius: 1.125rem; border: 1px solid rgb(228 228 231);
		padding: 1.5rem;
	}
	.acct-security-card__desc { margin: 0 0 1.25rem; font-size: 0.9375rem; color: rgb(82 82 91); line-height: 1.6; }

	.acct-warning {
		display: flex; align-items: flex-start; gap: 0.625rem;
		padding: 0.875rem 1rem; border: 1px solid rgb(254 215 170);
		border-radius: 0.75rem; background: rgb(255 247 237);
		font-size: 0.875rem; color: rgb(154 52 18); line-height: 1.5; margin-bottom: 1.5rem;
	}

	.acct-form { display: flex; flex-direction: column; gap: 1rem; max-width: 26rem; }
	.acct-field { display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.875rem; font-weight: 600; color: #0a0a0a; }
	.acct-field input {
		padding: 0.75rem 1rem; border: 1px solid rgb(228 228 231); border-radius: 0.75rem;
		background: #fff; font-family: inherit; font-size: 0.9375rem; color: #0a0a0a; outline: none;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}
	.acct-field input:focus { border-color: #0a0a0a; box-shadow: 0 0 0 3px rgb(10 10 10 / 0.08); }
	.acct-form__error {
		padding: 0.75rem 1rem; border: 1px solid rgb(254 202 202); border-radius: 0.75rem;
		background: rgb(254 242 242); font-size: 0.875rem; color: rgb(185 28 28);
	}
	.acct-form__success {
		padding: 0.75rem 1rem; border: 1px solid rgb(187 247 208); border-radius: 0.75rem;
		background: rgb(240 253 244); font-size: 0.875rem; color: rgb(21 128 61);
	}
	.acct-form__error.hidden, .acct-form__success.hidden { display: none; }

	.acct-submit {
		display: inline-flex; align-items: center; justify-content: center;
		padding: 0.75rem 1.5rem; border: none; border-radius: 0.75rem; background: #0a0a0a;
		font-family: "Oswald", sans-serif; font-size: 0.8125rem; font-weight: 500;
		letter-spacing: 0.1em; text-transform: uppercase; color: #fff;
		cursor: pointer; text-decoration: none;
		transition: opacity 0.2s ease; align-self: flex-start;
	}
	.acct-submit:hover { opacity: 0.8; }
	.acct-submit--danger { background: rgb(185 28 28); }

	/* Badges */
	.acct-badge {
		display: inline-flex; align-items: center; padding: 0.2rem 0.625rem;
		border-radius: 999px; font-family: "Oswald", sans-serif;
		font-size: 0.625rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
	}
	.acct-badge--green { background: rgb(220 252 231); color: rgb(21 128 61); }
	.acct-badge--zinc { background: rgb(244 244 245); color: rgb(82 82 91); }

	/* Buttons */
	.acct-btn {
		display: inline-flex; align-items: center; justify-content: center;
		padding: 0.5rem 1rem; border-radius: 0.625rem;
		border: 1px solid rgb(228 228 231); background: #fff;
		font-family: "Oswald", sans-serif; font-size: 0.6875rem; font-weight: 500;
		letter-spacing: 0.1em; text-transform: uppercase; color: #0a0a0a; text-decoration: none;
		transition: background-color 0.15s ease, border-color 0.15s ease;
	}
	.acct-btn:hover { background: rgb(244 244 245); border-color: rgb(161 161 170); }
	.acct-btn--sm { padding: 0.375rem 0.75rem; }

	/* Connected accounts list */
	.acct-connected-list {
		background: #fff; border-radius: 1.125rem; border: 1px solid rgb(228 228 231);
		overflow: hidden;
	}
	.acct-connected-row {
		display: flex; align-items: center; gap: 1rem;
		padding: 1rem 1.25rem; border-bottom: 1px solid rgb(244 244 245);
	}
	.acct-connected-row:last-child { border-bottom: none; }
	.acct-connected-icon {
		width: 2.25rem; height: 2.25rem; border-radius: 0.625rem;
		display: flex; align-items: center; justify-content: center; flex-shrink: 0;
	}
	.acct-connected-icon--steam { background: #1b2838; color: #fff; }
	.acct-connected-icon--discord { background: #5865f2; color: #fff; }
	.acct-connected-row__info {
		flex: 1; display: flex; flex-direction: column; gap: 0.125rem; min-width: 0;
	}
	.acct-connected-row__info strong {
		font-family: "Oswald", sans-serif; font-size: 0.875rem; font-weight: 500;
		letter-spacing: 0.04em; text-transform: uppercase; color: #0a0a0a;
	}
	.acct-connected-row__info span { font-size: 0.8125rem; color: rgb(113 113 122); }
	.acct-connected-row__none { color: rgb(212 212 216) !important; font-style: italic; }
</style>

<script>
	// Password change form
	const pwForm = document.getElementById("pwForm") as HTMLFormElement | null;
	const pwError = document.getElementById("pwError");
	const pwSuccess = document.getElementById("pwSuccess");
	const pwBtn = document.getElementById("pwBtn") as HTMLButtonElement | null;

	pwForm?.addEventListener("submit", async (e) => {
		e.preventDefault();
		if (!pwError || !pwSuccess || !pwBtn) return;
		pwError.classList.add("hidden");
		pwSuccess.classList.add("hidden");
		pwBtn.disabled = true;
		const origLabel = pwBtn.textContent;
		pwBtn.textContent = "Saving...";

		const fd = new FormData(pwForm);
		const res = await fetch("/api/account/change-password", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({
				current: fd.get("current") ?? undefined,
				password: fd.get("password"),
				confirm: fd.get("confirm"),
			}),
		});
		const data = await res.json();

		if (!res.ok) {
			pwError.textContent = data.error ?? "Something went wrong.";
			pwError.classList.remove("hidden");
		} else {
			pwSuccess.classList.remove("hidden");
			pwForm.reset();
		}
		pwBtn.disabled = false;
		pwBtn.textContent = origLabel;
	});
</script>

---
import AccountLayout from "../../layouts/AccountLayout.astro";
import { prisma } from "../../lib/prisma";

export const prerender = false;

const customer = Astro.locals.customer!;

const [orders, activeLicenseCount, connectedAccounts] = await Promise.all([
	prisma.order.findMany({
		where: { customerId: customer.id },
		orderBy: { createdAt: "desc" },
		take: 5,
		include: {
			items: { include: { variant: { include: { product: true } } } },
		},
	}),
	prisma.serverLicense.count({
		where: { customerId: customer.id, status: { in: ["ACTIVE", "GRACE"] } },
	}),
	prisma.connectedAccount.findMany({ where: { customerId: customer.id } }),
]);

const totalOrders = await prisma.order.count({ where: { customerId: customer.id } });

const statusLabel: Record<string, string> = {
	PENDING: "Pending",
	PAID: "Paid",
	REFUNDED: "Refunded",
	DISPUTED: "Disputed",
};
const statusColor: Record<string, string> = {
	PENDING: "acct-badge--yellow",
	PAID: "acct-badge--green",
	REFUNDED: "acct-badge--zinc",
	DISPUTED: "acct-badge--red",
};
---

<AccountLayout title="My Account | Monarch" tab="overview" customer={customer}>

	<!-- Page heading -->
	<div class="acct-page-header">
		<div>
			<h1 class="acct-page-header__title">Welcome back, {customer.displayName.split(" ")[0]}</h1>
			<p class="acct-page-header__sub">Here's what's happening with your account.</p>
		</div>
	</div>

	<!-- Stats -->
	<div class="acct-stats-grid">
		<div class="acct-stat-card">
			<span class="acct-stat-card__value">{totalOrders}</span>
			<span class="acct-stat-card__label">Total orders</span>
		</div>
		<div class="acct-stat-card">
			<span class="acct-stat-card__value">{activeLicenseCount}</span>
			<span class="acct-stat-card__label">Active licenses</span>
		</div>
		<div class="acct-stat-card">
			<span class="acct-stat-card__value">{connectedAccounts.length}</span>
			<span class="acct-stat-card__label">Connected accounts</span>
		</div>
	</div>

	<!-- Recent orders -->
	<div class="acct-section">
		<div class="acct-section__header">
			<h2 class="acct-section__title">Recent orders</h2>
			{totalOrders > 0 && <a href="/account/orders" class="acct-section__more">View all</a>}
		</div>

		{orders.length === 0 ? (
			<div class="acct-empty">
				<svg viewBox="0 0 24 24" fill="none" class="acct-empty__icon" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 9h8M8 13h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
				<p>No orders yet.</p>
				<a href="/shop" class="acct-empty__cta">Browse the shop</a>
			</div>
		) : (
			<div class="acct-card-list">
				{orders.map((order) => (
					<div class="acct-order-row">
						<div class="acct-order-row__info">
							<strong class="acct-order-row__id">Order #{order.id.slice(-8).toUpperCase()}</strong>
							<span class="acct-order-row__meta">
								{order.createdAt.toLocaleDateString("en-GB")} &middot; {order.items.length} item{order.items.length !== 1 ? "s" : ""}
							</span>
							<ul class="acct-order-row__items">
								{order.items.map((item) => (
									<li>{item.variant.product.title} — {item.variant.name}</li>
								))}
							</ul>
						</div>
						<div class="acct-order-row__actions">
							<span class={`acct-badge ${statusColor[order.status]}`}>{statusLabel[order.status]}</span>
							<span class="acct-order-row__price">&pound;{(order.totalMinorUnits / 100).toFixed(2)}</span>
							<a href={`/account/orders/${order.id}`} class="acct-btn acct-btn--sm">View</a>
						</div>
					</div>
				))}
			</div>
		)}
	</div>

	<!-- Connected accounts -->
	<div class="acct-section">
		<div class="acct-section__header">
			<h2 class="acct-section__title">Connected accounts</h2>
			<a href="/account/security" class="acct-section__more">Manage</a>
		</div>
		<div class="acct-connected-grid">
			{connectedAccounts.map((acc) => (
				<div class="acct-connected-card">
					<span class={`acct-connected-card__icon acct-connected-card__icon--${acc.provider}`}>
						{acc.provider === "steam" ? (
							<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
						) : (
							<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
						)}
					</span>
					<div>
						<strong>{acc.provider === "steam" ? "Steam" : "Discord"}</strong>
						<span>{acc.username}</span>
					</div>
					<span class="acct-badge acct-badge--green ml-auto">Connected</span>
				</div>
			))}
		</div>
	</div>

</AccountLayout>

<style>
	.acct-page-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 2rem;
	}
	.acct-page-header__title {
		margin: 0 0 0.375rem;
		font-family: "Oswald", sans-serif;
		font-size: 1.625rem;
		font-weight: 500;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: #0a0a0a;
	}
	.acct-page-header__sub { margin: 0; font-size: 0.9375rem; color: rgb(113 113 122); }

	/* Stats */
	.acct-stats-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
		margin-bottom: 2rem;
	}
	@media (max-width: 600px) {
		.acct-stats-grid { grid-template-columns: 1fr; }
	}
	.acct-stat-card {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
		padding: 1.25rem 1.5rem;
		background: #fff;
		border-radius: 1.125rem;
		border: 1px solid rgb(228 228 231);
	}
	.acct-stat-card__value {
		font-family: "Oswald", sans-serif;
		font-size: 2rem;
		font-weight: 500;
		color: #0a0a0a;
		line-height: 1;
	}
	.acct-stat-card__label { font-size: 0.8125rem; color: rgb(113 113 122); }

	/* Section */
	.acct-section { margin-bottom: 2rem; }
	.acct-section__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 0.875rem;
	}
	.acct-section__title {
		margin: 0;
		font-family: "Oswald", sans-serif;
		font-size: 0.9375rem;
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #0a0a0a;
	}
	.acct-section__more {
		font-family: "Oswald", sans-serif;
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: rgb(113 113 122);
		text-decoration: none;
	}
	.acct-section__more:hover { color: #0a0a0a; }

	/* Card list */
	.acct-card-list {
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
	}
	.acct-order-row {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.125rem 1.375rem;
		background: #fff;
		border-radius: 1rem;
		border: 1px solid rgb(228 228 231);
	}
	@media (max-width: 640px) {
		.acct-order-row { flex-direction: column; }
	}
	.acct-order-row__info { flex: 1; min-width: 0; }
	.acct-order-row__id {
		display: block;
		font-family: "Oswald", sans-serif;
		font-size: 0.9375rem;
		font-weight: 500;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: #0a0a0a;
	}
	.acct-order-row__meta { display: block; font-size: 0.8125rem; color: rgb(161 161 170); margin: 0.25rem 0 0; }
	.acct-order-row__items {
		list-style: none;
		padding: 0;
		margin: 0.375rem 0 0;
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
	}
	.acct-order-row__items li { font-size: 0.8125rem; color: rgb(82 82 91); }
	.acct-order-row__actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-shrink: 0;
	}
	.acct-order-row__price {
		font-family: "Oswald", sans-serif;
		font-size: 0.9375rem;
		font-weight: 500;
		color: #0a0a0a;
	}

	/* Badges */
	.acct-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.2rem 0.625rem;
		border-radius: 999px;
		font-family: "Oswald", sans-serif;
		font-size: 0.625rem;
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.acct-badge--green { background: rgb(220 252 231); color: rgb(21 128 61); }
	.acct-badge--yellow { background: rgb(254 249 195); color: rgb(133 77 14); }
	.acct-badge--zinc { background: rgb(244 244 245); color: rgb(82 82 91); }
	.acct-badge--red { background: rgb(254 226 226); color: rgb(185 28 28); }

	/* Buttons */
	.acct-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.5rem 1rem;
		border-radius: 0.625rem;
		border: 1px solid rgb(228 228 231);
		background: #fff;
		font-family: "Oswald", sans-serif;
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #0a0a0a;
		text-decoration: none;
		transition: background-color 0.15s ease, border-color 0.15s ease;
	}
	.acct-btn:hover { background: rgb(244 244 245); border-color: rgb(161 161 170); }
	.acct-btn--sm { padding: 0.375rem 0.75rem; }

	/* Connected accounts */
	.acct-connected-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
		gap: 0.75rem;
	}
	.acct-connected-card {
		display: flex;
		align-items: center;
		gap: 0.875rem;
		padding: 1rem 1.125rem;
		background: #fff;
		border-radius: 1rem;
		border: 1px solid rgb(228 228 231);
	}
	.acct-connected-card__icon {
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 0.625rem;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.acct-connected-card__icon--steam { background: #1b2838; color: #fff; }
	.acct-connected-card__icon--discord { background: #5865f2; color: #fff; }
	.acct-connected-card > div {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
		flex: 1;
		min-width: 0;
	}
	.acct-connected-card > div strong {
		font-family: "Oswald", sans-serif;
		font-size: 0.875rem;
		font-weight: 500;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: #0a0a0a;
	}
	.acct-connected-card > div span {
		font-size: 0.8125rem;
		color: rgb(113 113 122);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	/* Empty state */
	.acct-empty {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 3rem 2rem;
		background: #fff;
		border-radius: 1.125rem;
		border: 1px dashed rgb(212 212 216);
		text-align: center;
	}
	.acct-empty__icon { width: 2.5rem; height: 2.5rem; color: rgb(212 212 216); }
	.acct-empty p { margin: 0; font-size: 0.9375rem; color: rgb(113 113 122); }
	.acct-empty__cta {
		font-family: "Oswald", sans-serif;
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #0a0a0a;
		text-decoration: none;
		padding: 0.5rem 1.25rem;
		border: 1px solid #0a0a0a;
		border-radius: 0.625rem;
		transition: background-color 0.15s ease, color 0.15s ease;
	}
	.acct-empty__cta:hover { background: #0a0a0a; color: #fff; }
</style>

---
import AccountLayout from "../../layouts/AccountLayout.astro";
import { prisma } from "../../lib/prisma";

export const prerender = false;

const customer = Astro.locals.customer!;

// Handle add/remove server IP actions
if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const action = String(form.get("_action") ?? "");
	const licenseId = String(form.get("licenseId") ?? "");

	if (action === "add-server" && licenseId) {
		const license = await prisma.serverLicense.findUnique({
			where: { id: licenseId },
			include: { servers: true },
		});
		if (license && license.customerId === customer.id && license.status === "ACTIVE") {
			const ipAddress = String(form.get("ipAddress") ?? "").trim();
			const label = String(form.get("label") ?? "").trim() || null;
			const isTestServer = form.get("isTestServer") === "on";
			const realCount = license.servers.filter((s) => !s.isTestServer).length;
			const maxReal = license.maxServers ?? Infinity;
			if (ipAddress && (isTestServer || realCount < maxReal)) {
				await prisma.registeredServer.upsert({
					where: { licenseId_ipAddress: { licenseId, ipAddress } },
					create: { licenseId, ipAddress, label, isTestServer },
					update: { label, isTestServer },
				});
			}
		}
		return Astro.redirect("/account/licenses");
	}

	if (action === "remove-server" && licenseId) {
		const serverId = String(form.get("serverId") ?? "");
		if (serverId) {
			const server = await prisma.registeredServer.findUnique({
				where: { id: serverId },
				include: { license: true },
			});
			if (server && server.license.customerId === customer.id) {
				await prisma.registeredServer.delete({ where: { id: serverId } });
			}
		}
		return Astro.redirect("/account/licenses");
	}
}

const licenses = await prisma.serverLicense.findMany({
	where: { customerId: customer.id },
	include: {
		variant: { include: { product: true } },
		servers: { orderBy: { addedAt: "asc" } },
	},
	orderBy: { createdAt: "desc" },
});

const statusLabel: Record<string, string> = {
	ACTIVE: "Active",
	GRACE: "Grace period",
	REVOKED: "Revoked",
	SUSPENDED: "Suspended",
};
const statusColor: Record<string, string> = {
	ACTIVE: "acct-badge--green",
	GRACE: "acct-badge--yellow",
	REVOKED: "acct-badge--red",
	SUSPENDED: "acct-badge--zinc",
};
---

<AccountLayout title="Licenses | Monarch Account" tab="licenses" customer={customer}>

	<div class="acct-page-header">
		<div>
			<h1 class="acct-page-header__title">Licenses</h1>
			<p class="acct-page-header__sub">Manage server IP registrations for your active mod licenses.</p>
		</div>
	</div>

	{licenses.length === 0 ? (
		<div class="acct-empty">
			<svg viewBox="0 0 24 24" fill="none" class="acct-empty__icon" aria-hidden="true"><path d="M12 3l7 3v5c0 4-2.8 7.7-7 9-4.2-1.3-7-5-7-9V6l7-3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
			<p>No licenses yet.</p>
			<a href="/shop" class="acct-empty__cta">Browse the shop</a>
		</div>
	) : (
		<div class="acct-license-list">
			{licenses.map((license) => {
				const realServerCount = license.servers.filter((s) => !s.isTestServer).length;
				const canAddReal = license.maxServers === null || realServerCount < license.maxServers;
				const isActive = license.status === "ACTIVE";

				return (
					<div class="acct-license-card">
						<div class="acct-license-card__header">
							<div class="acct-license-card__title-row">
								<div>
									<strong class="acct-license-card__name">{license.variant.product.title}</strong>
									<span class="acct-license-card__tier">{license.variant.name}</span>
								</div>
								<div class="acct-license-card__header-right">
									<span class={`acct-badge ${statusColor[license.status]}`}>{statusLabel[license.status]}</span>
									{license.maxServers !== null && (
										<span class="acct-license-card__usage">{realServerCount}/{license.maxServers} servers</span>
									)}
								</div>
							</div>
						</div>

						{/* Server IPs */}
						{license.servers.length > 0 && (
							<div class="acct-license-card__servers">
								{license.servers.map((server) => (
									<div class="acct-server-row">
										<span class="acct-server-row__ip">{server.ipAddress}</span>
										{server.label && <span class="acct-server-row__label">{server.label}</span>}
										{server.isTestServer && <span class="acct-badge acct-badge--zinc">Test</span>}
										{isActive && (
											<form method="post" class="acct-server-row__remove">
												<input type="hidden" name="_action" value="remove-server" />
												<input type="hidden" name="licenseId" value={license.id} />
												<input type="hidden" name="serverId" value={server.id} />
												<button type="submit" class="acct-server-row__remove-btn" onclick="return confirm('Remove this server IP?')">
													<svg viewBox="0 0 16 16" fill="none" class="h-3.5 w-3.5" aria-hidden="true"><path d="M3 8h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
													Remove
												</button>
											</form>
										)}
									</div>
								))}
							</div>
						)}

						{/* Add server form */}
						{isActive && (canAddReal || license.maxServers === null) && (
							<form method="post" class="acct-add-server">
								<input type="hidden" name="_action" value="add-server" />
								<input type="hidden" name="licenseId" value={license.id} />
								<div class="acct-add-server__fields">
									<label class="acct-field acct-field--inline">
										<span>IP address</span>
										<input type="text" name="ipAddress" required placeholder="e.g. 123.456.78.9" />
									</label>
									<label class="acct-field acct-field--inline">
										<span>Label <span class="acct-field__opt">(optional)</span></span>
										<input type="text" name="label" placeholder="e.g. Main server" />
									</label>
									<label class="acct-field acct-field--check">
										<input type="checkbox" name="isTestServer" />
										<span>Test server</span>
									</label>
									<button type="submit" class="acct-btn acct-btn--primary">
										Add IP
									</button>
								</div>
							</form>
						)}
					</div>
				);
			})}
		</div>
	)}

</AccountLayout>

<style>
	.acct-page-header { margin-bottom: 2rem; }
	.acct-page-header__title {
		margin: 0 0 0.375rem;
		font-family: "Oswald", sans-serif; font-size: 1.625rem; font-weight: 500;
		letter-spacing: 0.03em; text-transform: uppercase; color: #0a0a0a;
	}
	.acct-page-header__sub { margin: 0; font-size: 0.9375rem; color: rgb(113 113 122); }

	.acct-license-list { display: flex; flex-direction: column; gap: 1rem; }

	.acct-license-card {
		background: #fff; border-radius: 1.125rem; border: 1px solid rgb(228 228 231); overflow: hidden;
	}
	.acct-license-card__header {
		padding: 1.25rem 1.5rem; border-bottom: 1px solid rgb(244 244 245);
	}
	.acct-license-card__title-row {
		display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem;
	}
	@media (max-width: 560px) {
		.acct-license-card__title-row { flex-direction: column; }
	}
	.acct-license-card__name {
		display: block; font-family: "Oswald", sans-serif; font-size: 1rem; font-weight: 500;
		letter-spacing: 0.04em; text-transform: uppercase; color: #0a0a0a;
	}
	.acct-license-card__tier { font-size: 0.875rem; color: rgb(113 113 122); }
	.acct-license-card__header-right { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; }
	.acct-license-card__usage { font-size: 0.8125rem; color: rgb(113 113 122); }

	/* Server rows */
	.acct-license-card__servers {
		border-bottom: 1px solid rgb(244 244 245);
	}
	.acct-server-row {
		display: flex; align-items: center; gap: 0.75rem;
		padding: 0.75rem 1.5rem; border-bottom: 1px solid rgb(248 248 250);
	}
	.acct-server-row:last-child { border-bottom: none; }
	.acct-server-row__ip {
		font-family: "ui-monospace", "Cascadia Code", "Source Code Pro", monospace;
		font-size: 0.875rem; color: #0a0a0a; flex-shrink: 0;
	}
	.acct-server-row__label { font-size: 0.8125rem; color: rgb(113 113 122); flex: 1; }
	.acct-server-row__remove { margin-left: auto; }
	.acct-server-row__remove-btn {
		display: inline-flex; align-items: center; gap: 0.25rem;
		padding: 0; border: none; background: none; cursor: pointer;
		font-family: "Oswald", sans-serif; font-size: 0.625rem; font-weight: 500;
		letter-spacing: 0.08em; text-transform: uppercase; color: rgb(185 28 28);
		transition: opacity 0.15s ease;
	}
	.acct-server-row__remove-btn:hover { opacity: 0.7; }

	/* Add server */
	.acct-add-server { padding: 1.125rem 1.5rem; background: rgb(248 248 250); }
	.acct-add-server__fields {
		display: flex; flex-wrap: wrap; align-items: flex-end; gap: 0.75rem;
	}
	.acct-field { display: flex; flex-direction: column; gap: 0.375rem; font-size: 0.8125rem; font-weight: 600; color: #0a0a0a; }
	.acct-field--inline { flex: 1; min-width: 10rem; }
	.acct-field--check { flex-direction: row; align-items: center; gap: 0.5rem; padding-bottom: 0.5rem; font-weight: 400; }
	.acct-field__opt { font-weight: 400; color: rgb(161 161 170); }
	.acct-field input[type="text"] {
		padding: 0.625rem 0.875rem; border: 1px solid rgb(228 228 231); border-radius: 0.625rem;
		background: #fff; font-family: inherit; font-size: 0.875rem; color: #0a0a0a; outline: none;
		transition: border-color 0.2s ease;
	}
	.acct-field input[type="text"]:focus { border-color: #0a0a0a; }
	.acct-field input[type="checkbox"] { width: 1rem; height: 1rem; }

	/* Badges */
	.acct-badge {
		display: inline-flex; align-items: center; padding: 0.2rem 0.625rem;
		border-radius: 999px; font-family: "Oswald", sans-serif;
		font-size: 0.625rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
	}
	.acct-badge--green { background: rgb(220 252 231); color: rgb(21 128 61); }
	.acct-badge--yellow { background: rgb(254 249 195); color: rgb(133 77 14); }
	.acct-badge--zinc { background: rgb(244 244 245); color: rgb(82 82 91); }
	.acct-badge--red { background: rgb(254 226 226); color: rgb(185 28 28); }

	/* Buttons */
	.acct-btn {
		display: inline-flex; align-items: center; justify-content: center;
		padding: 0.625rem 1.25rem; border-radius: 0.625rem;
		border: 1px solid rgb(228 228 231); background: #fff;
		font-family: "Oswald", sans-serif; font-size: 0.6875rem; font-weight: 500;
		letter-spacing: 0.1em; text-transform: uppercase; color: #0a0a0a; text-decoration: none; cursor: pointer;
		transition: background-color 0.15s ease, border-color 0.15s ease;
	}
	.acct-btn:hover { background: rgb(244 244 245); border-color: rgb(161 161 170); }
	.acct-btn--primary { background: #0a0a0a; color: #fff; border-color: #0a0a0a; }
	.acct-btn--primary:hover { background: rgb(39 39 42); border-color: rgb(39 39 42); }

	.acct-empty {
		display: flex; flex-direction: column; align-items: center;
		gap: 0.75rem; padding: 3rem 2rem;
		background: #fff; border-radius: 1.125rem; border: 1px dashed rgb(212 212 216); text-align: center;
	}
	.acct-empty__icon { width: 2.5rem; height: 2.5rem; color: rgb(212 212 216); }
	.acct-empty p { margin: 0; font-size: 0.9375rem; color: rgb(113 113 122); }
	.acct-empty__cta {
		font-family: "Oswald", sans-serif; font-size: 0.75rem; font-weight: 500;
		letter-spacing: 0.1em; text-transform: uppercase; color: #0a0a0a; text-decoration: none;
		padding: 0.5rem 1.25rem; border: 1px solid #0a0a0a; border-radius: 0.625rem;
		transition: background-color 0.15s ease, color 0.15s ease;
	}
	.acct-empty__cta:hover { background: #0a0a0a; color: #fff; }
</style>

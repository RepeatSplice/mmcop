---
import MonarchBasicPage from "../components/MonarchBasicPage.astro";
import MonarchProse from "../components/MonarchProse.astro";
---

<MonarchBasicPage
	title="Monarch Modding | Custom DayZ content"
	description="Monarch Modding creates custom DayZ weapon packs, configs, and workshop releases for server owners."
	eyebrow="Services"
	heading="Monarch Modding"
	lead="Custom DayZ packs, weapon platforms, and workshop content built for real server rulesets and wipe cycles."
	image="/Monarch%20Modding.png"
	cta={{ label: "Visit Monarch Modding", href: "https://monarch-modding.com", external: true }}
>
	<MonarchProse heading="What we do">
		<p>
			Monarch Modding is our content studio for DayZ. We design and ship weapon lines, item packs, and configuration work
			that fits how your community actually plays.
		</p>
		<p>
			From partner collaborations like Vyse to in house releases, every drop is built to install cleanly, balance against your
			economy, and stay maintainable across updates.
		</p>
	</MonarchProse>
</MonarchBasicPage>

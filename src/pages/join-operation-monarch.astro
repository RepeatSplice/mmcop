---
import MonarchBasicPage from "../components/MonarchBasicPage.astro";
import MonarchProse from "../components/MonarchProse.astro";
---

<MonarchBasicPage
	title="Join Operation Monarch | Play DayZ with Monarch"
	description="Join Operation Monarch community servers for events, wipes, and Monarch built DayZ worlds."
	eyebrow="Connect"
	heading="Join Operation Monarch"
	lead="Play on Monarch aligned community servers with events, seasonal play, and content from our modding team."
	image="/Operation%20Monarch%20Logo.png"
	cta={{ label: "Go to play-opm.com", href: "https://play-opm.com", external: true }}
>
	<MonarchProse heading="Players & community">
		<p>
			Operation Monarch is where players meet Monarch work in live environments. Schedules, join links, and event news are
			published on the Operation Monarch website.
		</p>
		<p>
			If you are looking for a community home in DayZ rather than commissioning services, this is the right place to start.
		</p>
	</MonarchProse>
</MonarchBasicPage>

---
import SiteLayout from "../layouts/SiteLayout.astro";

const pillars = [
	{
		title: "Innovation",
		body: "Continuous investment in reels, rods, and systems so anglers get dependable performance session after session.",
	},
	{
		title: "Quality",
		body: "Rigorous design, testing, and manufacturing standards across our fishing division — from entry level to flagship.",
	},
	{
		title: "Partnership",
		body: "We support authorised UK dealers, service centres, and clubs with training, warranty pathways, and clear product information.",
	},
];

const facts = [
	{ label: "Founded", value: "1921" },
	{ label: "Headquarters", value: "Sakai, Japan" },
	{ label: "Markets", value: "150+" },
];

const highlights = [
	{
		title: "UK network",
		body: "Nationwide retail and after-sales coverage so you can buy with confidence and get reels serviced when it matters.",
	},
	{
		title: "Product range",
		body: "Freshwater and saltwater tackle across predator, carp, match, and sea — aligned with how people fish in Britain and Ireland.",
	},
];
---

<SiteLayout
	title="About us — Shimano Fishing United Kingdom"
	description="Shimano Fishing in the UK: who we are, what we stand for, and how we support anglers, retailers, and the sport."
>
	<div slot="pre-main" class="mb-20 w-full">
		<div class="group/banner relative min-h-[240px] overflow-hidden text-white md:min-h-[320px]">
			<div class="absolute inset-0">
				<img
					src="https://images.unsplash.com/photo-1544551763-46a013bb70d5?auto=format&fit=crop&w=2000&q=80"
					alt=""
					width="2000"
					height="800"
					loading="eager"
					class="h-full min-h-[240px] w-full object-cover md:min-h-[320px]"
				/>
			</div>
			<div
				class="pointer-events-none absolute inset-0 bg-[linear-gradient(90deg,rgba(0,0,0,0.6)_0%,rgba(0,0,0,0.25)_50%,rgba(0,0,0,0.15)_100%)]"
				aria-hidden="true"
			>
			</div>
			<div class="relative z-10 mx-auto flex min-h-[240px] max-w-7xl flex-col items-start justify-center gap-3 px-6 py-14 md:min-h-[320px] md:gap-4 md:py-20">
				<p class="m-0 font-display text-[11px] uppercase tracking-[0.2em] text-white/75">Company</p>
				<h1 class="m-0 max-w-[22ch] font-display text-[clamp(1.85rem,5vw,3rem)] font-medium uppercase leading-tight tracking-wide">
					About Shimano Fishing
				</h1>
				<p class="m-0 max-w-3xl text-base leading-relaxed text-white/90 md:text-lg">
					Engineering-led tackle for anglers in the United Kingdom — backed by global R&amp;D and a commitment to the water.
				</p>
				<a
					class="font-display mt-2 inline-flex items-center justify-center border-0 bg-white px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-brand-black transition-colors hover:bg-zinc-100"
					href="#about"
				>
					Read on
				</a>
			</div>
		</div>
	</div>

	<section class="text-center" id="about" aria-labelledby="about-heading">
		<h2 id="about-heading" class="m-0 font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em]">
			Who we are
		</h2>
	</section>

	<div class="w-full max-w-none text-left">
		<p class="m-0 text-base leading-relaxed text-zinc-600">
			Shimano Fishing supports anglers with reels, rods, lines, lures, and accessories backed by decades of manufacturing
			expertise. In the United Kingdom we work with authorised dealers, service centres, and our community to deliver
			products and information you can trust on the bank, boat, or beach.
		</p>
		<p class="mt-5 text-base leading-relaxed text-zinc-600">
			This page is a layout demo aligned with the home experience: same typography, spacing, and content width — so
			navigation between marketing and corporate pages feels consistent.
		</p>
	</div>

	<section class="text-center">
		<h2 class="m-0 font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em]">What we stand for</h2>
	</section>

	<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
		{
			pillars.map((p) => (
				<div class="border border-zinc-200 bg-white p-6 text-left shadow-sm">
					<h3 class="m-0 mb-3 font-display text-sm font-medium uppercase tracking-wide text-brand-black">{p.title}</h3>
					<p class="m-0 text-sm leading-relaxed text-zinc-600">{p.body}</p>
				</div>
			))
		}
	</div>

	<div class="grid gap-6 border border-zinc-200 bg-white p-6 md:grid-cols-2 md:p-8">
		{
			highlights.map((h) => (
				<div class="text-left">
					<h3 class="m-0 mb-2 font-display text-sm font-medium uppercase tracking-wide text-brand-black">{h.title}</h3>
					<p class="m-0 text-sm leading-relaxed text-zinc-600">{h.body}</p>
				</div>
			))
		}
	</div>

	<section class="-mx-6 w-[calc(100%+3rem)] border-y border-zinc-200 bg-zinc-100 px-6 py-14">
		<h2 class="m-0 text-center font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em]">
			At a glance
		</h2>
		<dl class="mt-10 grid w-full grid-cols-1 gap-10 text-center sm:grid-cols-3 sm:gap-8">
			{
				facts.map((f) => (
					<div class="border-b border-zinc-200 pb-8 last:border-b-0 last:pb-0 sm:border-b-0 sm:pb-0">
						<dt class="font-display text-[11px] uppercase tracking-[0.18em] text-zinc-500">{f.label}</dt>
						<dd class="mt-2 font-display text-2xl font-medium uppercase tracking-wide text-brand-black md:text-3xl">{f.value}</dd>
					</div>
				))
			}
		</dl>
	</section>

	<section class="text-center">
		<h2 class="m-0 font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em]">Where to next</h2>
	</section>

	<div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:justify-center">
		<a
			class="font-display inline-flex items-center justify-center border border-zinc-200 bg-white px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-brand-black transition-colors hover:border-zinc-300 hover:bg-zinc-50"
			href="/"
		>
			Back to home
		</a>
		<a
			class="font-display inline-flex items-center justify-center border border-zinc-200 bg-white px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-brand-black transition-colors hover:border-zinc-300 hover:bg-zinc-50"
			href="/team"
		>
			Team
		</a>
		<a
			class="font-display inline-flex items-center justify-center border border-zinc-200 bg-white px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-brand-black transition-colors hover:border-zinc-300 hover:bg-zinc-50"
			href="/governance"
		>
			Governance
		</a>
		<a
			class="font-display inline-flex items-center justify-center border border-zinc-200 bg-white px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-brand-black transition-colors hover:border-zinc-300 hover:bg-zinc-50"
			href="/careers"
		>
			Careers
		</a>
		<a
			class="font-display inline-flex items-center justify-center bg-brand-black px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-white transition-colors hover:bg-zinc-800"
			href="/#news"
		>
			Latest news
		</a>
	</div>

	<section class="-mx-6 w-[calc(100%+3rem)] border-t border-zinc-200 bg-zinc-100" id="contact">
		<div class="grid w-full grid-cols-1 md:grid-cols-2">
			<div class="flex flex-col items-center border-b border-zinc-200 px-4 py-10 md:border-b-0 md:border-r md:border-zinc-200">
				<div class="w-full max-w-[36ch] text-left">
					<h2 class="mb-1.5 font-display font-medium uppercase tracking-wide">Members</h2>
					<span class="mb-3 block font-sans text-[13px] font-normal tracking-normal text-zinc-600">Shimano members</span>
					<p class="mb-5 text-sm leading-normal text-zinc-600">Catalogue requests, event news, and email updates in one place.</p>
					<a
						class="font-display inline-flex w-fit bg-brand-black px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-white transition-colors hover:bg-zinc-800"
						href="#"
					>
						Become a member
					</a>
				</div>
			</div>
			<div class="flex flex-col items-center px-4 py-10">
				<div class="w-full max-w-[36ch] text-left">
					<h2 class="mb-1.5 font-display font-medium uppercase tracking-wide">Dealer</h2>
					<span class="mb-3 block font-sans text-[13px] font-normal tracking-normal text-zinc-600">Store information</span>
					<p class="mb-5 text-sm leading-normal text-zinc-600">Find authorised retailers and service centres near you.</p>
					<a
						class="font-display inline-flex w-fit bg-brand-black px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-white transition-colors hover:bg-zinc-800"
						href="#"
					>
						Search for dealers
					</a>
				</div>
			</div>
		</div>
	</section>

	<script>
		import { initHome } from "../scripts/home.ts";
		initHome();
	</script>
</SiteLayout>

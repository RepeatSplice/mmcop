---
import SiteLayout from "../layouts/SiteLayout.astro";

const principles = [
	{
		title: "Integrity",
		body: "We deal fairly with customers, dealers, colleagues, and suppliers — and we keep accurate records that stand up to audit.",
	},
	{
		title: "Compliance",
		body: "UK and EU rules on competition, data protection, product safety, and employment guide how we operate day to day.",
	},
	{
		title: "Speak up",
		body: "Concerns about misconduct can be raised through line managers, HR, or confidential channels provided by your organisation.",
	},
];

const documents = [
	{ title: "Code of conduct — UK fishing division (PDF)", href: "#" },
	{ title: "Anti-bribery & hospitality policy (PDF)", href: "#" },
	{ title: "Modern slavery statement (PDF)", href: "#" },
	{ title: "Privacy & data protection notice — employees & contractors (PDF)", href: "#" },
];
---

<SiteLayout
	title="Governance & ethics — Shimano Fishing United Kingdom"
	description="Corporate governance, business ethics, and key policies for Shimano Fishing in the UK. Demo layout for regional compliance pages."
>
	<div slot="pre-main" class="mb-20 w-full">
		<div class="group/banner relative min-h-[240px] overflow-hidden text-white md:min-h-[300px]">
			<div class="absolute inset-0">
				<img
					src="https://images.unsplash.com/photo-1589829085413-56de8ae18c73?auto=format&fit=crop&w=2000&q=80"
					alt=""
					width="2000"
					height="800"
					loading="eager"
					class="h-full min-h-[240px] w-full object-cover md:min-h-[300px]"
				/>
			</div>
			<div
				class="pointer-events-none absolute inset-0 bg-[linear-gradient(90deg,rgba(0,0,0,0.65)_0%,rgba(0,0,0,0.3)_55%,rgba(0,0,0,0.15)_100%)]"
				aria-hidden="true"
			>
			</div>
			<div class="relative z-10 mx-auto flex min-h-[240px] max-w-7xl flex-col items-start justify-center gap-3 px-6 py-14 md:min-h-[300px] md:gap-4 md:py-16">
				<p class="m-0 font-display text-[11px] uppercase tracking-[0.2em] text-white/75">Company</p>
				<h1 class="m-0 max-w-[22ch] font-display text-[clamp(1.85rem,5vw,3rem)] font-medium uppercase leading-tight tracking-wide">
					Governance &amp; ethics
				</h1>
				<p class="m-0 max-w-3xl text-base leading-relaxed text-white/90 md:text-lg">
					How we oversee the UK fishing business, meet regulatory expectations, and set clear standards for everyone who
					represents Shimano.
				</p>
				<a
					class="font-display mt-2 inline-flex items-center justify-center border-0 bg-white px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-brand-black transition-colors hover:bg-zinc-100"
					href="#oversight"
				>
					Read the overview
				</a>
			</div>
		</div>
	</div>

	<section class="text-center" id="oversight" aria-labelledby="oversight-heading">
		<h2 id="oversight-heading" class="m-0 font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em]">
			Corporate governance
		</h2>
	</section>

	<div class="w-full max-w-none text-left">
		<p class="m-0 text-base leading-relaxed text-zinc-600">
			Shimano Inc. sets group-level governance, reporting, and risk management. In the United Kingdom and Ireland, regional
			leadership is accountable for executing those standards in sales, marketing, technical service, and operations — with
			transparent escalation to European and global functions where required.
		</p>
		<p class="mt-5 text-base leading-relaxed text-zinc-600">
			This page is a <strong class="font-semibold text-brand-black">layout and content placeholder</strong>. Replace every
			paragraph, policy link, and process description with wording approved by your legal, compliance, and HR teams before
			publication.
		</p>
	</div>

	<ul class="m-0 w-full list-none border border-zinc-200 bg-zinc-50 p-0">
		<li class="border-b border-zinc-200 px-[1.1rem] py-4 text-sm leading-relaxed text-zinc-700 last:border-b-0">
			<span class="font-semibold text-brand-black">Accountability:</span> clear ownership for P&amp;L, product compliance, and
			customer-facing commitments in the UK market.
		</li>
		<li class="border-b border-zinc-200 px-[1.1rem] py-4 text-sm leading-relaxed text-zinc-700 last:border-b-0">
			<span class="font-semibold text-brand-black">Controls:</span> segregation of duties, approval limits, and documented
			workflows for pricing, promotions, and dealer programmes (demo copy).
		</li>
		<li class="px-[1.1rem] py-4 text-sm leading-relaxed text-zinc-700">
			<span class="font-semibold text-brand-black">Reporting:</span> periodic reviews of risks — including product integrity,
			cyber security, and third-party relationships — with action tracking (demo copy).
		</li>
	</ul>

	<section class="text-center" id="ethics" aria-labelledby="ethics-heading">
		<h2 id="ethics-heading" class="m-0 font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em]">
			Business ethics
		</h2>
	</section>

	<div class="grid w-full gap-4 sm:grid-cols-2 lg:grid-cols-3">
		{
			principles.map((p) => (
				<div class="border border-zinc-200 bg-white p-6 text-left shadow-sm">
					<h3 class="m-0 mb-3 font-display text-sm font-medium uppercase tracking-wide text-brand-black">{p.title}</h3>
					<p class="m-0 text-sm leading-relaxed text-zinc-600">{p.body}</p>
				</div>
			))
		}
	</div>

	<section class="-mx-6 w-[calc(100%+3rem)] border-y border-zinc-200 bg-zinc-100 px-6 py-14" id="policies" aria-labelledby="policies-heading">
		<h2 id="policies-heading" class="m-0 text-center font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em]">
			Key documents
		</h2>
		<p class="mx-auto mt-4 max-w-none text-center text-sm text-zinc-600">Placeholder downloads — attach real PDFs when approved.</p>

		<ul class="mx-auto mt-8 w-full max-w-none border border-zinc-200 bg-white p-0">
			{
				documents.map((doc) => (
					<li class="border-b border-zinc-200 last:border-b-0">
						<a
							class="flex items-center justify-between gap-4 px-[1.1rem] py-4 text-left text-[15px] font-semibold text-brand-black transition-colors hover:bg-zinc-50 hover:text-shimano-500"
							href={doc.href}
						>
							<span>{doc.title}</span>
							<span class="font-display shrink-0 text-[11px] font-medium uppercase tracking-wide text-zinc-500">Download</span>
						</a>
					</li>
				))
			}
		</ul>
	</section>

	<section class="text-center">
		<h2 class="m-0 font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em]">Raising a concern</h2>
	</section>

	<div class="w-full max-w-none text-left">
		<p class="m-0 text-base leading-relaxed text-zinc-600">
			If you believe a law, regulation, or internal policy may have been broken, report it promptly. Your employer or
			appointed whistleblowing provider should publish the official route — this demo page does not host a live reporting
			form.
		</p>
	</div>

	<section class="text-center">
		<h2 class="m-0 font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em]">Where to next</h2>
	</section>

	<div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:justify-center">
		<a
			class="font-display inline-flex items-center justify-center border border-zinc-200 bg-white px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-brand-black transition-colors hover:border-zinc-300 hover:bg-zinc-50"
			href="/"
		>
			Back to home
		</a>
		<a
			class="font-display inline-flex items-center justify-center border border-zinc-200 bg-white px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-brand-black transition-colors hover:border-zinc-300 hover:bg-zinc-50"
			href="/about"
		>
			About us
		</a>
		<a
			class="font-display inline-flex items-center justify-center border border-zinc-200 bg-white px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-brand-black transition-colors hover:border-zinc-300 hover:bg-zinc-50"
			href="/team"
		>
			Team
		</a>
		<a
			class="font-display inline-flex items-center justify-center bg-brand-black px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-white transition-colors hover:bg-zinc-800"
			href="/careers"
		>
			Careers
		</a>
	</div>

	<section class="-mx-6 w-[calc(100%+3rem)] border-t border-zinc-200 bg-zinc-100" id="contact">
		<div class="grid w-full grid-cols-1 md:grid-cols-2">
			<div class="flex flex-col items-center border-b border-zinc-200 px-4 py-10 md:border-b-0 md:border-r md:border-zinc-200">
				<div class="w-full max-w-[36ch] text-left">
					<h2 class="mb-1.5 font-display font-medium uppercase tracking-wide">Members</h2>
					<span class="mb-3 block font-sans text-[13px] font-normal tracking-normal text-zinc-600">Shimano members</span>
					<p class="mb-5 text-sm leading-normal text-zinc-600">Catalogue requests, event news, and email updates in one place.</p>
					<a
						class="font-display inline-flex w-fit bg-brand-black px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-white transition-colors hover:bg-zinc-800"
						href="#"
					>
						Become a member
					</a>
				</div>
			</div>
			<div class="flex flex-col items-center px-4 py-10">
				<div class="w-full max-w-[36ch] text-left">
					<h2 class="mb-1.5 font-display font-medium uppercase tracking-wide">Dealer</h2>
					<span class="mb-3 block font-sans text-[13px] font-normal tracking-normal text-zinc-600">Store information</span>
					<p class="mb-5 text-sm leading-normal text-zinc-600">Find authorised retailers and service centres near you.</p>
					<a
						class="font-display inline-flex w-fit bg-brand-black px-[1.35rem] py-[0.65rem] text-[13px] uppercase tracking-wide text-white transition-colors hover:bg-zinc-800"
						href="#"
					>
						Search for dealers
					</a>
				</div>
			</div>
		</div>
	</section>

	<script>
		import { initHome } from "../scripts/home.ts";
		initHome();
	</script>
</SiteLayout>

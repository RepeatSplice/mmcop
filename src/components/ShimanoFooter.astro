---
import { Icon } from 'astro-icon/components';

const year = new Date().getFullYear();
---

<footer class="mt-0 w-full max-w-none bg-footer text-sm text-zinc-300">
	<div class="mx-auto max-w-7xl px-6 pb-0 pt-10">
		<div class="border-b border-zinc-700 pb-8 text-center">
			<p class="mb-4 font-display text-xs uppercase tracking-[0.15em] text-zinc-500">Follow us</p>
			<ul class="flex list-none justify-center gap-5 p-0">
				<li>
					<a
						class="group flex size-10 items-center justify-center border border-zinc-700 bg-zinc-800 transition-colors hover:border-zinc-600 hover:bg-zinc-700"
						href="https://www.facebook.com/ShimanoFishingEU/"
						aria-label="Facebook"
					>
						<Icon name="simple-icons:facebook" class="size-[22px] shrink-0 text-zinc-300 transition-colors group-hover:text-white" is:inline aria-hidden="true" />
						<span class="sr-only">Facebook</span>
					</a>
				</li>
				<li>
					<a
						class="group flex size-10 items-center justify-center border border-zinc-700 bg-zinc-800 transition-colors hover:border-zinc-600 hover:bg-zinc-700"
						href="https://www.instagram.com/shimanofishing_eu/"
						aria-label="Instagram"
					>
						<Icon name="simple-icons:instagram" class="size-[22px] shrink-0 text-zinc-300 transition-colors group-hover:text-white" is:inline aria-hidden="true" />
						<span class="sr-only">Instagram</span>
					</a>
				</li>
				<li>
					<a
						class="group flex size-10 items-center justify-center border border-zinc-700 bg-zinc-800 transition-colors hover:border-zinc-600 hover:bg-zinc-700"
						href="https://www.youtube.com/user/FishWithShimanoEU"
						aria-label="YouTube"
					>
						<Icon name="simple-icons:youtube" class="size-[22px] shrink-0 text-zinc-300 transition-colors group-hover:text-white" is:inline aria-hidden="true" />
						<span class="sr-only">YouTube</span>
					</a>
				</li>
			</ul>
		</div>

		<div class="mx-auto grid w-full max-w-none grid-cols-2 gap-x-4 gap-y-6 py-8 md:grid-cols-4">
			<div>
				<h3 class="mb-3 font-display text-xs uppercase tracking-wide text-white">Products</h3>
				<ul class="m-0 list-none p-0">
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="#">Reels</a></li>
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="#">Rods</a></li>
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="#">Lines</a></li>
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="#">Lures</a></li>
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="#">Accessories</a></li>
				</ul>
			</div>
			<div>
				<h3 class="mb-3 font-display text-xs uppercase tracking-wide text-white">About us</h3>
				<ul class="m-0 list-none p-0">
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="/about">About Shimano</a></li>
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="/goals">Goals</a></li>
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="/roadmap">Innovation roadmap</a></li>
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="/governance">Governance &amp; ethics</a></li>
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="/careers">Careers</a></li>
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="/partners">Partners</a></li>
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="#">Catalogues</a></li>
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="#">Distributors</a></li>
				</ul>
			</div>
			<div>
				<h3 class="mb-3 font-display text-xs uppercase tracking-wide text-white">Service</h3>
				<ul class="m-0 list-none p-0">
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="#">Warranty policy</a></li>
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="#">Reel maintenance</a></li>
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="#">Dealer locator</a></li>
				</ul>
			</div>
			<div>
				<h3 class="mb-3 font-display text-xs uppercase tracking-wide text-white">Legal</h3>
				<ul class="m-0 list-none p-0">
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="/privacy-policy">Privacy policy</a></li>
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="/terms-and-conditions">Terms and conditions</a></li>
					<li class="mb-[0.45rem]"><a class="text-zinc-400 transition-colors hover:text-white" href="/legal-info">Legal info</a></li>
				</ul>
			</div>
		</div>

		<div class="flex flex-wrap items-center justify-between gap-4 border-t border-zinc-700 py-5 pb-8 text-[11px] text-zinc-500">
			<a class="text-zinc-500 transition-colors hover:text-white" href="https://www.shimano.com/">Shimano global site</a>
			<span>© {year} Shimano Inc. All rights reserved.</span>
		</div>
	</div>
</footer>

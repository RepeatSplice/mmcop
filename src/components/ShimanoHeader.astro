---
import { Icon } from "astro-icon/components";
import LanguageSwitcher from "./LanguageSwitcher.astro";

const nav = [
	{
		label: "Company",
		href: "/about",
		children: [
			{ label: "About us", href: "/about" },
			{ label: "Governance & ethics", href: "/governance" },
			{ label: "Integrated report", href: "#" },
		],
	},
	{
		label: "Goals",
		href: "/goals",
		children: [
			{ label: "2030 priorities", href: "/goals#priorities" },
			{ label: "Innovation roadmap", href: "/roadmap" },
		],
	},
	{
		label: "Partners",
		href: "/partners",
		children: [
			{ label: "Strategic alliances", href: "/partners#alliances" },
			{ label: "Conservation", href: "/partners#conservation" },
		],
	},
	{ label: "News", href: "/#news", children: [{ label: "Newsroom", href: "/#news" }, { label: "Press kit", href: "#" }] },
	{ label: "Team", href: "/team", children: [
		{ label: "Leadership", href: "/team#leadership" },
		{ label: "Full team", href: "/team#full-team" },
		{ label: "Careers", href: "/careers" },
	] },
	{ label: "Contact", href: "/#contact", children: [{ label: "Media enquiries", href: "/#contact" }, { label: "Investor relations", href: "#" }] },
];
---

<div class="h-9 border-b border-zinc-200 text-[11px] font-semibold tracking-wide">
	<div class="mx-auto flex h-full max-w-7xl items-center justify-end gap-6 px-6 uppercase">
		<a class="text-brand-black transition-colors hover:text-shimano-500" href="#">Investors</a>
		<a class="text-brand-black transition-colors hover:text-shimano-500" href="#">Media</a>
		<a class="text-brand-black transition-colors hover:text-shimano-500" href="#">Contact</a>
		<LanguageSwitcher variant="subheader" />
	</div>
</div>

<header class="sticky top-0 z-50 border-b border-zinc-200 bg-white">
	<div class="mx-auto flex min-h-[4.5rem] max-w-7xl items-center justify-between gap-4 px-6">
		<a class="group/logo shrink-0" href="/" aria-label="Shimano Fishing home">
			<svg class="block h-7 w-auto" viewBox="0 0 140 32" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
				<text
					class="fill-shimano-500 transition-colors group-hover/logo:fill-shimano-600"
					x="0"
					y="24"
					font-family="Oswald, system-ui, sans-serif"
					font-size="26"
					font-weight="500"
					letter-spacing="0.12em">SHIMANO</text>
				<text x="0" y="31" font-family="Noto Sans, system-ui, sans-serif" font-size="7" fill="#333333" letter-spacing="0.18em">FISHING</text>
			</svg>
		</a>

		<nav class="hidden flex-1 items-center justify-center gap-1 lg:flex" aria-label="Primary">
			{
				nav.map((item) => (
					<div class="group/nav relative">
						<a
							class="font-display block px-[0.85rem] py-[0.65rem] text-sm font-medium uppercase tracking-wide text-brand-black transition-colors hover:text-shimano-500 group-focus-within/nav:text-shimano-500"
							href={item.href}
						>
							{item.label}
						</a>
						{item.children.length > 0 && (
							<div
								class="invisible pointer-events-none absolute left-1/2 top-full z-50 min-w-[220px] -translate-x-1/2 translate-y-1 border border-zinc-200 bg-white py-3 opacity-0 shadow-[0_12px_40px_rgba(0,0,0,0.08)] transition-all duration-150 ease-out group-focus-within/nav:visible group-focus-within/nav:translate-y-0 group-focus-within/nav:opacity-100 group-focus-within/nav:pointer-events-auto group-hover/nav:visible group-hover/nav:translate-y-0 group-hover/nav:opacity-100 group-hover/nav:pointer-events-auto"
								role="menu"
							>
								{item.children.map((c) => (
									<a class="block px-5 py-[0.45rem] text-[13px] text-zinc-600 transition-colors hover:bg-zinc-50 hover:text-brand-black" href={c.href} role="menuitem">
										{c.label}
									</a>
								))}
							</div>
						)}
					</div>
				))
			}
		</nav>

		<div class="flex items-center gap-2">
			<div class="hidden min-w-[140px] items-center gap-[0.35rem] border border-zinc-200 px-2 py-[0.35rem] text-xs text-zinc-600 lg:flex" role="search">
				<Icon name="lucide:search" class="size-4 shrink-0 text-zinc-600" is:inline aria-hidden="true" />
				<span>Search</span>
			</div>
			<button
				type="button"
				class="flex h-11 w-11 flex-col items-center justify-center gap-[5px] border-0 bg-transparent p-0 lg:hidden"
				id="drawerBtn"
				aria-expanded="false"
				aria-controls="mobileDrawer"
				aria-label="Open menu"
			>
				<span class="block h-0.5 w-[22px] bg-brand-black transition-[transform,opacity] duration-200 ease-out"></span>
				<span class="block h-0.5 w-[22px] bg-brand-black transition-[transform,opacity] duration-200 ease-out"></span>
				<span class="block h-0.5 w-[22px] bg-brand-black transition-[transform,opacity] duration-200 ease-out"></span>
			</button>
		</div>
	</div>
</header>

<div class="fixed inset-x-0 bottom-0 top-[108px] z-[35] bg-black/35 lg:hidden" id="drawerBackdrop"></div>
<nav
	class="fixed inset-x-0 bottom-0 top-[108px] z-40 overflow-y-auto bg-white px-5 pb-8 pt-4 transition-transform duration-300 ease-out lg:hidden"
	id="mobileDrawer"
	aria-label="Mobile"
>
	<div class="mb-4 border-b border-zinc-200 pb-4">
		<p class="mb-2 font-display text-[11px] uppercase tracking-wide text-zinc-500">Language / region</p>
		<LanguageSwitcher variant="drawer" />
	</div>
	<div>
		{
			nav.map((item) => (
				<div class="mb-2 border-b border-zinc-200 pb-2">
					<a class="font-display block border-b border-zinc-200 py-3 text-[15px] uppercase tracking-wide hover:text-shimano-500" href={item.href}>
						{item.label}
					</a>
					{item.children.map((c) => (
						<a class="block border-b-0 py-2 pl-3 font-sans text-sm tracking-normal hover:text-shimano-500" href={c.href}>
							{c.label}
						</a>
					))}
				</div>
			))
		}
	</div>
</nav>

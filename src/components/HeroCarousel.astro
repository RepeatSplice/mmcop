---
import { Icon } from "astro-icon/components";

export interface HeroSlideCta {
	label: string;
	href: string;
	external?: boolean;
}

export interface Slide {
	src: string;
	alt: string;
	eyebrow?: string;
	title: string;
	lead: string;
	ctas: HeroSlideCta[];
}

export interface Props {
	slides: Slide[];
	delayMs?: number;
}

const { slides, delayMs = 5000 } = Astro.props;
---

<section
	class="hero-carousel relative bg-brand-black text-white"
	aria-roledescription="carousel"
	aria-label="Featured"
	data-hero-carousel
	data-delay={delayMs}
>
	<div class="hero-carousel__stage relative aspect-[21/7] max-h-[72vh] min-h-[240px] overflow-hidden max-md:aspect-video max-md:min-h-[220px]">
		{
			slides.map((slide, i) => (
				<div
					class:list={["hero-slide", { "is-active": i === 0 }]}
					data-hero-slide
					role="group"
					aria-label={`Slide ${i + 1} of ${slides.length}`}
					aria-hidden={i === 0 ? "false" : "true"}
				>
					<div class="hero-slide__media" aria-hidden="true">
						<img
							src={slide.src}
							alt={slide.alt}
							width="1920"
							height="640"
							loading={i === 0 ? "eager" : "lazy"}
							decoding="async"
						/>
					</div>
					<div class="hero-slide__overlay" aria-hidden="true" />
					<div class="hero-slide__content">
						{slide.eyebrow ? (
							<p class="hero-slide__eyebrow">{slide.eyebrow}</p>
						) : null}
						<h2 class="hero-slide__title">{slide.title}</h2>
						<p class="hero-slide__lead">{slide.lead}</p>
						{
							slide.ctas.length > 0 && (
								<div class="hero-slide__actions">
									{slide.ctas.map((cta, ctaIndex) => (
										<a
											class:list={[
												"hero-slide__btn",
												ctaIndex === 0 ? "hero-slide__btn--primary" : "hero-slide__btn--secondary",
											]}
											href={cta.href}
											{...(cta.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
										>
											{cta.label}
											{cta.external ? (
												<Icon name="lucide:arrow-up-right" class="size-3.5 shrink-0 opacity-80" is:inline aria-hidden="true" />
											) : null}
										</a>
									))}
								</div>
							)
						}
					</div>
				</div>
			))
		}
		<button type="button" class="hero-carousel__nav hero-carousel__nav--prev" data-hero-prev aria-label="Previous slide">
			<Icon name="lucide:chevron-left" class="size-5 shrink-0" is:inline aria-hidden="true" />
		</button>
		<button type="button" class="hero-carousel__nav hero-carousel__nav--next" data-hero-next aria-label="Next slide">
			<Icon name="lucide:chevron-right" class="size-5 shrink-0" is:inline aria-hidden="true" />
		</button>
		<div class="hero-carousel__dots" role="tablist" aria-label="Slides">
			{
				slides.map((_, i) => (
					<button
						type="button"
						class:list={["hero-carousel__dot", { "is-active": i === 0 }]}
						data-hero-dot
						role="tab"
						aria-selected={i === 0 ? "true" : "false"}
						aria-label={`Go to slide ${i + 1}`}
					>
					</button>
				))
			}
		</div>
	</div>
</section>

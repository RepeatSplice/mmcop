---
import type { Product, ProductVariant, ProductFile, ProductChangelog } from "@prisma/client";
import ManageBtn from "./ManageBtn.astro";

interface Props {
	product?: Product & {
		variants: ProductVariant[];
		files: ProductFile[];
		changelog: ProductChangelog[];
	};
	action: string;
	r2Enabled?: boolean;
}

const { product, action, r2Enabled = false } = Astro.props;
const isEdit = Boolean(product);

const categoryOptions = [
	{ value: "modding", label: "Modding" },
	{ value: "software", label: "Software" },
	{ value: "hosting", label: "Hosting" },
	{ value: "bundle", label: "Bundle" },
	{ value: "other", label: "Other" },
];

const statusOptions = [
	{ value: "DRAFT", label: "Draft" },
	{ value: "PUBLISHED", label: "Published" },
	{ value: "WAITLIST", label: "Waitlist" },
	{ value: "ARCHIVED", label: "Archived" },
];

// previewImages stored as JSON array — show as one URL per line
const previewImagesText = (() => {
	if (!product?.previewImages) return "";
	try {
		const arr = JSON.parse(product.previewImages as string);
		return Array.isArray(arr) ? arr.join("\n") : "";
	} catch {
		return "";
	}
})();

const formatPrice = (cents: number) => (cents / 100).toFixed(2);

const inputClass =
	"w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm text-brand-black focus:border-brand-black focus:outline-none";
const labelClass = "mb-1 block font-display text-[10px] uppercase tracking-widest text-zinc-500";

const variantStatusClass = (active: boolean) =>
	active ? "bg-emerald-100 text-emerald-800" : "bg-zinc-100 text-zinc-500";

const fileStatusClass = (isLatest: boolean) =>
	isLatest ? "bg-emerald-100 text-emerald-800" : "bg-zinc-100 text-zinc-500";
---

<div class="space-y-6">
	<!-- ── Core product details ─────────────────────────────────────────────── -->
	<section class="overflow-hidden rounded-xl border border-zinc-200 bg-white shadow-sm">
		<div class="border-b border-zinc-100 px-5 py-4">
			<h2 class="m-0 font-display text-xs uppercase tracking-[0.15em] text-zinc-500">Product Details</h2>
		</div>
		<form method="post" action={action} class="space-y-5 p-5">
			<input type="hidden" name="_action" value={isEdit ? "update-product" : "create-product"} />

			<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
				<div>
					<label class={labelClass}>Title <span class="text-red-500">*</span></label>
					<input
						type="text"
						name="title"
						required
						value={product?.title ?? ""}
						class={inputClass}
						placeholder="Monarch Weapon Pack v3"
						id="product-title"
					/>
				</div>
				<div>
					<label class={labelClass}>Slug <span class="text-red-500">*</span></label>
					<input
						type="text"
						name="slug"
						required
						value={product?.slug ?? ""}
						class={`${inputClass} font-mono`}
						placeholder="monarch-weapon-pack-v3"
						id="product-slug"
					/>
				</div>
			</div>

			<div>
				<label class={labelClass}>Excerpt <span class="text-red-500">*</span></label>
				<input
					type="text"
					name="excerpt"
					required
					value={product?.excerpt ?? ""}
					class={inputClass}
					placeholder="One-line shop listing description shown in cards and search"
				/>
			</div>

			<div>
				<label class={labelClass}>
					Body <span class="text-zinc-400 normal-case tracking-normal">(Markdown)</span>
					<span class="text-red-500"> *</span>
				</label>
				<textarea
					name="body"
					required
					rows="14"
					class={`${inputClass} font-mono`}
				>{product?.body ?? ""}</textarea>
			</div>

			<div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
				<div>
					<label class={labelClass}>Category <span class="text-red-500">*</span></label>
					<select name="category" required class={inputClass}>
						{categoryOptions.map((opt) => (
							<option value={opt.value} selected={product?.category === opt.value}>
								{opt.label}
							</option>
						))}
					</select>
				</div>
				<div>
					<label class={labelClass}>Status</label>
					<select name="status" class={inputClass}>
						{statusOptions.map((opt) => (
							<option value={opt.value} selected={product?.status === opt.value}>
								{opt.label}
							</option>
						))}
					</select>
				</div>
				<div>
					<label class={labelClass}>Cover image URL</label>
					<input
						type="url"
						name="imageUrl"
						value={product?.imageUrl ?? ""}
						class={inputClass}
						placeholder="https://..."
					/>
				</div>
			</div>

			<div>
				<label class={labelClass}>
					Preview images
					<span class="ml-1 font-normal normal-case tracking-normal text-zinc-400">(one URL per line)</span>
				</label>
				<textarea
					name="previewImages"
					rows="3"
					class={`${inputClass} font-mono text-xs`}
					placeholder={"https://example.com/image1.jpg\nhttps://example.com/image2.jpg"}
				>{previewImagesText}</textarea>
			</div>

			<div class="flex items-center gap-3 pt-1">
				<ManageBtn type="submit" variant="primary">
					{isEdit ? "Save changes" : "Create product"}
				</ManageBtn>
				{!isEdit && (
					<p class="m-0 text-xs text-zinc-400">
						Variants, files, and changelog are added after creating the product.
					</p>
				)}
			</div>
		</form>
	</section>

	{isEdit && product && (
		<>
			<!-- ── Variants ──────────────────────────────────────────────────────── -->
			<section class="overflow-hidden rounded-xl border border-zinc-200 bg-white shadow-sm">
				<div class="border-b border-zinc-100 px-5 py-4">
					<h2 class="m-0 font-display text-xs uppercase tracking-[0.15em] text-zinc-500">
						Pricing &amp; Variants
					</h2>
				</div>

				{product.variants.length === 0 ? (
					<div class="px-5 py-6 text-center">
						<p class="m-0 text-sm text-zinc-400">No variants yet. Add one below.</p>
					</div>
				) : (
					<ul class="list-none divide-y divide-zinc-100 p-0">
						{product.variants.map((v) => (
							<li>
								<details class="group">
									<summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 hover:bg-zinc-50">
										<div class="flex min-w-0 flex-1 items-center gap-3">
											<svg class="h-3.5 w-3.5 shrink-0 rotate-[-90deg] text-zinc-400 transition-transform group-open:rotate-0" viewBox="0 0 16 16" fill="none" aria-hidden="true">
												<path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
											</svg>
											<div class="min-w-0">
												<p class="m-0 font-semibold text-brand-black">{v.name}</p>
												<p class="m-0 text-xs text-zinc-500">
													$&thinsp;{formatPrice(v.priceUsd)}
													{v.maxServers ? ` &middot; ${v.maxServers} servers` : ""}
													{v.description ? ` &middot; ${v.description}` : ""}
												</p>
											</div>
										</div>
										<div class="flex shrink-0 items-center gap-2">
											{v.stripePriceId && (
												<span class="rounded-full bg-blue-100 px-2 py-0.5 font-mono text-[9px] font-semibold text-blue-700">
													Stripe
												</span>
											)}
											<span class:list={["rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase", variantStatusClass(v.active)]}>
												{v.active ? "Active" : "Inactive"}
											</span>
										</div>
									</summary>

									<!-- Edit form (visible when open) -->
									<div class="border-t border-zinc-100 bg-zinc-50 px-5 py-4">
										<form method="post" action={action} class="grid grid-cols-2 gap-3 sm:grid-cols-4">
											<input type="hidden" name="_action" value="update-variant" />
											<input type="hidden" name="variantId" value={v.id} />
											<div>
												<label class={labelClass}>Name</label>
												<input type="text" name="variantName" value={v.name} required class={inputClass} />
											</div>
											<div>
												<label class={labelClass}>Price ($)</label>
												<input
													type="number"
													name="variantpriceUsd"
													value={formatPrice(v.priceUsd)}
													step="0.01"
													min="0"
													required
													class={inputClass}
												/>
											</div>
											<div>
												<label class={labelClass}>Max servers</label>
												<input
													type="number"
													name="variantMaxServers"
													value={v.maxServers ?? ""}
													min="1"
													class={inputClass}
													placeholder="Unlimited"
												/>
											</div>
											<div>
												<label class={labelClass}>Description</label>
												<input type="text" name="variantDescription" value={v.description ?? ""} class={inputClass} placeholder="Optional" />
											</div>
											<div class="col-span-2 sm:col-span-4 flex flex-wrap gap-2 pt-1">
												<ManageBtn type="submit" variant="primary">Save variant</ManageBtn>
											</div>
										</form>

										<div class="mt-3 flex flex-wrap gap-2 border-t border-zinc-200 pt-3">
											<!-- Toggle active -->
											<form method="post" action={action}>
												<input type="hidden" name="_action" value="toggle-variant" />
												<input type="hidden" name="variantId" value={v.id} />
												<ManageBtn type="submit" variant={v.active ? "muted" : "success"}>
													{v.active ? "Deactivate" : "Activate"}
												</ManageBtn>
											</form>

											<!-- Sync Stripe -->
											{!v.stripePriceId && (
												<form method="post" action={action}>
													<input type="hidden" name="_action" value="sync-stripe" />
													<input type="hidden" name="variantId" value={v.id} />
													<ManageBtn type="submit" variant="secondary">Sync to Stripe</ManageBtn>
												</form>
											)}

											<!-- Delete -->
											<form method="post" action={action}>
												<input type="hidden" name="_action" value="delete-variant" />
												<input type="hidden" name="variantId" value={v.id} />
												<ManageBtn type="submit" variant="danger" confirm={`Delete variant "${v.name}"? Orders using it will be unaffected.`}>
													Delete variant
												</ManageBtn>
											</form>
										</div>
									</div>
								</details>
							</li>
						))}
					</ul>
				)}

				<!-- Add variant form -->
				<div class="border-t border-zinc-100 px-5 py-5">
					<p class="m-0 mb-3 font-display text-[10px] uppercase tracking-widest text-zinc-400">Add variant</p>
					<form method="post" action={action} class="grid grid-cols-2 gap-3 sm:grid-cols-5">
						<input type="hidden" name="_action" value="add-variant" />
						<div>
							<label class={labelClass}>Name <span class="text-red-500">*</span></label>
							<input type="text" name="variantName" required placeholder="Standard" class={inputClass} />
						</div>
						<div>
							<label class={labelClass}>Price (£) <span class="text-red-500">*</span></label>
							<input
								type="number"
								name="variantpriceUsd"
								placeholder="9.99"
								step="0.01"
								min="0"
								required
								class={inputClass}
							/>
						</div>
						<div>
							<label class={labelClass}>Max servers</label>
							<input type="number" name="variantMaxServers" placeholder="No limit" min="1" class={inputClass} />
						</div>
						<div>
							<label class={labelClass}>Description</label>
							<input type="text" name="variantDescription" placeholder="Optional" class={inputClass} />
						</div>
						<div class="flex items-end">
							<ManageBtn type="submit" variant="primary">Add</ManageBtn>
						</div>
					</form>
				</div>
			</section>

			<!-- ── Downloads / Files ──────────────────────────────────────────────── -->
			<section class="overflow-hidden rounded-xl border border-zinc-200 bg-white shadow-sm">
				<div class="border-b border-zinc-100 px-5 py-4">
					<h2 class="m-0 font-display text-xs uppercase tracking-[0.15em] text-zinc-500">
						Downloads
					</h2>
				</div>

				{product.files.length === 0 ? (
					<div class="px-5 py-6 text-center">
						<p class="m-0 text-sm text-zinc-400">No files uploaded yet.</p>
					</div>
				) : (
					<ul class="list-none divide-y divide-zinc-100 p-0">
						{product.files.map((f) => (
							<li class="flex flex-wrap items-center justify-between gap-4 px-5 py-3.5">
								<div class="min-w-0 flex-1">
									<p class="m-0 font-semibold text-brand-black">{f.label}</p>
									<p class="m-0 mt-0.5 font-mono text-xs text-zinc-400">
										v{f.version} &middot; {(f.sizeBytes / 1024).toFixed(0)} KB &middot;{" "}
										{f.uploadedAt.toLocaleDateString("en-GB")}
									</p>
								</div>
								<div class="flex shrink-0 items-center gap-2">
									<span class:list={["rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase", fileStatusClass(f.isLatest)]}>
										{f.isLatest ? "Latest" : "Old"}
									</span>
									<form method="post" action={action}>
										<input type="hidden" name="_action" value="delete-file" />
										<input type="hidden" name="fileId" value={f.id} />
										<ManageBtn type="submit" variant="danger" confirm={`Delete file "${f.label}" v${f.version}?`}>
											Delete
										</ManageBtn>
									</form>
								</div>
							</li>
						))}
					</ul>
				)}

				<!-- Upload new file -->
				<div class="border-t border-zinc-100 px-5 py-5">
					<p class="m-0 mb-3 font-display text-[10px] uppercase tracking-widest text-zinc-400">Upload new file</p>
					{r2Enabled ? (
						<form
							method="post"
							action={`/api/manage/products/${product.id}/files`}
							enctype="multipart/form-data"
							class="space-y-3"
						>
							<input type="hidden" name="_redirect" value={`/manage/products/${product.slug}`} />
							<div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
								<div>
									<label class={labelClass}>Label <span class="text-red-500">*</span></label>
									<input type="text" name="label" placeholder="Mod Archive" required class={inputClass} />
								</div>
								<div>
									<label class={labelClass}>Version <span class="text-red-500">*</span></label>
									<input type="text" name="version" placeholder="1.2.0" required class={inputClass} />
								</div>
							</div>
							<div>
								<label class={labelClass}>File <span class="text-red-500">*</span></label>
								<input
									type="file"
									name="file"
									required
									class="block w-full text-sm text-zinc-500 file:mr-4 file:rounded-lg file:border file:border-zinc-300 file:bg-white file:px-3 file:py-1.5 file:font-display file:text-[10px] file:uppercase file:tracking-wide file:text-zinc-600 hover:file:bg-zinc-50"
								/>
							</div>
							<ManageBtn type="submit" variant="primary">Upload file</ManageBtn>
						</form>
					) : (
						<div class="rounded-lg border border-dashed border-zinc-300 px-4 py-5 text-center">
							<p class="m-0 text-sm font-semibold text-zinc-500">Cloudflare R2 not configured</p>
							<p class="m-0 mt-1 text-xs text-zinc-400">
								Add <code class="rounded bg-zinc-100 px-1 text-zinc-600">R2_ACCOUNT_ID</code>,{" "}
								<code class="rounded bg-zinc-100 px-1 text-zinc-600">R2_ACCESS_KEY_ID</code>,{" "}
								<code class="rounded bg-zinc-100 px-1 text-zinc-600">R2_SECRET_ACCESS_KEY</code>, and{" "}
								<code class="rounded bg-zinc-100 px-1 text-zinc-600">R2_BUCKET</code> to your <code class="rounded bg-zinc-100 px-1 text-zinc-600">.env</code> to enable file uploads.
							</p>
						</div>
					)}
				</div>
			</section>

			<!-- ── Changelog ──────────────────────────────────────────────────────── -->
			<section class="overflow-hidden rounded-xl border border-zinc-200 bg-white shadow-sm">
				<div class="border-b border-zinc-100 px-5 py-4">
					<h2 class="m-0 font-display text-xs uppercase tracking-[0.15em] text-zinc-500">
						Changelog
					</h2>
				</div>

				{product.changelog.length === 0 ? (
					<div class="px-5 py-6 text-center">
						<p class="m-0 text-sm text-zinc-400">No changelog entries yet.</p>
					</div>
				) : (
					<ul class="list-none divide-y divide-zinc-100 p-0">
						{product.changelog.map((entry) => (
							<li class="flex items-start justify-between gap-4 px-5 py-4">
								<div class="min-w-0 flex-1">
									<p class="m-0 text-sm font-semibold text-brand-black">
										v{entry.version}
										<span class="ml-2 font-normal text-zinc-400 font-mono text-xs">
											{entry.createdAt.toLocaleDateString("en-GB")}
										</span>
									</p>
									<p class="m-0 mt-1 whitespace-pre-line text-sm text-zinc-500">{entry.notes}</p>
								</div>
								<form method="post" action={action} class="shrink-0">
									<input type="hidden" name="_action" value="delete-changelog" />
									<input type="hidden" name="changelogId" value={entry.id} />
									<ManageBtn type="submit" variant="danger" confirm="Delete this changelog entry?">
										Delete
									</ManageBtn>
								</form>
							</li>
						))}
					</ul>
				)}

				<!-- Add changelog entry -->
				<div class="border-t border-zinc-100 px-5 py-5">
					<p class="m-0 mb-3 font-display text-[10px] uppercase tracking-widest text-zinc-400">Add entry</p>
					<form method="post" action={action} class="space-y-3">
						<input type="hidden" name="_action" value="add-changelog" />
						<div class="grid grid-cols-1 gap-3 sm:grid-cols-4">
							<div>
								<label class={labelClass}>Version <span class="text-red-500">*</span></label>
								<input type="text" name="changelogVersion" placeholder="1.3.0" required class={inputClass} />
							</div>
							<div class="sm:col-span-3">
								<label class={labelClass}>Notes <span class="text-red-500">*</span></label>
								<textarea
									name="changelogNotes"
									placeholder="What changed in this release..."
									required
									rows="3"
									class={inputClass}
								/>
							</div>
						</div>
						<ManageBtn type="submit" variant="primary">Add entry</ManageBtn>
					</form>
				</div>
			</section>
		</>
	)}
</div>

<script>
	// Auto-generate slug from title on new product form
	const titleInput = document.getElementById("product-title") as HTMLInputElement | null;
	const slugInput = document.getElementById("product-slug") as HTMLInputElement | null;

	if (titleInput && slugInput && !slugInput.value) {
		titleInput.addEventListener("input", () => {
			slugInput.value = titleInput.value
				.toLowerCase()
				.replace(/[^a-z0-9]+/g, "-")
				.replace(/^-+|-+$/g, "");
		});
	}
</script>

---
interface Props {
	heading?: string;
}

const { heading } = Astro.props;
---

<section class="w-full max-w-none text-left">
	{heading ? (
		<h2 class="m-0 mb-4 font-display text-[clamp(1.35rem,3vw,1.75rem)] font-medium uppercase tracking-[0.12em] text-brand-black">
			{heading}
		</h2>
	) : null}
	<div class="flex flex-col gap-4 text-[15px] leading-relaxed text-zinc-700 sm:text-base">
		<slot />
	</div>
</section>

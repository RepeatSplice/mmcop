---
import type { Partner } from "../lib/partners";

interface Props {
	partners: Partner[];
	kicker?: string;
	heading?: string;
	text?: string;
	ctaLabel?: string;
	ctaHref?: string;
}

const {
	partners,
	kicker = "Our partners",
	heading = "Studios, servers & creator brands",
	text = "Brands and creators we work with across modding, live play, hosting, and community content.",
	ctaLabel = "View all partners",
	ctaHref = "/partners",
} = Astro.props;
---

<section class="partners-brand" id="partners" aria-labelledby="partners-heading" data-scroll-reveal>
	<div class="partners-brand__inner">
		<div class="partners-brand__grid" role="list">
			{
				partners.map((p) => {
					const tileClass = "partners-brand__tile";
					const img = (
						<span class="partners-brand__logo">
							<img
								src={p.logo}
								alt=""
								width="260"
								height="96"
								loading="lazy"
								decoding="async"
							/>
						</span>
					);

					return p.href ? (
						<a
							class={tileClass}
							href={p.href}
							target="_blank"
							rel="noopener noreferrer"
							role="listitem"
							aria-label={`${p.name} (opens in new tab)`}
						>
							{img}
						</a>
					) : (
						<div class={tileClass} role="listitem" aria-label={p.name}>
							{img}
						</div>
					);
				})
			}
		</div>

		<div class="partners-brand__copy">
			<div class="partners-brand__copy-head">
				<p class="partners-brand__kicker">{kicker}</p>
				<h2 class="partners-brand__heading st-reveal" id="partners-heading">
					{heading}
				</h2>
				<div class="partners-brand__text st-reveal">
					<p>{text}</p>
				</div>
			</div>
			<a class="partners-brand__btn st-reveal" href={ctaHref}>
				{ctaLabel}
			</a>
		</div>
	</div>
</section>

<style>
	.partners-brand {
		padding: 0;
	}

	.partners-brand__inner {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.75rem;
		align-items: stretch;
	}

	.partners-brand__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		grid-auto-rows: 5rem;
		gap: 0.875rem;
	}

	.partners-brand__tile {
		height: 5rem;
		border-radius: 1rem;
		border: 1px solid rgba(0, 0, 0, 0.08);
		background: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		overflow: hidden;
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease;
		padding: 0;
	}

	.partners-brand__logo {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 78%;
		height: 62%;
	}

	.partners-brand__tile img {
		width: 100%;
		height: 100%;
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
		display: block;
		opacity: 0.42;
		filter: grayscale(1);
		transform: none;
		transition:
			opacity 0.3s ease,
			filter 0.3s ease;
	}

	a.partners-brand__tile:hover {
		transform: translateY(-2px);
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
	}

	a.partners-brand__tile:focus-visible {
		outline: 2px solid var(--color-monarch-500, #355a7a);
		outline-offset: 2px;
	}

	a.partners-brand__tile:hover img,
	a.partners-brand__tile:focus-visible img {
		opacity: 1;
		filter: grayscale(0);
	}

	.partners-brand__copy {
		display: flex;
		flex-direction: column;
		max-width: 26.25rem;
	}

	.partners-brand__kicker {
		margin: 0 0 0.625rem;
		font-family: var(--font-display, "Oswald", sans-serif);
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(0, 0, 0, 0.55);
	}

	.partners-brand__heading {
		margin: 0 0 0.75rem;
		font-family: var(--font-display, "Oswald", sans-serif);
		font-size: clamp(1.35rem, 2.5vw, 1.75rem);
		font-weight: 500;
		line-height: 1.1;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--color-brand-black, #0a0a0a);
	}

	.partners-brand__text {
		color: rgba(0, 0, 0, 0.65);
		line-height: 1.6;
		margin-bottom: 1.125rem;
		font-size: 0.9375rem;
	}

	.partners-brand__text p {
		margin: 0;
	}

	.partners-brand__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 2.75rem;
		padding: 0 1.125rem;
		border-radius: 0.625rem;
		border: 1px solid rgba(0, 0, 0, 0.25);
		text-decoration: none;
		font-family: var(--font-display, "Oswald", sans-serif);
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: #000;
		background: #fff;
		margin-top: auto;
		transition:
			border-color 0.18s ease,
			background-color 0.18s ease;
	}

	.partners-brand__btn:hover {
		border-color: rgba(0, 0, 0, 0.45);
		background: rgba(0, 0, 0, 0.02);
	}

	.partners-brand__btn:focus-visible {
		outline: 2px solid var(--color-monarch-500, #355a7a);
		outline-offset: 2px;
	}

	@media (min-width: 990px) {
		.partners-brand__inner {
			grid-template-columns: minmax(0, 1fr) auto;
			gap: 3.5rem;
		}

		.partners-brand__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			grid-auto-rows: 6.5rem;
			gap: 1.125rem;
		}

		.partners-brand__tile {
			height: 6.5rem;
		}

		.partners-brand__copy {
			justify-content: flex-start;
			min-height: 100%;
		}
	}

	@media (max-width: 989px) {
		.partners-brand__inner {
			display: flex;
			flex-direction: column;
		}

		.partners-brand__copy {
			display: contents;
			max-width: none;
		}

		.partners-brand__copy-head {
			order: 1;
			margin-bottom: 0;
		}

		.partners-brand__grid {
			order: 2;
		}

		.partners-brand__btn {
			order: 3;
			width: 100%;
			max-width: none;
			height: 3rem;
			font-size: 0.8125rem;
			letter-spacing: 0.16em;
			margin-top: 0;
		}
	}
</style>

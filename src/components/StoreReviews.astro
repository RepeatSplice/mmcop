---
import { getStoreReviews } from "../lib/reviews";

const reviews = await getStoreReviews(6);
if (!reviews || reviews.length === 0) return;
---

<section class="py-2">
	<header class="mb-8 text-center">
		<p class="m-0 font-display text-xs uppercase tracking-[0.18em] text-monarch-500">What people say</p>
		<h2 class="m-0 mt-2 font-display text-2xl font-medium uppercase tracking-[0.1em] text-brand-black">
			Customer reviews
		</h2>
	</header>

	<div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
		{reviews.map((review) => (
			<div class="flex flex-col gap-3 border border-zinc-200 bg-white p-5">
				{/* Stars */}
				<div class="flex gap-0.5" aria-label={`${review.rating} out of 5 stars`}>
					{[1, 2, 3, 4, 5].map((n) => (
						<svg
							class={`h-4 w-4 ${n <= review.rating ? "text-amber-400" : "text-zinc-200"}`}
							viewBox="0 0 20 20"
							fill="currentColor"
							aria-hidden="true"
						>
							<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
						</svg>
					))}
				</div>

				{/* Review body */}
				{review.title && (
					<p class="m-0 text-sm font-semibold text-brand-black">{review.title}</p>
				)}
				<p class="m-0 flex-1 text-sm leading-relaxed text-zinc-600">
					{review.body.length > 200 ? review.body.slice(0, 200).trimEnd() + "..." : review.body}
				</p>

				{/* Author */}
				<div class="flex items-center gap-2.5 border-t border-zinc-100 pt-3">
					<div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-monarch-500 font-display text-sm font-semibold uppercase text-white">
						{review.customer.displayName.charAt(0)}
					</div>
					<div>
						<p class="m-0 text-xs font-semibold text-brand-black">{review.customer.displayName}</p>
						<p class="m-0 text-[11px] text-zinc-400">
							{review.createdAt.toLocaleDateString("en-GB", { month: "long", year: "numeric" })}
						</p>
					</div>
				</div>
			</div>
		))}
	</div>
</section>

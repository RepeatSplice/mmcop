{
  "name": "mm",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "prisma generate && astro build",
    "start": "node ./dist/server/entry.mjs",
    "preview": "astro preview",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "search:index": "tsx src/scripts/algolia-index.ts",
    "astro": "astro",
    "dev:portal": "npm run dev --workspace=apps/portal",
    "dev:bot": "npm run dev --workspace=apps/discord-bot",
    "build:portal": "npm run build --workspace=apps/portal",
    "build:bot": "npm run build --workspace=apps/discord-bot",
    "prisma:generate:portal": "npm run prisma:generate --workspace=apps/portal"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.1",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@iconify-json/circle-flags": "^1.2.10",
    "@iconify-json/lucide": "^1.2.108",
    "@iconify-json/simple-icons": "^1.2.82",
    "@prisma/client": "^6.19.0",
    "algoliasearch": "^5.55.1",
    "astro": "^6.3.3",
    "astro-icon": "^1.1.5",
    "bcrypt": "^6.0.0",
    "gsap": "^3.15.0",
    "marked": "^15.0.12",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "resend": "^4.8.0",
    "sanitize-html": "^2.17.0",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/sanitize-html": "^2.16.0",
    "dotenv": "^17.4.2",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.20.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
